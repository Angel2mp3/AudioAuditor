<Window x:Class="AudioQualityChecker.DuplicateDetectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="560" Width="720"
        MinHeight="350" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Border CornerRadius="10" Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBg}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Duplicate Detection" FontWeight="SemiBold" FontSize="14"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="16,0,0,0"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Click="Close_Click" Cursor="Hand"
                            Background="Transparent" BorderBrush="Transparent"
                            Foreground="{DynamicResource TextMuted}" FontSize="16" Padding="8,2"/>
                </Grid>
            </Border>

            <!-- Controls -->
            <StackPanel Grid.Row="1" Margin="16,8,16,0" Orientation="Horizontal">
                <Button x:Name="BtnScan" Content="Scan for Duplicates" Click="Scan_Click" Cursor="Hand"
                        Padding="14,6" Background="{DynamicResource AccentColor}" Foreground="White"
                        BorderBrush="Transparent" FontWeight="SemiBold" FontSize="12" FontFamily="Segoe UI"/>
                <TextBlock x:Name="ProgressText" Foreground="{DynamicResource TextMuted}" FontSize="12"
                           FontFamily="Segoe UI" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <!-- Results -->
            <Border Grid.Row="2" Margin="16,10,16,0" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    CornerRadius="4" Background="{DynamicResource InputBg}">
                <TreeView x:Name="ResultTree" Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource TextPrimary}" FontSize="12" FontFamily="Segoe UI"/>
            </Border>

            <!-- Summary -->
            <TextBlock Grid.Row="3" x:Name="SummaryText" Foreground="{DynamicResource TextMuted}" FontSize="12"
                       FontFamily="Segoe UI" Margin="16,8,16,14"/>
        </Grid>
    </Border>
</Window>
