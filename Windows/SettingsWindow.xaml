<Window x:Class="AudioQualityChecker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="720" Width="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Themed ComboBox ToggleButton -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="22"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="{DynamicResource InputBg}"
                        BorderBrush="{DynamicResource ButtonBorder}"
                        BorderThickness="1" CornerRadius="3"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource TextMuted}"
                      StrokeThickness="1.5" HorizontalAlignment="Center"
                      VerticalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush"
                            Value="{DynamicResource AccentColor}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Themed ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,4,24,4" VerticalAlignment="Center"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource PanelBg}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1" CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300" Margin="0,2,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SelectionBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small themed button -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBorder" Width="16" Height="16"
                                    Background="{DynamicResource InputBg}"
                                    BorderBrush="{DynamicResource ButtonBorder}"
                                    BorderThickness="1" CornerRadius="3"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock x:Name="checkMark" Text="&#xE73E;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed Crossfade Slider Style -->
        <Style x:Key="CrossfadeSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Center" CornerRadius="2"
                                    Background="{DynamicResource ScrollBg}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentColor}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource ButtonBorder}"
                                                         StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Stroke"
                                                                Value="{DynamicResource AccentColor}"/>
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <ScrollViewer.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
                    <Setter Property="Width" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton OverridesDefaultStyle="True" Background="Transparent" Focusable="False" IsTabStop="False" Command="ScrollBar.PageUpCommand">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb OverridesDefaultStyle="True" IsTabStop="False">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="thumbBd" Background="{DynamicResource ScrollThumb}" CornerRadius="4" Margin="2">
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="thumbBd" Property="Background" Value="{DynamicResource ScrollThumbHover}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton OverridesDefaultStyle="True" Background="Transparent" Focusable="False" IsTabStop="False" Command="ScrollBar.PageDownCommand">
                                                <RepeatButton.Template>
                                                    <ControlTemplate TargetType="RepeatButton">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </RepeatButton.Template>
                                            </RepeatButton>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ScrollViewer.Resources>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with drag + close -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown">
                <TextBlock Text="Settings"
                           FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"/>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="Close_Click" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="{DynamicResource TextMuted}" Padding="6,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#44FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Theme Section -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Color Theme:"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ThemeCombo" FontSize="13"
                              SelectionChanged="ThemeCombo_SelectionChanged"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Playbar Style:"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="PlaybarCombo" FontSize="13"
                              SelectionChanged="PlaybarCombo_SelectionChanged"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Visualizer Style:"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" x:Name="VisualizerThemeCombo" FontSize="13"
                              SelectionChanged="VisualizerThemeCombo_SelectionChanged"/>
                </Grid>
            </StackPanel>

            <!-- Play Options Section -->
            <StackPanel Grid.Row="4">
                <TextBlock Text="Play Options" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,10"/>

                <CheckBox x:Name="ChkAutoPlay" Content="Auto-Play next song"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,0,0,8"
                          Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>

                <CheckBox x:Name="ChkNormalization" Content="Audio Normalization"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,0,0,8"
                          Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>

                <CheckBox x:Name="ChkCrossfade" Content="Crossfade"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,0,0,4"
                          Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>

                <StackPanel Orientation="Horizontal" Margin="22,6,0,0"
                            IsEnabled="{Binding IsChecked, ElementName=ChkCrossfade}">
                    <TextBlock Text="Duration:" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Slider x:Name="CrossfadeSlider" Minimum="1" Maximum="10" Value="3"
                            Width="140" IsSnapToTickEnabled="True" TickFrequency="1"
                            ValueChanged="CrossfadeSlider_Changed"
                            VerticalAlignment="Center"
                            Style="{StaticResource CrossfadeSlider}"/>
                    <TextBlock x:Name="CrossfadeDurationLabel" Text="3s" FontSize="12"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" Margin="8,0,0,0" Width="24"/>
                </StackPanel>

                <CheckBox x:Name="ChkSpatialAudio" Content="Spatial Audio (Headphones)"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,10,0,0"
                          Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>
                <TextBlock Text="Creates a wider, room-like soundstage for headphone listening using crossfeed and stereo widening."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                <CheckBox x:Name="ChkVisualizerFullVolume" Content="Visualizer Full Volume"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,10,0,0"
                          Checked="VisualizerFullVolume_Changed" Unchecked="VisualizerFullVolume_Changed"/>
                <TextBlock Text="Makes the visualizer always respond as if the volume is at 100%, even when you lower it. Keeps the visual effects lively at any volume level."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                <!-- Visualizer Cycle Settings -->
                <TextBlock Text="Visualizer Cycle" FontSize="13" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,14,0,6"/>
                <TextBlock Text="When cycling, automatically switches between visualizer styles."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Speed:" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                               Margin="0,0,8,0"/>
                    <Slider x:Name="CycleSpeedSlider" Minimum="5" Maximum="60" Value="10"
                            Width="140" IsSnapToTickEnabled="True" TickFrequency="5"
                            ValueChanged="CycleSpeedSlider_Changed"
                            VerticalAlignment="Center"
                            Style="{StaticResource CrossfadeSlider}"/>
                    <TextBlock x:Name="CycleSpeedLabel" Text="10s" FontSize="12"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center" Margin="8,0,0,0" Width="28"/>
                </StackPanel>
                <TextBlock Text="Custom cycle selection (check styles to include):"
                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <WrapPanel x:Name="CycleStyleChecks" Margin="0,0,0,0">
                    <CheckBox x:Name="ChkCycleBars" Content="Bars" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                    <CheckBox x:Name="ChkCycleMirror" Content="Mirror" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                    <CheckBox x:Name="ChkCycleParticles" Content="Particles" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                    <CheckBox x:Name="ChkCycleCircles" Content="Circles" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                    <CheckBox x:Name="ChkCycleScope" Content="Scope" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                    <CheckBox x:Name="ChkCycleKaleido" Content="Abstract" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                    <CheckBox x:Name="ChkCycleVU" Content="VU Meter" Margin="0,0,12,4"
                              Foreground="{DynamicResource TextSecondary}" FontSize="12"
                              FontFamily="Segoe UI" IsChecked="True"
                              Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                </WrapPanel>

            </StackPanel>

            <!-- Music Services Section -->
            <StackPanel Grid.Row="6">
                <TextBlock Text="Music Service Buttons" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Configure each of the 6 toolbar search buttons. Select 'Custom...' for any slot to set your own URL and icon."
                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <!-- Slot 1 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Slot 1:" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ServiceCombo0" Tag="0" FontSize="12"
                              SelectionChanged="ServiceCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomPanel0" Visibility="Collapsed" Margin="20,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="URL:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomUrlBox0" Width="340" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" Tag="0" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"
                                 TextChanged="CustomUrl_Changed"
                                 ToolTip="Search URL — song name will be appended"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Icon:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomIconBox0" Width="280" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" IsReadOnly="True" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"/>
                        <Button Content="Browse..." Margin="4,0,0,0" Style="{StaticResource SmallButton}"
                                Tag="0" Click="BrowseIcon_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Slot 2 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Slot 2:" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ServiceCombo1" Tag="1" FontSize="12"
                              SelectionChanged="ServiceCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomPanel1" Visibility="Collapsed" Margin="20,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="URL:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomUrlBox1" Width="340" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" Tag="1" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"
                                 TextChanged="CustomUrl_Changed"
                                 ToolTip="Search URL — song name will be appended"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Icon:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomIconBox1" Width="280" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" IsReadOnly="True" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"/>
                        <Button Content="Browse..." Margin="4,0,0,0" Style="{StaticResource SmallButton}"
                                Tag="1" Click="BrowseIcon_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Slot 3 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Slot 3:" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ServiceCombo2" Tag="2" FontSize="12"
                              SelectionChanged="ServiceCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomPanel2" Visibility="Collapsed" Margin="20,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="URL:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomUrlBox2" Width="340" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" Tag="2" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"
                                 TextChanged="CustomUrl_Changed"
                                 ToolTip="Search URL — song name will be appended"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Icon:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomIconBox2" Width="280" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" IsReadOnly="True" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"/>
                        <Button Content="Browse..." Margin="4,0,0,0" Style="{StaticResource SmallButton}"
                                Tag="2" Click="BrowseIcon_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Slot 4 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Slot 4:" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ServiceCombo3" Tag="3" FontSize="12"
                              SelectionChanged="ServiceCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomPanel3" Visibility="Collapsed" Margin="20,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="URL:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomUrlBox3" Width="340" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" Tag="3" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"
                                 TextChanged="CustomUrl_Changed"
                                 ToolTip="Search URL — song name will be appended"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Icon:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomIconBox3" Width="280" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" IsReadOnly="True" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"/>
                        <Button Content="Browse..." Margin="4,0,0,0" Style="{StaticResource SmallButton}"
                                Tag="3" Click="BrowseIcon_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Slot 5 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Slot 5:" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ServiceCombo4" Tag="4" FontSize="12"
                              SelectionChanged="ServiceCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomPanel4" Visibility="Collapsed" Margin="20,0,0,8">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="URL:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomUrlBox4" Width="340" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" Tag="4" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"
                                 TextChanged="CustomUrl_Changed"
                                 ToolTip="Search URL — song name will be appended"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Icon:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomIconBox4" Width="280" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" IsReadOnly="True" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"/>
                        <Button Content="Browse..." Margin="4,0,0,0" Style="{StaticResource SmallButton}"
                                Tag="4" Click="BrowseIcon_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Slot 6 -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Slot 6:" FontSize="12" FontFamily="Segoe UI"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ServiceCombo5" Tag="5" FontSize="12"
                              SelectionChanged="ServiceCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomPanel5" Visibility="Collapsed" Margin="20,0,0,4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="URL:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomUrlBox5" Width="340" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" Tag="5" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextPrimary}"
                                 CaretBrush="{DynamicResource TextPrimary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"
                                 TextChanged="CustomUrl_Changed"
                                 ToolTip="Search URL — song name will be appended"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Icon:" FontSize="11" FontFamily="Segoe UI" Width="40"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                        <TextBox x:Name="CustomIconBox5" Width="280" FontSize="11" FontFamily="Segoe UI"
                                 Padding="4,3" IsReadOnly="True" Background="{DynamicResource InputBg}"
                                 Foreground="{DynamicResource TextSecondary}"
                                 BorderBrush="{DynamicResource ButtonBorder}"/>
                        <Button Content="Browse..." Margin="4,0,0,0" Style="{StaticResource SmallButton}"
                                Tag="5" Click="BrowseIcon_Click"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Integrations Section -->
            <StackPanel Grid.Row="8">
                <TextBlock Text="Integrations" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,10"/>

                <!-- Discord Rich Presence -->
                <TextBlock Text="Discord Rich Presence" FontSize="13" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Shows your currently playing track in your Discord status."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,6" TextWrapping="Wrap"/>

                <TextBlock Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,8" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}">Setup:</Run>
                    <Run>1. Go to</Run>
                    <Run FontWeight="SemiBold">discord.com/developers/applications</Run>
                    <Run>→ New Application</Run>
                    <LineBreak/>
                    <Run>2. Copy the</Run>
                    <Run FontWeight="SemiBold">Application ID</Run>
                    <Run>(on the General Information page) and paste below</Run>
                    <LineBreak/>
                    <Run>3. (Optional) Go to Rich Presence → Art Assets, upload an icon named</Run>
                    <Run FontWeight="SemiBold">audioauditor</Run>
                </TextBlock>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Style="{StaticResource SmallButton}" Click="DiscordCreateApp_Click"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Open Discord Developer Portal" FontSize="11" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" &#x2197;" FontSize="12" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SmallButton}" Click="DiscordDownloadLogo_Click"
                            HorizontalAlignment="Left" Margin="6,0,0,0" Padding="6,3"
                            ToolTip="Save the AudioAuditor icon to your Downloads folder for use as a Rich Presence asset">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2B73; Logo" FontSize="11" FontFamily="Segoe UI"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Application ID:"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Column="1" x:Name="DiscordAppIdBox"
                             FontSize="12" FontFamily="Segoe UI" Padding="4,3"
                             Background="{DynamicResource InputBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             CaretBrush="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             TextChanged="DiscordAppId_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Eye toggle for Discord App ID -->
                    <Button Grid.Column="2"
                            x:Name="BtnToggleDiscordIdVisibility"
                            Click="ToggleDiscordIdVisibility_Click"
                            VerticalAlignment="Center" Margin="6,0,0,0"
                            Cursor="Hand" ToolTip="Show/Hide Application ID"
                            Background="Transparent" BorderBrush="Transparent"
                            Padding="4,2">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background"
                                                Value="{DynamicResource ButtonHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Canvas Width="20" Height="16">
                            <Path x:Name="DiscordEyeIcon"
                                  Data="M10,4 C5,4 1.5,8 1.5,8 C1.5,8 5,12 10,12 C15,12 18.5,8 18.5,8 C18.5,8 15,4 10,4 Z"
                                  Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3" Fill="Transparent"/>
                            <Ellipse Canvas.Left="7.5" Canvas.Top="5.5" Width="5" Height="5"
                                     Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2" Fill="Transparent"/>
                            <Line x:Name="DiscordEyeSlash" X1="3" Y1="14" X2="17" Y2="2"
                                  Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"/>
                        </Canvas>
                    </Button>
                </Grid>

                <CheckBox x:Name="ChkDiscordRpc" Content="Enable Discord Rich Presence"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,4,0,8"
                          Checked="DiscordRpc_Changed" Unchecked="DiscordRpc_Changed"/>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Display Mode:"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="DiscordDisplayModeCombo"
                              FontSize="12" SelectionChanged="DiscordDisplayMode_Changed"/>
                </Grid>

                <CheckBox x:Name="ChkDiscordShowElapsed" Content="Show elapsed time"
                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                          FontFamily="Segoe UI" Margin="0,2,0,4"
                          Checked="DiscordShowElapsed_Changed" Unchecked="DiscordShowElapsed_Changed"/>

                <TextBlock x:Name="DiscordStatusText" Text=""
                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Last.fm Section -->
            <StackPanel Grid.Row="10">
                <TextBlock Text="Last.fm Scrobbling" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Scrobbles tracks to your Last.fm account."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,0,0,8" TextWrapping="Wrap"/>

                <Button Style="{StaticResource SmallButton}" Click="LastFmCreateApiKey_Click"
                        HorizontalAlignment="Left" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Create API Key" FontSize="11" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" &#x2197;" FontSize="12" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key:"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="LastFmApiKeyBox"
                             FontSize="12" FontFamily="Segoe UI" Padding="4,3"
                             Background="{DynamicResource InputBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             CaretBrush="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             TextChanged="LastFmKey_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="API Secret:"
                               FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="LastFmApiSecretBox"
                             FontSize="12" FontFamily="Segoe UI" Padding="4,3"
                             Background="{DynamicResource InputBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             CaretBrush="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             TextChanged="LastFmKey_Changed">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Eye toggle button spanning both rows on the right -->
                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                            x:Name="BtnToggleApiVisibility"
                            Click="ToggleApiVisibility_Click"
                            VerticalAlignment="Center" Margin="6,0,0,0"
                            Cursor="Hand" ToolTip="Show/Hide API keys"
                            Background="Transparent" BorderBrush="Transparent"
                            Padding="4,2">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background"
                                                Value="{DynamicResource ButtonHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Canvas Width="20" Height="16">
                            <!-- Eye icon -->
                            <Path x:Name="EyeIcon"
                                  Data="M10,4 C5,4 1.5,8 1.5,8 C1.5,8 5,12 10,12 C15,12 18.5,8 18.5,8 C18.5,8 15,4 10,4 Z"
                                  Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3" Fill="Transparent"/>
                            <Ellipse Canvas.Left="7.5" Canvas.Top="5.5" Width="5" Height="5"
                                     Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2" Fill="Transparent"/>
                            <!-- Slash line (visible by default = hidden) -->
                            <Line x:Name="EyeSlash" X1="3" Y1="14" X2="17" Y2="2"
                                  Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"/>
                        </Canvas>
                    </Button>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button x:Name="BtnLastFmAuth" Content="Authenticate"
                            Style="{StaticResource SmallButton}" Click="LastFmAuth_Click"
                            Margin="0,0,10,0"/>
                    <Button x:Name="BtnLastFmConfirm" Content="Confirm Auth"
                            Style="{StaticResource SmallButton}" Click="LastFmConfirm_Click"
                            Visibility="Collapsed" Margin="0,0,10,0"/>
                    <TextBlock x:Name="LastFmStatusText" Text=""
                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Note -->
            <TextBlock Grid.Row="12"
                       Text="All playback options are off by default. Music service buttons search for the selected song."
                       Foreground="{DynamicResource TextMuted}" FontSize="11"
                       FontFamily="Segoe UI" FontStyle="Italic" TextWrapping="Wrap"/>

            <!-- Export Format Section -->
            <StackPanel Grid.Row="14">
                <TextBlock Text="Export" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Default Format:"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ExportFormatCombo" FontSize="13"
                              SelectionChanged="ExportFormatCombo_Changed"/>
                </Grid>
            </StackPanel>

            <!-- Performance Section -->
            <StackPanel Grid.Row="16">
                <TextBlock Text="Performance" FontSize="14" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CPU Usage Limit:"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="ConcurrencyCombo" FontSize="13"
                              SelectionChanged="ConcurrencyCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomCpuPanel" Orientation="Horizontal" Margin="130,6,0,0" Visibility="Collapsed">
                    <TextBox x:Name="CustomCpuBox" Width="80" FontSize="13" FontFamily="Segoe UI"
                             Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource ButtonBorder}" Padding="4,2"
                             TextChanged="CustomCpu_Changed"/>
                    <TextBlock Text=" threads" FontSize="13" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="ConcurrencyInfoText" Text=""
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Memory Limit:"
                               FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox Grid.Column="1" x:Name="MemoryLimitCombo" FontSize="13"
                              SelectionChanged="MemoryLimitCombo_Changed"/>
                </Grid>
                <StackPanel x:Name="CustomMemPanel" Orientation="Horizontal" Margin="130,6,0,0" Visibility="Collapsed">
                    <TextBox x:Name="CustomMemBox" Width="80" FontSize="13" FontFamily="Segoe UI"
                             Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource ButtonBorder}" Padding="4,2"
                             TextChanged="CustomMem_Changed"/>
                    <TextBlock Text=" MB" FontSize="13" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="MemoryInfoText" Text=""
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- AI Detection Section -->
            <StackPanel Grid.Row="18">
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="AI Detection" FontSize="14" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Show AI Setup" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource AccentColor}" Cursor="Hand"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               MouseLeftButtonDown="ShowAiSetup_Click"
                               TextDecorations="Underline" Margin="0,1,0,0"/>
                </DockPanel>

                <!-- Default (watermark) detector — always available -->
                <CheckBox x:Name="ChkDefaultAi" Content="Default AI Detection (Watermark / Metadata)"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,0,0,2" IsChecked="True" IsEnabled="False"/>
                <TextBlock Text="Scans metadata, watermarks, and known AI markers. Always enabled, unlimited, no network needed."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="22,2,0,8" TextWrapping="Wrap"/>

                <!-- Experimental spectral detector -->
                <CheckBox x:Name="ChkExperimentalAi" Content="Aggressive AI Detection (Spectral Analysis)"
                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                          FontFamily="Segoe UI" Margin="0,0,0,2"
                          Checked="ExperimentalAi_Changed" Unchecked="ExperimentalAi_Changed"/>
                <TextBlock Text="⚠ Uses spectral analysis (ultrasonic energy, stereo correlation, spectral regularity) to detect AI-generated audio. This will produce more false positives than standard detection but can catch AI audio that has been stripped of metadata markers."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="22,2,0,8" TextWrapping="Wrap"/>

                <!-- SH Labs API detector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                    <CheckBox x:Name="ChkSHLabsAi" Content="SH Labs AI Audio Detection (API)"
                              Foreground="{DynamicResource TextSecondary}" FontSize="13"
                              FontFamily="Segoe UI"
                              Checked="SHLabsAi_Changed" Unchecked="SHLabsAi_Changed"/>
                    <TextBlock x:Name="SHLabsPrivacyIcon" Text=" ⚠️" FontSize="14"
                               VerticalAlignment="Center" Cursor="Hand"
                               ToolTip="View SH Labs privacy information"
                               MouseLeftButtonDown="SHLabsPrivacyIcon_Click"/>
                </StackPanel>
                <TextBlock Text="AI audio detection via SH Labs. Can sometimes be more accurate than the other options but limited to 15 scans/day and 100/month. When the limit is reached, your other selected detection methods will be used instead."
                           Foreground="{DynamicResource TextDim}" FontSize="11"
                           FontFamily="Segoe UI" Margin="22,2,0,4" TextWrapping="Wrap"/>
                <TextBlock x:Name="SHLabsQuotaText" Text=""
                           Foreground="{DynamicResource AccentColor}" FontSize="11"
                           FontFamily="Segoe UI" Margin="22,0,0,6"/>

                <!-- Custom API Key -->
                <TextBlock Text="Use your own SH Labs API key (optional):" FontSize="11.5"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                           Margin="22,4,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="22,0,0,2">
                    <TextBox x:Name="SHLabsApiKeyBox" Width="280" FontSize="12"
                             FontFamily="Segoe UI" Padding="4,3"
                             Background="{DynamicResource InputBg}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             TextChanged="SHLabsApiKey_Changed"/>
                    <Button Content="Clear" FontSize="11" FontFamily="Segoe UI" Margin="8,0,0,0"
                            Click="SHLabsApiKeyClear_Click" Cursor="Hand" Padding="8,3"
                            Background="{DynamicResource ButtonBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource ButtonBorder}"/>
                </StackPanel>
                <TextBlock Text="With your own key, audio goes directly to SH Labs — no proxy, no rate limits, no data collection by AudioAuditor."
                           Foreground="{DynamicResource TextDim}" FontSize="10.5"
                           FontFamily="Segoe UI" Margin="22,3,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Attribution -->
            <Grid Grid.Row="20" Margin="0,8,0,4">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontFamily="Segoe UI">
                    <Run Text="Made with " Foreground="{DynamicResource TextMuted}"/><Run Text="&#x2764;" Foreground="#E25555" FontSize="13"/><Run Text=" by " Foreground="{DynamicResource TextMuted}"/><Hyperlink x:Name="AuthorLink" NavigateUri="https://github.com/Angel2mp3" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentColor}" TextDecorations="None">Angel</Hyperlink>
                </TextBlock>
            </Grid>

            <!-- Support button + Close -->
            <Grid Grid.Row="22" Margin="0,8,0,4">
                <Button Click="SupportDonate_Click" Cursor="Hand"
                        HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="supportBd" Background="{DynamicResource ButtonBg}"
                                    BorderBrush="{DynamicResource ButtonBorder}"
                                    BorderThickness="1" CornerRadius="5" Padding="18,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Support AudioAuditor" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" ❤" FontSize="14" Foreground="#E25555"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="supportBd" Property="Background"
                                            Value="{DynamicResource ButtonHover}"/>
                                    <Setter TargetName="supportBd" Property="BorderBrush"
                                            Value="{DynamicResource AccentColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Content="Close" Width="90"
                        Click="Close_Click" Padding="12,6"
                        Background="{DynamicResource ButtonBg}"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource ButtonBorder}"
                        FontFamily="Segoe UI" FontSize="13" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background"
                                            Value="{DynamicResource ButtonHover}"/>
                                    <Setter TargetName="bd" Property="BorderBrush"
                                            Value="{DynamicResource AccentColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
        </ScrollViewer>
    </Border>
</Window>
