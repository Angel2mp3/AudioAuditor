                                         Background="{DynamicResource InputBg}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource ButtonBorder}"
                                         TextChanged="DiscordAppId_Changed"/>
                                <Button Grid.Column="2"
                                        x:Name="BtnToggleDiscordIdVisibility"
                                        Click="ToggleDiscordIdVisibility_Click"
                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                        Cursor="Hand" ToolTip="Show/Hide Application ID"
                                        Background="Transparent" BorderBrush="Transparent"
                                        Padding="4,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource ButtonHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
