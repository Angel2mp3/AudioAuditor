                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="API Key:"
                                           FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="LastFmApiKeyBox"
                                         FontSize="12" FontFamily="Segoe UI" Padding="4,3"
                                         Background="{DynamicResource InputBg}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource ButtonBorder}"
                                         TextChanged="LastFmKey_Changed"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="API Secret:"
                                           FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="LastFmApiSecretBox"
                                         FontSize="12" FontFamily="Segoe UI" Padding="4,3"
                                         Background="{DynamicResource InputBg}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource ButtonBorder}"
                                         TextChanged="LastFmKey_Changed"/>

                                <!-- Eye toggle button spanning both rows -->
                                <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                        x:Name="BtnToggleApiVisibility"
                                        Click="ToggleApiVisibility_Click"
                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                        Cursor="Hand" ToolTip="Show/Hide API keys"
                                        Background="Transparent" BorderBrush="Transparent"
                                        Padding="4,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource ButtonHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Canvas Width="20" Height="16">
                                        <Path x:Name="EyeIcon"
                                              Data="M10,4 C5,4 1.5,8 1.5,8 C1.5,8 5,12 10,12 C15,12 18.5,8 18.5,8 C18.5,8 15,4 10,4 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="7.5" Canvas.Top="5.5" Width="5" Height="5"
                                                 Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2" Fill="Transparent"/>
                                        <Line x:Name="EyeSlash" X1="3" Y1="14" X2="17" Y2="2"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"/>
                                    </Canvas>
                                </Button>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button x:Name="BtnLastFmAuth" Content="Authenticate"
                                        Style="{StaticResource SmallButton}" Click="LastFmAuth_Click"
                                        Margin="0,0,10,0"/>
                                <Button x:Name="BtnLastFmConfirm" Content="Confirm Auth"
                                        Style="{StaticResource SmallButton}" Click="LastFmConfirm_Click"
                                        Visibility="Collapsed" Margin="0,0,10,0"/>
                                <TextBlock x:Name="LastFmStatusText" Text=""
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- AcoustID Fingerprinting -->
                            <TextBlock Text="AcoustID Fingerprinting" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,20,0,4"/>
                            <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="11"
                                       FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,4"
                                       Text="Identify unknown tracks via audio fingerprint."/>

                            <Button Style="{StaticResource SmallButton}" Click="AcoustIdCreateApiKey_Click"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Get a Free API Key" FontSize="11" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" &#x2197;" FontSize="12" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="API Key:"
                                           FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Grid.Column="1" x:Name="AcoustIdKeyBox"
                                         FontSize="12" FontFamily="Consolas"
                                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource Border}" Padding="6,4"
                                         TextChanged="AcoustIdKey_Changed"/>
                                <Button Grid.Column="2" x:Name="BtnToggleAcoustIdVisibility"
                                        Click="ToggleAcoustIdVisibility_Click"
                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                        Cursor="Hand" ToolTip="Show/Hide API key"
                                        Background="Transparent" BorderBrush="Transparent"
                                        Padding="4,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="4,2">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource ButtonHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Canvas Width="20" Height="16">
                                        <Path x:Name="AcoustIdEyeIcon"
                                              Data="M10,4 C5,4 1.5,8 1.5,8 C1.5,8 5,12 10,12 C15,12 18.5,8 18.5,8 C18.5,8 15,4 10,4 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3" Fill="Transparent"/>
                                        <Ellipse Canvas.Left="7.5" Canvas.Top="5.5" Width="5" Height="5"
                                                 Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2" Fill="Transparent"/>
                                        <Line x:Name="AcoustIdEyeSlash" X1="3" Y1="14" X2="17" Y2="2"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"/>
                                    </Canvas>
                                </Button>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════ ABOUT ═══════════════════════════════════ -->
                <TabItem Header="About">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,14,12,14">

                            <TextBlock Text="Version &amp; Updates" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource InputBg}" CornerRadius="6"
                                    Padding="14,10" Margin="0,0,0,10"
                                    BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="6"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Current:"
                                               FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               x:Name="CurrentVersionText" FontSize="12"
                                               FontFamily="Segoe UI" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Latest:"
                                               FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               x:Name="LatestVersionText" FontSize="12"
                                               FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <CheckBox x:Name="ChkCheckForUpdates" Content="Check for Updates on Startup"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,4"
                                      Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>
                            <TextBlock Text="Silently checks GitHub for a new version each time AudioAuditor starts."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!-- Footer: attribution + support + close -->
            <StackPanel Grid.Row="2" Margin="20,6,20,12">
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontFamily="Segoe UI">
                    <Run Text="Made with " Foreground="{DynamicResource TextMuted}"/><Run Text="&#x2764;" Foreground="#E25555" FontSize="13"/><Run Text=" by " Foreground="{DynamicResource TextMuted}"/><Hyperlink x:Name="AuthorLink" NavigateUri="https://github.com/Angel2mp3" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentColor}" TextDecorations="None">Angel</Hyperlink>
                </TextBlock>
                <Grid Margin="0,6,0,0">
                    <Button Click="SupportDonate_Click" Cursor="Hand" HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="supportBd" Background="{DynamicResource ButtonBg}"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        BorderThickness="1" CornerRadius="5" Padding="18,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Support AudioAuditor" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" ❤" FontSize="14" Foreground="#E25555"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="supportBd" Property="Background"
                                                Value="{DynamicResource ButtonHover}"/>
                                        <Setter TargetName="supportBd" Property="BorderBrush"
                                                Value="{DynamicResource AccentColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Content="Close" Width="90"
                            Click="Close_Click" Padding="12,6"
                            Background="{DynamicResource ButtonBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource ButtonBorder}"
                            FontFamily="Segoe UI" FontSize="13" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background"
                                                Value="{DynamicResource ButtonHover}"/>
                                        <Setter TargetName="bd" Property="BorderBrush"
                                                Value="{DynamicResource AccentColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>

        </Grid>
    </Border>
</Window>
