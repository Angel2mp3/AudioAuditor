<Window x:Class="AudioQualityChecker.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="740" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Themed ComboBox ToggleButton -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="22"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2"
                        Background="{DynamicResource InputBg}"
                        BorderBrush="{DynamicResource ButtonBorder}"
                        BorderThickness="1" CornerRadius="3"/>
                <Path x:Name="Arrow" Grid.Column="1"
                      Data="M 0 0 L 4 4 L 8 0" Stroke="{DynamicResource TextMuted}"
                      StrokeThickness="1.5" HorizontalAlignment="Center"
                      VerticalAlignment="Center" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush"
                            Value="{DynamicResource AccentColor}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Themed ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Template="{StaticResource ComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False" ClickMode="Press"/>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,4,24,4" VerticalAlignment="Center"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="300" Margin="0,2,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SelectionBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small themed button -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBorder" Width="16" Height="16"
                                    Background="{DynamicResource InputBg}"
                                    BorderBrush="{DynamicResource ButtonBorder}"
                                    BorderThickness="1" CornerRadius="3"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                                <TextBlock x:Name="checkMark" Text="&#xE73E;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="{DynamicResource AccentColor}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed TextBox Style — rounded corners matching ComboBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed Crossfade Slider Style -->
        <Style x:Key="CrossfadeSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Center" CornerRadius="2"
                                    Background="{DynamicResource ScrollBg}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentColor}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource ButtonBorder}"
                                                         StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Stroke"
                                                                Value="{DynamicResource AccentColor}"/>
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ScrollBar Style (global) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton OverridesDefaultStyle="True" Background="Transparent" Focusable="False" IsTabStop="False" Command="ScrollBar.PageUpCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" IsTabStop="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="thumbBd" Background="{DynamicResource ScrollThumb}" CornerRadius="4" Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbBd" Property="Background" Value="{DynamicResource ScrollThumbHover}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton OverridesDefaultStyle="True" Background="Transparent" Focusable="False" IsTabStop="False" Command="ScrollBar.PageDownCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed TabItem Style -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBd" Background="{TemplateBinding Background}"
                                CornerRadius="4,4,0,0" Padding="{TemplateBinding Padding}" Margin="2,0,2,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBd" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tabBd" Property="Background" Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed TabControl Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="0,0,0,1">
                                <TabPanel IsItemsHost="True" Background="Transparent"/>
                            </Border>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed RadioButton Style -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse Width="16" Height="16"
                                         Fill="{DynamicResource InputBg}"
                                         Stroke="{DynamicResource ButtonBorder}"
                                         StrokeThickness="1"/>
                                <Ellipse x:Name="checkMark" Width="8" Height="8"
                                         Fill="{DynamicResource AccentColor}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Visibility="Collapsed"/>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkMark" Property="Fill" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource GlassFloatingBg}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1" CornerRadius="8"
            SnapsToDevicePixels="True"
            MouseLeftButtonDown="Window_MouseDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (drag handled window-wide via Window_MouseDown) + close button -->
            <Grid Grid.Row="0" Margin="20,12,20,4">
                <TextBlock Text="Settings"
                           FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Top" HorizontalAlignment="Center"/>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="Close_Click" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="{DynamicResource TextMuted}" Padding="6,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#44FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Tabbed content -->
            <TabControl x:Name="SettingsTabControl" Grid.Row="1" Margin="8,0,8,0" SelectionChanged="SettingsTabControl_SelectionChanged">

                <!-- ═══════════════════════════════════ APPEARANCE ═══════════════════════════════════ -->
                <TabItem Header="Appearance">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,14,12,14">

                            <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Color Theme:"
                                           FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ThemeCombo" FontSize="13"
                                          SelectionChanged="ThemeCombo_SelectionChanged"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Playbar Style:"
                                           FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="PlaybarCombo" FontSize="13"
                                          SelectionChanged="PlaybarCombo_SelectionChanged"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Main Bar Animation:"
                                           FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="MainPlaybarAnimationCombo" FontSize="13"
                                          SelectionChanged="MainPlaybarAnimationCombo_SelectionChanged"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="NP Bar Animation:"
                                           FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="NpPlaybarAnimationCombo" FontSize="13"
                                          SelectionChanged="NpPlaybarAnimationCombo_SelectionChanged"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="Visualizer Style:"
                                           FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox Grid.Row="8" Grid.Column="1" x:Name="VisualizerThemeCombo" FontSize="13"
                                          SelectionChanged="VisualizerThemeCombo_SelectionChanged"/>
                            </Grid>

                            <CheckBox x:Name="ChkReduceMotion"
                                      Content="Reduce motion" FontSize="13"
                                      Margin="0,14,0,0"
                                      Checked="ReduceMotion_Changed"
                                      Unchecked="ReduceMotion_Changed"/>
                            <TextBlock Text="Stops decorative animations across the app — Now Playing backgrounds, cover glow, lyric transitions, playbar effects, and the audio visualizer. Lowers GPU/CPU load on lower-end hardware."
                                       FontSize="11" Foreground="{DynamicResource TextDim}"
                                       FontFamily="Segoe UI" Margin="22,4,0,0" TextWrapping="Wrap"/>

                            <TextBlock Text="Now Playing Visuals" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,8"/>
                            <CheckBox x:Name="ChkNpRememberManualColors" Content="Remember manual ColorMatch picks"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,4"
                                      Checked="NpRememberManualColors_Changed" Unchecked="NpRememberManualColors_Changed"/>
                            <TextBlock Text="Manual color picker choices are saved with hashed track keys and restored next time, even when the automatic color cache is not persisted."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,6" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ChkNpColorCache" Content="Cache album art colors"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,4,0,4"
                                      Checked="NpColorCache_Changed" Unchecked="NpColorCache_Changed"/>
                            <TextBlock Text="Stores extracted album art colors so track switching is instant. In-memory only unless persist is enabled below."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,4" TextWrapping="Wrap"/>
                            <CheckBox x:Name="ChkNpColorCachePersist" Content="Persist color cache to disk"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="22,4,0,4"
                                      Checked="NpColorCachePersist_Changed" Unchecked="NpColorCachePersist_Changed"/>
                            <TextBlock Text="Saves the color cache to %APPDATA%\AudioAuditor\ so it survives app restarts. Keys are hashed — no file paths are stored."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="44,2,0,4" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="22,2,0,6">
                                <TextBlock x:Name="NpColorCacheStatusText" Text=""
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkNpAlbumBackdrop" Content="Use album art as blurred Now Playing backdrop"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,4,0,4"
                                      Checked="NpAlbumBackdrop_Changed" Unchecked="NpAlbumBackdrop_Changed"/>
                            <StackPanel Orientation="Horizontal" Margin="22,6,0,4">
                                <TextBlock Text="Background animation:" FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="NpBackgroundAnimationCombo" Width="130" FontSize="12"
                                          SelectionChanged="NpBackgroundAnimationCombo_SelectionChanged"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkNpColorDriftGlow" Content="Color Drift glow (under effect)"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="22,4,0,8"
                                      ToolTip="Run the Color Drift gradient glow as a background under the selected effect"
                                      Checked="NpColorDriftGlow_Changed" Unchecked="NpColorDriftGlow_Changed"/>
                            <CheckBox x:Name="ChkNpBackgroundUseAlbumColors" Content="Use album colors for Stars, Rain, Snow, and Underwater"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="22,4,0,8"
                                      Checked="NpBackgroundUseAlbumColors_Changed" Unchecked="NpBackgroundUseAlbumColors_Changed"/>
                            <CheckBox x:Name="ChkNpBackgroundCycle" Content="Cycle background animations"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="22,0,0,4"
                                      Checked="NpBackgroundCycle_Changed" Unchecked="NpBackgroundCycle_Changed"/>
                            <Grid Margin="22,4,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cycle speed" FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" x:Name="NpBackgroundCycleSpeedSlider" Minimum="0.25" Maximum="3" Value="1"
                                        SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                        Style="{StaticResource CrossfadeSlider}"
                                        ValueChanged="NpBackgroundCycleSpeedSlider_Changed"/>
                                <TextBlock Grid.Column="2" x:Name="NpBackgroundCycleSpeedLabel" Text="1.0x"
                                           Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <CheckBox x:Name="ChkNpBackgroundCycleOnSongChange" Content="Advance background on song change"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="22,0,0,8"
                                      Checked="NpBackgroundCycleOnSongChange_Changed" Unchecked="NpBackgroundCycleOnSongChange_Changed"/>
                            <StackPanel x:Name="NpStarsControls">
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Star density" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpStarDensitySlider" Minimum="0.25" Maximum="2.5" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpStarDensitySlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpStarDensityLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <CheckBox x:Name="ChkNpShootingStars" Content="Shooting stars"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" Margin="22,2,0,4"
                                          Checked="NpShootingStars_Changed" Unchecked="NpShootingStars_Changed"/>
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Shooting density" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpShootingStarDensitySlider" Minimum="0.25" Maximum="4.0" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpShootingStarDensitySlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpShootingStarDensityLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel x:Name="NpRainControls">
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Rain intensity" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpRainIntensitySlider" Minimum="0.25" Maximum="2.5" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpRainIntensitySlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpRainIntensityLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <CheckBox x:Name="ChkNpRainLightning" Content="Lightning strikes"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" Margin="22,2,0,4"
                                          Checked="NpRainLightning_Changed" Unchecked="NpRainLightning_Changed"/>
                                <Border x:Name="NpRainLightningPrompt" Visibility="Collapsed" Margin="22,4,0,8" Padding="10"
                                        Background="{DynamicResource GlassFloatingBg}" BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Lightning can include bright flashes. Enable it for Rain?"
                                                   Foreground="{DynamicResource TextPrimary}" FontSize="12" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                            <Button Content="Keep off" Style="{StaticResource SmallButton}" Padding="10,4" Margin="0,0,8,0"
                                                    Click="NpRainLightningPromptNo_Click"/>
                                            <Button Content="Enable lightning" Style="{StaticResource SmallButton}" Padding="10,4"
                                                    Click="NpRainLightningPromptYes_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Lightning amount" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpRainLightningSlider" Minimum="0" Maximum="3.0" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpRainLightningSlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpRainLightningLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel x:Name="NpSnowControls">
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Snow density" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpSnowDensitySlider" Minimum="0.25" Maximum="2.5" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpSnowDensitySlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpSnowDensityLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Snowflake amount" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpSnowflakeSlider" Minimum="0.25" Maximum="2.5" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpSnowflakeSlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpSnowflakeLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel x:Name="NpUnderwaterControls">
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bubble density" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpUnderwaterBubbleSlider" Minimum="0.25" Maximum="2.5" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpUnderwaterBubbleSlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpUnderwaterBubbleLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="22,4,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="48"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Caustic light" FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                    <Slider Grid.Column="1" x:Name="NpUnderwaterCausticSlider" Minimum="0" Maximum="2.0" Value="1"
                                            SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                            Style="{StaticResource CrossfadeSlider}"
                                            ValueChanged="NpUnderwaterCausticSlider_Changed"/>
                                    <TextBlock Grid.Column="2" x:Name="NpUnderwaterCausticLabel" Text="1.0x"
                                               Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <CheckBox x:Name="ChkNpUnderwaterFish" Content="Fish silhouettes"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" Margin="22,2,0,4"
                                          Checked="NpUnderwaterFish_Changed" Unchecked="NpUnderwaterFish_Changed"/>
                                <CheckBox x:Name="ChkNpUnderwaterSeaweed" Content="Seaweed"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" Margin="22,0,0,8"
                                          Checked="NpUnderwaterSeaweed_Changed" Unchecked="NpUnderwaterSeaweed_Changed"/>
                            </StackPanel>
                            <Grid Margin="22,4,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="48"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Animation speed" FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                <Slider Grid.Column="1" x:Name="NpAnimationSpeedSlider" Minimum="0.4" Maximum="2.5" Value="1"
                                        SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                        Style="{StaticResource CrossfadeSlider}"
                                        ValueChanged="NpAnimationSpeedSlider_Changed"/>
                                <TextBlock Grid.Column="2" x:Name="NpAnimationSpeedLabel" Text="1.0x"
                                           Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                                <Button Content="Set NP Image..." Style="{StaticResource SmallButton}"
                                        Click="SelectNpBackground_Click" Margin="0,0,8,0"/>
                                <Button Content="Reset NP Image" Style="{StaticResource SmallButton}"
                                        Click="ResetNpBackground_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                <Button Content="Set Main Image..." Style="{StaticResource SmallButton}"
                                        Click="SelectMainBackground_Click" Margin="0,0,8,0"/>
                                <Button Content="Reset Main Image" Style="{StaticResource SmallButton}"
                                        Click="ResetMainBackground_Click"/>
                            </StackPanel>

                            <!-- Custom Theme Builder -->
                            <Expander IsExpanded="False" Margin="0,18,0,6"
                                      Foreground="{DynamicResource TextPrimary}">
                                <Expander.Header>
                                    <StackPanel>
                                        <TextBlock Text="Custom Theme Builder" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="Create named themes with portable JSON import/export."
                                                   Foreground="{DynamicResource TextDim}" FontSize="11"
                                                   FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Expander.Header>
                                <Border CornerRadius="6" Padding="10" Margin="0,8,0,0"
                                        Background="{DynamicResource PanelBg}"
                                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="6"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme Name:"
                                                       Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="CustomThemeNameBox"
                                                     Height="24" Text="My Custom Theme"/>
                                            <Button Grid.Row="0" Grid.Column="2" x:Name="BtnCustomThemeDuplicate"
                                                    Content="Duplicate" Width="82" Margin="8,0,0,0"
                                                    Style="{StaticResource SmallButton}"
                                                    Click="CustomThemeDuplicate_Click"/>
                                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal">
                                                <Button x:Name="BtnCustomThemeSave" Content="Save Theme" Width="88" Margin="0,0,6,0"
                                                        Style="{StaticResource SmallButton}"
                                                        Click="CustomThemeSave_Click"/>
                                                <Button x:Name="BtnCustomThemeDelete" Content="Delete" Width="64" Margin="0,0,6,0"
                                                        Style="{StaticResource SmallButton}"
                                                        Click="CustomThemeDelete_Click"/>
                                                <Button x:Name="BtnCustomThemeReset" Content="Reset" Width="64" Margin="0,0,6,0"
                                                        Style="{StaticResource SmallButton}"
                                                        Click="CustomThemeReset_Click"/>
                                                <Button x:Name="BtnCustomThemeImport" Content="Import JSON" Width="90" Margin="0,0,6,0"
                                                        Style="{StaticResource SmallButton}"
                                                        Click="CustomThemeImport_Click"/>
                                                <Button x:Name="BtnCustomThemeExport" Content="Export JSON" Width="90"
                                                        Style="{StaticResource SmallButton}"
                                                        Click="CustomThemeExport_Click"/>
                                            </StackPanel>
                                        </Grid>

                                        <UniformGrid Columns="2" Margin="0,0,0,8">
                                            <StackPanel Margin="0,0,6,6">
                                                <TextBlock Text="Accent" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <DockPanel>
                                                    <Button Content="Pick" DockPanel.Dock="Right" Width="46" Margin="4,0,0,0"
                                                            Style="{StaticResource SmallButton}"
                                                            Tag="{Binding ElementName=CustomAccentBox}" Click="PickCustomThemeColor_Click"/>
                                                    <TextBox x:Name="CustomAccentBox" Text="#5865F2" Height="24"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Margin="6,0,0,6">
                                                <TextBlock Text="Window" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <DockPanel>
                                                    <Button Content="Pick" DockPanel.Dock="Right" Width="46" Margin="4,0,0,0"
                                                            Style="{StaticResource SmallButton}"
                                                            Tag="{Binding ElementName=CustomWindowBox}" Click="PickCustomThemeColor_Click"/>
                                                    <TextBox x:Name="CustomWindowBox" Text="#101326" Height="24"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,6,6">
                                                <TextBlock Text="Panel" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <DockPanel>
                                                    <Button Content="Pick" DockPanel.Dock="Right" Width="46" Margin="4,0,0,0"
                                                            Style="{StaticResource SmallButton}"
                                                            Tag="{Binding ElementName=CustomPanelBox}" Click="PickCustomThemeColor_Click"/>
                                                    <TextBox x:Name="CustomPanelBox" Text="#141832" Height="24"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Margin="6,0,0,6">
                                                <TextBlock Text="Text" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <DockPanel>
                                                    <Button Content="Pick" DockPanel.Dock="Right" Width="46" Margin="4,0,0,0"
                                                            Style="{StaticResource SmallButton}"
                                                            Tag="{Binding ElementName=CustomTextBox}" Click="PickCustomThemeColor_Click"/>
                                                    <TextBox x:Name="CustomTextBox" Text="#F4F6FF" Height="24"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,6,6">
                                                <TextBlock Text="Border" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <DockPanel>
                                                    <Button Content="Pick" DockPanel.Dock="Right" Width="46" Margin="4,0,0,0"
                                                            Style="{StaticResource SmallButton}"
                                                            Tag="{Binding ElementName=CustomBorderBox}" Click="PickCustomThemeColor_Click"/>
                                                    <TextBox x:Name="CustomBorderBox" Text="#7F8CFF" Height="24"/>
                                                </DockPanel>
                                            </StackPanel>
                                            <StackPanel Margin="6,0,0,6">
                                                <TextBlock Text="Playbar Colors" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox x:Name="CustomPlaybar1Box" Text="#3C46B6" Width="70" Height="24" Margin="0,0,4,0"/>
                                                    <TextBox x:Name="CustomPlaybar2Box" Text="#5865F2" Width="70" Height="24" Margin="0,0,4,0"/>
                                                    <TextBox x:Name="CustomPlaybar3Box" Text="#8C96FF" Width="70" Height="24"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,6,6">
                                                <TextBlock Text="Visualizer Colors" Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBox x:Name="CustomViz1Box" Text="#3C46B6" Width="70" Height="24" Margin="0,0,4,0"/>
                                                    <TextBox x:Name="CustomViz2Box" Text="#5865F2" Width="70" Height="24" Margin="0,0,4,0"/>
                                                    <TextBox x:Name="CustomViz3Box" Text="#8C96FF" Width="70" Height="24"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </UniformGrid>

                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Corners" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                            <Slider Grid.Column="1" x:Name="CustomCornerSlider" Minimum="2" Maximum="16" Value="8"
                                                    TickFrequency="1" Style="{StaticResource CrossfadeSlider}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ElementName=CustomCornerSlider, Path=Value, StringFormat=F0}"
                                                       Foreground="{DynamicResource TextSecondary}" Margin="8,0,0,0"/>
                                        </Grid>

                                        <Border x:Name="CustomThemePreview" CornerRadius="8" Padding="12" Margin="0,0,0,2"
                                                Background="{DynamicResource PanelBg}"
                                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="Custom Theme Preview" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}" FontSize="13"/>
                                                <TextBlock Text="Saved custom themes appear in the Color Theme and Visualizer Theme lists."
                                                           Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>
                                                <Border Height="8" Margin="0,8,0,0" CornerRadius="4"
                                                        Background="{DynamicResource PlaybarAccentColor}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Expander>

                            <!-- Visualizer Cycle Settings -->
                            <TextBlock Text="Visualizer Cycle" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,6"/>
                            <TextBlock Text="When cycling, automatically switches between visualizer styles."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,0,0,6" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Speed:" FontSize="12" FontFamily="Segoe UI"
                                           Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <Slider x:Name="CycleSpeedSlider" Minimum="5" Maximum="60" Value="10"
                                        Width="140" IsSnapToTickEnabled="True" TickFrequency="5"
                                        ValueChanged="CycleSpeedSlider_Changed"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource CrossfadeSlider}"/>
                                <TextBlock x:Name="CycleSpeedLabel" Text="10s" FontSize="12"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center" Margin="8,0,0,0" Width="28"/>
                            </StackPanel>
                            <TextBlock Text="Custom cycle selection (check styles to include):"
                                       Foreground="{DynamicResource TextMuted}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <WrapPanel x:Name="CycleStyleChecks" Margin="0,0,0,0">
                                <CheckBox x:Name="ChkCycleBars" Content="Bars" Margin="0,0,12,4"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" IsChecked="True"
                                          Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                                <CheckBox x:Name="ChkCycleMirror" Content="Mirror" Margin="0,0,12,4"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" IsChecked="True"
                                          Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                                <CheckBox x:Name="ChkCycleParticles" Content="Particles" Margin="0,0,12,4"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" IsChecked="True"
                                          Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                                <CheckBox x:Name="ChkCycleCircles" Content="Circles" Margin="0,0,12,4"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" IsChecked="True"
                                          Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                                <CheckBox x:Name="ChkCycleScope" Content="Scope" Margin="0,0,12,4"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" IsChecked="True"
                                          Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                                <CheckBox x:Name="ChkCycleVU" Content="VU Meter" Margin="0,0,12,4"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" IsChecked="True"
                                          Checked="CycleStyleCheck_Changed" Unchecked="CycleStyleCheck_Changed"/>
                            </WrapPanel>

                            <!-- Main window color-match removed from Settings UI — Now Playing panel color-match remains available via the NP panel button -->

                            <!-- The "Now Playing — Look Up This Song" services were moved to the
                                 Integrations tab, grouped with the Music Service Buttons. -->

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════ PLAYBACK ═══════════════════════════════════ -->
                <TabItem Header="Playback">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,14,12,14">

                            <TextBlock Text="Playback &amp; Visualizer" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,10"/>

                            <CheckBox x:Name="ChkAutoPlay" Content="Auto-Play next song"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,8"
                                      Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>

                            <CheckBox x:Name="ChkNormalization" Content="Audio Normalization"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,8"
                                      Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>

                            <CheckBox x:Name="ChkCrossfade" Content="Crossfade"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,4"
                                      Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>

                            <StackPanel IsEnabled="{Binding IsChecked, ElementName=ChkCrossfade}"
                                        Margin="22,6,0,4">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Duration:" FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <Slider x:Name="CrossfadeSlider" Minimum="1" Maximum="30" Value="5"
                                            Width="130" IsSnapToTickEnabled="True" TickFrequency="1"
                                            ValueChanged="CrossfadeSlider_Changed"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource CrossfadeSlider}"/>
                                    <TextBox x:Name="CrossfadeDurationBox" Width="42" Height="24"
                                             Margin="8,0,0,0" VerticalContentAlignment="Center"
                                             TextAlignment="Center" FontSize="12" FontFamily="Segoe UI"
                                             Text="5" LostFocus="CrossfadeDurationBox_LostFocus"
                                             KeyDown="CrossfadeDurationBox_KeyDown"/>
                                    <TextBlock x:Name="CrossfadeDurationLabel" Text="5s" FontSize="12"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center" Margin="8,0,0,0" Width="24"/>
                                </StackPanel>
                                <CheckBox x:Name="ChkCrossfadeOnManualSkip" Content="Crossfade on manual skip"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                          FontFamily="Segoe UI" Margin="0,0,0,6"
                                          Checked="CrossfadeManualSkip_Changed" Unchecked="CrossfadeManualSkip_Changed"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Curve:" FontSize="12" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <ComboBox x:Name="CrossfadeCurveCombo" Width="160" Height="24"
                                              SelectionChanged="CrossfadeCurve_Changed">
                                        <ComboBoxItem Tag="EqualPower" Content="Equal Power"/>
                                        <ComboBoxItem Tag="Linear" Content="Linear"/>
                                        <ComboBoxItem Tag="Natural" Content="Natural"/>
                                        <ComboBoxItem Tag="SmoothStep" Content="Smooth Step"/>
                                        <ComboBoxItem Tag="FastFade" Content="Fast Fade"/>
                                        <ComboBoxItem Tag="SlowBlend" Content="Slow Blend"/>
                                        <ComboBoxItem Tag="Sequential" Content="Sequential (no overlap)"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Crossfade Curve Preview -->
                                <TextBlock Text="Curve Preview" FontSize="12" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                           Margin="0,14,0,6"/>
                                <Border Background="{DynamicResource InputBg}" CornerRadius="6"
                                        BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                        Width="260" Height="140" HorizontalAlignment="Left" Margin="0,0,0,6">
                                    <Canvas x:Name="CrossfadeCurveCanvas" ClipToBounds="True"
                                            Background="Transparent" Margin="8"
                                            Loaded="CrossfadeCurveCanvas_Loaded">
                                        <Polyline x:Name="CrossfadeFadeOutLine" Stroke="{DynamicResource AccentColor}"
                                                  StrokeThickness="2" Opacity="0.85"/>
                                        <Polyline x:Name="CrossfadeFadeInLine" Stroke="{DynamicResource TextSecondary}"
                                                  StrokeThickness="2" Opacity="0.85"/>
                                        <Ellipse x:Name="CrossfadePlayhead" Width="8" Height="8"
                                                 Fill="White" Visibility="Collapsed"/>
                                    </Canvas>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <Button x:Name="BtnAnimateCrossfade" Content="Animate Preview" FontSize="11"
                                            FontFamily="Segoe UI" Click="AnimateCrossfade_Click"
                                            Style="{StaticResource SmallButton}" Padding="8,4"/>
                                </StackPanel>
                            </StackPanel>

                            <CheckBox x:Name="ChkGapless" Content="Gapless Playback"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,10,0,4"
                                      Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>
                            <TextBlock Text="Seamless track transitions with zero silence gap. Mutually exclusive with Crossfade."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <CheckBox x:Name="ChkSpatialAudio" Content="Spatial Audio (Headphones)"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,10,0,0"
                                      Checked="PlayOption_Changed" Unchecked="PlayOption_Changed"/>
                            <TextBlock Text="Creates a wider, room-like soundstage for headphone listening using crossfeed and stereo widening."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <CheckBox x:Name="ChkVisualizerFullVolume" Content="Visualizer Full Volume"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,10,0,0"
                                      Checked="VisualizerFullVolume_Changed" Unchecked="VisualizerFullVolume_Changed"/>
                            <TextBlock Text="Makes the visualizer always respond as if the volume is at 100%, even when you lower it. Keeps the visual effects lively at any volume level."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <CheckBox x:Name="ChkPreloadNextTrack" Content="Preload next track data"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,14,0,0"
                                      Checked="PreloadNextTrack_Changed" Unchecked="PreloadNextTrack_Changed"/>
                            <TextBlock Text="Decodes the next track's album art, colors, and metadata in the background before you skip to it. Reduces transition lag."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════ ANALYSIS ═══════════════════════════════════ -->
                <TabItem Header="Analysis">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,14,12,14">

                            <TextBlock Text="Analysis" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,10"/>

                            <!-- Silence gap threshold -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <CheckBox x:Name="ChkSilenceMinGap" Content="Flag gaps longer than"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" VerticalAlignment="Center"
                                          Checked="SilenceOption_Changed" Unchecked="SilenceOption_Changed"/>
                                <TextBox x:Name="TxtSilenceMinGapSec" Width="48" Margin="8,0,4,0" Text="0.5"
                                         FontSize="13" FontFamily="Segoe UI" Padding="4,2"
                                         Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource ButtonBorder}"
                                         TextChanged="SilenceOption_Changed"/>
                                <TextBlock Text="seconds" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock Text="Overrides the default 500 ms minimum silence gap for mid-track flagging."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,0,0,8" TextWrapping="Wrap"/>

                            <!-- Edge-skip threshold -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <CheckBox x:Name="ChkSilenceSkipEdges" Content="Don't flag silence in the first/last"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" VerticalAlignment="Center"
                                          Checked="SilenceOption_Changed" Unchecked="SilenceOption_Changed"/>
                                <TextBox x:Name="TxtSilenceSkipEdgeSec" Width="48" Margin="8,0,4,0" Text="5.0"
                                         FontSize="13" FontFamily="Segoe UI" Padding="4,2"
                                         Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource ButtonBorder}"
                                         TextChanged="SilenceOption_Changed"/>
                                <TextBlock Text="seconds of the track" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock Text="Suppresses leading/trailing silence flags within the specified zone at each end of the file."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,0,0,8" TextWrapping="Wrap"/>

                            <!-- Always full analysis -->
                            <CheckBox x:Name="ChkAlwaysFullAnalysis" Content="Always analyze the entire audio file (much slower)"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,4,0,4"
                                      Checked="SilenceOption_Changed" Unchecked="SilenceOption_Changed"/>
                            <TextBlock Text="Forces a complete sample-by-sample pass even when Silence, DR, True Peak, and LUFS detection are all disabled. Useful for bitrate/encoder analysis only."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,0,0,0" TextWrapping="Wrap"/>

                            <!-- Hz Cutoff Allow Setting (F13) -->
                            <TextBlock Text="Frequency Cutoff" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <CheckBox x:Name="ChkFreqCutoffAllow" Content="Allow cutoffs above"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI" VerticalAlignment="Center"
                                          Checked="FreqCutoff_Changed" Unchecked="FreqCutoff_Changed"/>
                                <TextBox x:Name="TxtFreqCutoffHz" Width="64" Margin="8,0,4,0" Text="19600"
                                         FontSize="13" FontFamily="Segoe UI" Padding="4,2"
                                         TextChanged="FreqCutoffHz_Changed"/>
                                <TextBlock Text="Hz (don't flag these files)" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                           FontFamily="Segoe UI"/>
                            </StackPanel>
                            <TextBlock Text="When enabled, files whose frequency cutoff meets or exceeds this threshold will not be flagged as low-quality. Default: 19,600 Hz. Off by default."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,0,0,0" TextWrapping="Wrap"/>

                            <!-- AI Detection -->
                            <TextBlock Text="AI Detection" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,8"/>

                            <CheckBox x:Name="ChkDefaultAi" Content="Default AI Detection (Watermark / Metadata)"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,2"
                                      Checked="DefaultAi_Changed" Unchecked="DefaultAi_Changed"/>
                            <TextBlock Text="Scans metadata, watermarks, and known AI markers. Unlimited, no network needed."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,8" TextWrapping="Wrap"/>

                            <CheckBox x:Name="ChkExperimentalAi" Content="Aggressive AI Detection (Spectral Analysis)"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,2"
                                      Checked="ExperimentalAi_Changed" Unchecked="ExperimentalAi_Changed"/>
                            <TextBlock Text="⚠ Uses spectral analysis (ultrasonic energy, stereo correlation, spectral regularity) to detect AI-generated audio. This will produce more false positives than standard detection but can catch AI audio that has been stripped of metadata markers."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,8" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <CheckBox x:Name="ChkSHLabsAi" Content="SH Labs AI Audio Detection (API)"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                          FontFamily="Segoe UI"
                                          Checked="SHLabsAi_Changed" Unchecked="SHLabsAi_Changed"/>
                                <TextBlock x:Name="SHLabsPrivacyIcon" Text=" ⚠️" FontSize="14"
                                           VerticalAlignment="Center" Cursor="Hand"
                                           ToolTip="View SH Labs privacy information"
                                           PreviewMouseLeftButtonDown="SHLabsPrivacyIcon_Click"/>
                            </StackPanel>
                            <TextBlock Text="AI audio detection via SH Labs. Can be better at detecting certain types of AI audio compared to the other options, but limited to 15 scans/day and 100/month. ⚠ Enabling this will significantly slow down scanning as each file must be uploaded for analysis. When the limit is reached, your other selected detection methods will be used instead."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,4" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SHLabsQuotaText" Text=""
                                       Foreground="{DynamicResource AccentColor}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,0,0,6"/>

                            <TextBlock Text="Use your own SH Labs API key (optional):" FontSize="11.5"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                       Margin="22,4,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="22,0,0,2">
                                <TextBox x:Name="SHLabsApiKeyBox" Width="280" FontSize="12"
                                         FontFamily="Segoe UI" Padding="4,3"
                                         Background="{DynamicResource InputBg}"
                                         Foreground="{DynamicResource TextPrimary}"
                                         BorderBrush="{DynamicResource ButtonBorder}"
                                         TextChanged="SHLabsApiKey_Changed"/>
                                <Button Content="Clear" FontSize="11" FontFamily="Segoe UI" Margin="8,0,0,0"
                                        Click="SHLabsApiKeyClear_Click" Cursor="Hand" Padding="8,3"
                                        Background="{DynamicResource ButtonBg}"
                                        Foreground="{DynamicResource TextPrimary}"
                                        BorderBrush="{DynamicResource ButtonBorder}"/>
                            </StackPanel>
                            <TextBlock Text="With your own key, audio goes directly to SH Labs — no proxy, no rate limits, no data collection by AudioAuditor."
                                       Foreground="{DynamicResource TextDim}" FontSize="10.5"
                                       FontFamily="Segoe UI" Margin="22,3,0,0" TextWrapping="Wrap"/>

                            <!-- Columns & Features -->
                            <TextBlock Text="Columns &amp; Features" FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,8"/>
                            <TextBlock Text="Toggle which columns and analysis features are enabled. Disabled analysis features won't run or appear in the results table."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <WrapPanel Orientation="Horizontal">
                                <CheckBox x:Name="ColFavoriteCb" Content="★ Favorite" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColStatusCb" Content="Status" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColTitleCb" Content="Title" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColArtistCb" Content="Artist" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColFilenameCb" Content="Filename" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColPathCb" Content="Path" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColSampleRateCb" Content="Sample Rate" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColBitsCb" Content="Bits" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColChCb" Content="Ch" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColDurationCb" Content="Duration" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColSizeCb" Content="Size" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColBitrateCb" Content="Bitrate" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColActualBRCb" Content="Actual BR" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColFormatCb" Content="Format" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColMaxFreqCb" Content="Max Freq" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColClippingCb" Content="Clipping" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColBpmCb" Content="BPM" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColReplayGainCb" Content="Replay Gain" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColDRCb" Content="DR" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColMqaCb" Content="MQA" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColAiCb" Content="AI" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColStereoCb" Content="Fake Stereo" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColSilenceCb" Content="Silence" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColDateModifiedCb" Content="Date Modified" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColDateCreatedCb" Content="Date Created" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColTruePeakCb" Content="True Peak" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColLufsCb" Content="LUFS" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                                <CheckBox x:Name="ColRipQualityCb" Content="Rip Quality" Margin="0,0,12,6" FontSize="12" FontFamily="Segoe UI"
                                          Foreground="{DynamicResource TextPrimary}" Checked="ColumnVisibility_Changed" Unchecked="ColumnVisibility_Changed"/>
                            </WrapPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════════════════════════════ CACHE & FILES ═══════════════════════════════════ -->
                <TabItem Header="Cache &amp; Files">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12,14,12,14">

                            <!-- Scan Cache -->
                            <TextBlock Text="Scan Cache" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,0,0,8"/>
                            <CheckBox x:Name="ChkScanCache" Content="Remember previous scan results"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,0,0,4"
                                      Checked="ScanCache_Changed" Unchecked="ScanCache_Changed"/>
                            <TextBlock Text="Caches analysis results locally so previously scanned files load instantly without re-analysis. Only uses cached data when the file hasn't been modified (same path, size, and date)."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,6" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Margin="22,0,0,0">
                                <Button x:Name="BtnClearCache" Content="Clear Cache"
                                        Style="{StaticResource SmallButton}" Click="ClearCache_Click"
                                        Margin="0,0,8,0"/>
                                <Button x:Name="BtnEditCache" Content="Edit Cache..."
                                        Style="{StaticResource SmallButton}" Click="EditCache_Click"
                                        Margin="0,0,10,0"/>
                                <TextBlock x:Name="CacheStatusText" Text=""
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>

                            <CheckBox x:Name="ChkFocusNewFiles" Content="Focus newly added songs"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,14,0,4"
                                      Checked="FocusNewFiles_Changed" Unchecked="FocusNewFiles_Changed"/>
                            <TextBlock Text="After an import finishes, selects and scrolls to the first added song without changing the current search or filter."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <!-- Restore last session -->
                            <CheckBox x:Name="ChkRestoreLastSession" Content="Restore last session on startup"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,18,0,4"
                                      Checked="RestoreLastSession_Changed" Unchecked="RestoreLastSession_Changed"/>
                            <TextBlock Text="Remembers the files and folders you had loaded and offers to restore them next time you open AudioAuditor. Pairs with scan cache so the restored list loads instantly."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <!-- Local Stats Collection -->
                            <CheckBox x:Name="ChkStatsCollection" Content="Enable local listening &amp; analysis stats"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,18,0,4"
                                      Checked="StatsCollection_Changed" Unchecked="StatsCollection_Changed"/>
                            <TextBlock Text="Collects scanned files, listening time, top tracks/artists, and audio quality metrics locally. 100% offline — nothing is ever uploaded. Default: OFF."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>
                            <Button Content="View Your Wrapped" Style="{StaticResource SmallButton}"
                                    Click="ViewWrapped_Click" Padding="10,4" Margin="22,8,0,0"
                                    HorizontalAlignment="Left"
                                    ToolTip="See your AudioAuditor Wrapped — your local listening &amp; library stats"/>

                            <!-- Crash Logging -->
                            <CheckBox x:Name="ChkCrashLogging" Content="Enable local crash logging"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,18,0,4"
                                      Checked="CrashLogging_Changed" Unchecked="CrashLogging_Changed"/>
                            <TextBlock Text="When enabled, unhandled errors are saved to a local file on your PC. These logs never leave your machine and are only used to help diagnose issues."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <!-- Close to Tray -->
                            <CheckBox x:Name="ChkCloseToTray" Content="Minimize to system tray on close"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                      FontFamily="Segoe UI" Margin="0,18,0,4"
                                      Checked="CloseToTray_Changed" Unchecked="CloseToTray_Changed"/>
                            <TextBlock Text="When enabled, closing the window sends it to the system tray instead of exiting. Playback and analysis continue in the background. Right-click the tray icon to exit."
                                       Foreground="{DynamicResource TextDim}" FontSize="11"
                                       FontFamily="Segoe UI" Margin="22,2,0,0" TextWrapping="Wrap"/>

                            <!-- Favorites (F9) -->
                            <TextBlock Text="Favorites" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button x:Name="BtnClearFavorites" Content="Clear All Favorites"
                                        Style="{StaticResource SmallButton}" Click="ClearFavorites_Click"
                                        Margin="0,0,8,0"/>
                                <Button x:Name="BtnOpenFavoritesFile" Content="Edit Favorites File..."
                                        Style="{StaticResource SmallButton}" Click="OpenFavoritesFile_Click"
                                        Margin="0,0,10,0"/>
                                <TextBlock x:Name="FavoritesStatusText" Text=""
                                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="favorites.json is stored in %APPDATA%\AudioAuditor\ and can be manually edited to rearrange or remove entries."
                                       FontSize="11" Foreground="{DynamicResource TextMuted}"
                                       FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <!-- Performance -->
                            <TextBlock Text="Performance" FontSize="14" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                       Margin="0,18,0,8"/>

                            <!-- Battery Saver -->
                            <CheckBox x:Name="ChkBatterySaver"
                                      Content="Battery Saver" FontSize="13"
                                      Checked="BatterySaver_Changed" Unchecked="BatterySaver_Changed"/>
                            <TextBlock Text="Reduces power use by disabling or throttling animations. Choose what it affects below."
                                       FontSize="11" Foreground="{DynamicResource TextDim}"
                                       FontFamily="Segoe UI" Margin="22,4,0,8" TextWrapping="Wrap"/>
                            <StackPanel x:Name="BatterySaverAreasPanel" Margin="22,0,0,0">
                                <CheckBox x:Name="ChkBatteryEntireProgram"
                                          Content="Entire program (all areas)" FontSize="13" Margin="0,0,0,6"
                                          Checked="BatterySaverArea_Changed" Unchecked="BatterySaverArea_Changed"/>
                                <CheckBox x:Name="ChkBatteryNpBackground"
                                          Content="Now Playing backgrounds" FontSize="12" Margin="16,0,0,4"
                                          Foreground="{DynamicResource TextSecondary}"
                                          Checked="BatterySaverArea_Changed" Unchecked="BatterySaverArea_Changed"/>
