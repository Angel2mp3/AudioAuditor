<Window x:Class="AudioQualityChecker.WaveformCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="700" Width="1000"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="ThemedSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Center" CornerRadius="2"
                                    Background="{DynamicResource ScrollBg}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentColor}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource ButtonBorder}"
                                                         StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Stroke"
                                                                Value="{DynamicResource AccentColor}"/>
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThemedVerticalSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Width="4" HorizontalAlignment="Center" CornerRadius="2"
                                    Background="{DynamicResource ScrollBg}"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Width="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentColor}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource ButtonBorder}"
                                                         StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Stroke"
                                                                Value="{DynamicResource AccentColor}"/>
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBg}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Waveform Comparison" FontWeight="SemiBold" FontSize="14"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="16,0,0,0"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Click="Close_Click" Cursor="Hand"
                            Background="Transparent" BorderBrush="Transparent"
                            Foreground="{DynamicResource TextMuted}" FontSize="16" Padding="8,2"/>
                </Grid>
            </Border>

            <!-- File labels -->
            <Grid Grid.Row="1" Margin="16,8,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="File A:" FontWeight="SemiBold" FontSize="12"
                           Foreground="#5B9BD5" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="1" x:Name="FileALabel" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="File B:" FontWeight="SemiBold" FontSize="12"
                           Foreground="#E57373" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="4" x:Name="FileBLabel" FontSize="12"
                           Foreground="{DynamicResource TextSecondary}" FontFamily="Segoe UI"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
            </Grid>

            <!-- Single waveform canvas + merge slider -->
            <Grid Grid.Row="2" Margin="16,8,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Canvas Grid.Column="0" x:Name="WaveCanvas" ClipToBounds="True"
                        Background="{DynamicResource InputBg}" SizeChanged="Canvas_SizeChanged"/>

                <!-- Vertical merge slider -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Merge" FontSize="10" Foreground="{DynamicResource TextMuted}"
                               FontFamily="Segoe UI" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <Slider x:Name="MergeSlider" Orientation="Vertical" Minimum="0" Maximum="100" Value="0"
                            Height="140" TickFrequency="10" IsSnapToTickEnabled="False"
                            ValueChanged="MergeSlider_ValueChanged"
                            Style="{StaticResource ThemedVerticalSlider}"/>
                    <TextBlock x:Name="MergeLabel" Text="0%" FontSize="10"
                               Foreground="{DynamicResource TextMuted}" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Horizontal offset slider -->
            <Grid Grid.Row="3" Margin="16,6,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Offset:" FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Slider Grid.Column="1" x:Name="OffsetSlider" Minimum="-500" Maximum="500" Value="0"
                        TickFrequency="50" IsSnapToTickEnabled="False"
                        ValueChanged="OffsetSlider_ValueChanged"
                        Style="{StaticResource ThemedSlider}"/>
                <TextBlock Grid.Column="2" x:Name="OffsetLabel" Text="0 px" FontSize="11"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="50"/>
            </Grid>

            <!-- Stats and legend -->
            <Grid Grid.Row="4" Margin="16,6,16,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatsText" FontSize="12"
                           Foreground="{DynamicResource TextMuted}" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Rectangle Width="14" Height="3" Fill="#5B9BD5" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="File A" FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Segoe UI" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Rectangle Width="14" Height="3" Fill="#E57373" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="File B" FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Segoe UI" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Rectangle Width="14" Height="3" Fill="#81C784" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Difference" FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
