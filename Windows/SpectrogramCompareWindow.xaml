<Window x:Class="AudioQualityChecker.SpectrogramCompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="850" Width="1300"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Themed ScrollBar -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                                Background="{DynamicResource ScrollThumb}"
                                CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SpectToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SpectToolbarToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Center" CornerRadius="2"
                                    Background="{DynamicResource ScrollBg}"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentColor}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource ButtonBorder}"
                                                         StrokeThickness="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Stroke"
                                                                Value="{DynamicResource AccentColor}"/>
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBg}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Spectrogram Comparison" FontWeight="SemiBold" FontSize="14"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="16,0,0,0"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Click="Close_Click" Cursor="Hand"
                            Background="Transparent" BorderBrush="Transparent"
                            Foreground="{DynamicResource TextMuted}" FontSize="16" Padding="8,2"/>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="16,8,16,0">
                <Button x:Name="BtnStacked" Content="Stacked" Click="ViewMode_Click"
                        Style="{StaticResource SpectToolbarButton}" Margin="0,0,4,0"/>
                <Button x:Name="BtnOverlay" Content="Overlay" Click="ViewMode_Click"
                        Style="{StaticResource SpectToolbarButton}" Margin="0,0,4,0"/>
                <Button x:Name="BtnWipe" Content="Wipe" Click="ViewMode_Click"
                        Style="{StaticResource SpectToolbarButton}" Margin="0,0,12,0"/>
                <ToggleButton x:Name="BtnChannel" Content="Mono" Click="Channel_Click"
                              Margin="0,0,4,0" Style="{StaticResource SpectToolbarToggle}"/>
                <ToggleButton x:Name="BtnScale" Content="Log" Click="Scale_Click"
                              Margin="0,0,4,0" Style="{StaticResource SpectToolbarToggle}"/>
                <ToggleButton x:Name="BtnZoom" Content="Fit" Click="Zoom_Click"
                              Margin="0,0,0,0" Style="{StaticResource SpectToolbarToggle}"/>
            </StackPanel>

            <!-- Spectrogram display area -->
            <Grid Grid.Row="2" Margin="16,8,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Stacked view (default) -->
                <Border Grid.Column="0" x:Name="StackedPanel" Background="{DynamicResource InputBg}"
                        ClipToBounds="True" Visibility="Visible">
                    <ScrollViewer x:Name="StackedScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <StackPanel Orientation="Vertical">
                            <TextBlock x:Name="StackedLabelA" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource AccentColor}" FontFamily="Segoe UI"
                                       Margin="8,8,8,4"/>
                            <Image x:Name="StackedImageA" Stretch="None"
                                   HorizontalAlignment="Left"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <Border Height="20" Background="Transparent"/>
                            <TextBlock x:Name="StackedLabelB" FontWeight="SemiBold" FontSize="13"
                                       Foreground="#E57373" FontFamily="Segoe UI"
                                       Margin="8,8,8,4"/>
                            <Image x:Name="StackedImageB" Stretch="None"
                                   HorizontalAlignment="Left"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Overlay / Wipe canvas -->
                <Border Grid.Column="0" x:Name="OverlayPanel" Background="{DynamicResource InputBg}"
                        ClipToBounds="True" Visibility="Collapsed">
                    <ScrollViewer x:Name="OverlayScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <Canvas x:Name="SpectCanvas" Background="Transparent">
                            <Image x:Name="ImageA" Stretch="None"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            <Image x:Name="ImageB" Stretch="None"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   Opacity="1"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor">
                                <Image.RenderTransform>
                                    <TranslateTransform x:Name="ImageBOffset" X="0" Y="0"/>
                                </Image.RenderTransform>
                                <Image.Clip>
                                    <RectangleGeometry x:Name="ImageBClip" Rect="0,0,0,0"/>
                                </Image.Clip>
                            </Image>
                            <Image x:Name="DiffImage" Stretch="None"
                                   HorizontalAlignment="Left" VerticalAlignment="Top"
                                   Opacity="1"
                                   Visibility="Collapsed"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor">
                                <Image.RenderTransform>
                                    <TranslateTransform x:Name="DiffOffset" X="0" Y="0"/>
                                </Image.RenderTransform>
                                <Image.Clip>
                                    <RectangleGeometry x:Name="DiffClip" Rect="0,0,0,0"/>
                                </Image.Clip>
                            </Image>
                            <Rectangle x:Name="WipeLine" Width="2" Fill="White"
                                       Visibility="Collapsed" IsHitTestVisible="False"/>
                        </Canvas>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Stats -->
            <Grid Grid.Row="3" Margin="16,6,16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatsText" FontSize="12"
                           Foreground="{DynamicResource TextMuted}" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Rectangle Width="14" Height="3" Fill="{DynamicResource AccentColor}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="File A" FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Segoe UI" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Rectangle Width="14" Height="3" Fill="#E57373" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="File B" FontSize="11" Foreground="{DynamicResource TextSecondary}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Controls -->
            <Grid Grid.Row="4" Margin="16,6,16,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Merge slider -->
                <Grid Grid.Row="0" x:Name="MergeSliderPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Merge:" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider Grid.Column="1" x:Name="MergeSlider" Minimum="0" Maximum="100" Value="0"
                            TickFrequency="10" IsSnapToTickEnabled="False"
                            ValueChanged="MergeSlider_ValueChanged"
                            Style="{StaticResource ThemedSlider}"/>
                    <TextBlock Grid.Column="2" x:Name="MergeLabel" Text="0%" FontSize="11"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="40"/>
                </Grid>

                <!-- Horizontal offset slider -->
                <Grid Grid.Row="1" x:Name="OffsetSliderPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Offset:" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider Grid.Column="1" x:Name="OffsetSlider" Minimum="-500" Maximum="500" Value="0"
                            TickFrequency="50" IsSnapToTickEnabled="False"
                            ValueChanged="OffsetSlider_ValueChanged"
                            Style="{StaticResource ThemedSlider}"/>
                    <TextBlock Grid.Column="2" x:Name="OffsetLabel" Text="0 px" FontSize="11"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="50"/>
                </Grid>

                <!-- Wipe slider -->
                <Grid Grid.Row="2" x:Name="WipeSliderPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Wipe:" FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Slider Grid.Column="1" x:Name="WipeSlider" Minimum="0" Maximum="100" Value="50"
                            TickFrequency="10" IsSnapToTickEnabled="False"
                            ValueChanged="WipeSlider_ValueChanged"
                            Style="{StaticResource ThemedSlider}"/>
                    <TextBlock Grid.Column="2" x:Name="WipeLabel" Text="50%" FontSize="11"
                               FontFamily="Segoe UI" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="40"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
