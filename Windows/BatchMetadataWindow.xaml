<Window x:Class="AudioQualityChecker.BatchMetadataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="720" Width="1100"
        MinHeight="540" MinWidth="840"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">
    <Border Background="{DynamicResource GlassFloatingBg}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="17"
                               Foreground="{DynamicResource AccentColor}" Margin="0,0,8,0"/>
                    <StackPanel>
                        <TextBlock Text="Batch Metadata Enrichment"
                                   FontSize="19" FontWeight="Bold" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="FileCountText" FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="Close_Click" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="{DynamicResource TextMuted}" Padding="8,5"/>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource GlassPanelBg}"
                    BorderBrush="{DynamicResource GlassBorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,10">
                        <CheckBox x:Name="ChkMissingOnly" Content="Missing only" IsChecked="True" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ChkReplaceCovers" Content="Replace existing covers" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ChkBackups" Content="Create backups before writing" IsChecked="True" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ChkMusicBrainz" Content="MusicBrainz" IsChecked="True" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ChkCoverArchive" Content="Cover Art Archive" IsChecked="True" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ChkITunes" Content="Apple/iTunes" Margin="0,0,16,6"/>
                        <CheckBox x:Name="ChkAcoustId" Content="AcoustID" Margin="0,0,16,6"/>
                    </WrapPanel>
                    <WrapPanel>
                        <CheckBox x:Name="FldTitle" Content="Title" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldArtist" Content="Artist" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldAlbum" Content="Album" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldAlbumArtist" Content="Album artist" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldYear" Content="Year" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldTrack" Content="Track" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldDisc" Content="Disc" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldGenre" Content="Genre" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldComposer" Content="Composer" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldComment" Content="Comment" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldLyrics" Content="Lyrics" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldCopyright" Content="Copyright" IsChecked="True" Margin="0,0,12,6"/>
                        <CheckBox x:Name="FldCover" Content="Cover art" IsChecked="True" Margin="0,0,12,6"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <DataGrid Grid.Row="4" x:Name="ChangesGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Extended"
                      Background="{DynamicResource PanelBg}"
                      Foreground="{DynamicResource TextPrimary}"
                      BorderBrush="{DynamicResource BorderColor}"
                      RowBackground="{DynamicResource RowBg}"
                      AlternatingRowBackground="{DynamicResource RowAltBg}">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Apply" Binding="{Binding IsSelected, Mode=TwoWay}" Width="56"/>
                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="180" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="110" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Old" Binding="{Binding OldValue}" Width="180" IsReadOnly="True"/>
                    <DataGridTextColumn Header="New" Binding="{Binding NewValue}" Width="220" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence, StringFormat={}{0:P0}}" Width="90" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="{DynamicResource TextMuted}"/>
                <Button Grid.Column="1" Content="Search" Padding="18,7" Click="Search_Click"/>
                <Button Grid.Column="3" Content="Select High Confidence" Padding="18,7" Click="SelectHigh_Click"/>
                <Button Grid.Column="5" Content="Apply Selected" Padding="18,7" Click="Apply_Click"/>
                <Button Grid.Column="7" Content="Close" Padding="18,7" Click="Close_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
