<Window x:Class="AudioQualityChecker.BatchRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="CanResize"
        Height="580" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Border CornerRadius="10" Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{DynamicResource TitleBarBg}" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Batch Rename" FontWeight="SemiBold" FontSize="14"
                               FontFamily="Segoe UI" VerticalAlignment="Center" Margin="16,0,0,0"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0" Click="Close_Click" Cursor="Hand"
                            Background="Transparent" BorderBrush="Transparent"
                            Foreground="{DynamicResource TextMuted}" FontSize="16" Padding="8,2"/>
                </Grid>
            </Border>

            <!-- Pattern input -->
            <StackPanel Grid.Row="1" Margin="16,12,16,0">
                <TextBlock Text="Rename Pattern" FontWeight="SemiBold" FontSize="12"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                <TextBox x:Name="PatternBox" FontSize="13" FontFamily="Consolas"
                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource Border}" Padding="8,6"
                         Text="{}{artist} - {title}"
                         TextChanged="PatternBox_TextChanged"/>
                <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="11"
                           FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,4,0,0">
                    <Run Text="Tags: {artist} {title} {album} {year} {track} {genre} {bitrate} {codec} {samplerate}"/>
                </TextBlock>
            </StackPanel>

            <!-- Options -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="16,8,16,0">
                <CheckBox x:Name="ChkOrganizeFolders" Content="Organize into folders: {artist}/{album}/"
                          Foreground="{DynamicResource TextSecondary}" FontSize="12" FontFamily="Segoe UI"
                          Cursor="Hand" Checked="Option_Changed" Unchecked="Option_Changed"/>
            </StackPanel>

            <!-- Preview list -->
            <Border Grid.Row="3" Margin="16,10,16,0" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                    CornerRadius="4" Background="{DynamicResource InputBg}">
                <ListView x:Name="PreviewList" Background="Transparent" BorderThickness="0"
                          Foreground="{DynamicResource TextPrimary}" FontSize="12" FontFamily="Segoe UI"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Current Name" Width="280"
                                            DisplayMemberBinding="{Binding CurrentName}"/>
                            <GridViewColumn Header="→" Width="30"
                                            DisplayMemberBinding="{Binding Arrow}"/>
                            <GridViewColumn Header="New Name" Width="280"
                                            DisplayMemberBinding="{Binding NewName}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10,16,14">
                <TextBlock x:Name="StatusText" Foreground="{DynamicResource TextMuted}" FontSize="12"
                           FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="Cancel" Click="Close_Click" Cursor="Hand" Padding="16,6"
                        Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource Border}" Margin="0,0,8,0"/>
                <Button x:Name="BtnRename" Content="Rename Files" Click="Rename_Click" Cursor="Hand" Padding="16,6"
                        Background="{DynamicResource AccentColor}" Foreground="White"
                        BorderBrush="Transparent" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
