<Window x:Class="AudioQualityChecker.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AudioAuditor Mini"
        Width="400" SizeToContent="Height"
        MinHeight="120" MinWidth="320"
        MaxHeight="420" MaxWidth="920"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Mini button base -->
        <Style x:Key="MiniBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play/Pause button -->
        <Style x:Key="MiniPlayBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="14" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Mini seek slider -->
        <Style x:Key="MiniSeekSlider" TargetType="Slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PlaybarAccentColor}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent" MinHeight="16">
                            <Border Height="4" VerticalAlignment="Center"
                                    Background="{DynamicResource ScrollBg}" CornerRadius="2" Opacity="0.6"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" VerticalAlignment="Center"
                                                        Background="{DynamicResource PlaybarAccentColor}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="12" Height="12"
                                                         Fill="{DynamicResource PlaybarAccentColor}"
                                                         Stroke="{DynamicResource TextPrimary}"
                                                         StrokeThickness="1.5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                                                          Opacity="0.3" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="14"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="14"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed context-menu used for the mini-player options flyout -->
        <Style x:Key="MiniContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="12" Opacity="0.4" Color="Black"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed menu item (handles header, normal, checkable, hover, disabled) -->
        <Style x:Key="MiniMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}" Margin="0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Check" Grid.Column="0" Text="&#x2713;"
                                           Foreground="{DynamicResource PlaybarAccentColor}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            Background="{DynamicResource GlassFloatingBg}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="0">
        <Grid>
            <!-- Subtle gradient overlay for depth -->
            <Border CornerRadius="14" Opacity="0.04">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid Margin="14,10,14,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Cover + Info + Actions -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Cover art with album-colour glow -->
                    <Grid Grid.Column="0" Width="52" Height="52">
                        <!-- Outer colour glow (driven by ColorMatch / album colours) -->
                        <Border x:Name="CoverGlow1" CornerRadius="14" Opacity="0.55" Margin="-10">
                            <Border.Effect>
                                <BlurEffect Radius="18"/>
                            </Border.Effect>
                        </Border>
                        <!-- Inner colour glow -->
                        <Border x:Name="CoverGlow2" CornerRadius="10" Opacity="0.4" Margin="-5">
                            <Border.Effect>
                                <BlurEffect Radius="10"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="CoverBorder" CornerRadius="8"
                                Background="{DynamicResource GlassPanelBg}" ClipToBounds="True"
                                MouseLeftButtonDown="Cover_Click" Cursor="Hand"
                                ToolTip="Click to restore main window">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <Border.Clip>
                                <RectangleGeometry x:Name="CoverClip" RadiusX="8" RadiusY="8"
                                                   Rect="0,0,52,52"/>
                            </Border.Clip>
                            <Grid>
                                <!-- Fallback music-note glyph shown when a track has no album art -->
                                <TextBlock x:Name="CoverPlaceholder" Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="22" Foreground="{DynamicResource TextMuted}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:Name="CoverImage" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Title / Artist -->
                    <StackPanel Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" Text="No track"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ArtistText" Text=""
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Top-right actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button x:Name="MiniSettingsBtn" Style="{StaticResource MiniBtn}" Click="SettingsBtn_Click"
                                ToolTip="Mini player options" Padding="4" FontSize="12">
                            <TextBlock Text="&#x2699;" Foreground="{DynamicResource TextMuted}"/>
                        </Button>
                        <Button Style="{StaticResource MiniBtn}" Click="Close_Click"
                                ToolTip="Close" Padding="4" FontSize="11" Margin="2,0,0,0">
                            <TextBlock Text="&#x2715;" Foreground="{DynamicResource TextMuted}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Row 1: Mini visualizer (collapses fully when off) -->
                <Grid Grid.Row="1" Margin="0,4,0,0"
                      x:Name="VisualizerRow" Visibility="Collapsed">
                    <Canvas x:Name="MiniVizCanvas" ClipToBounds="True" Height="36"
                            Background="Transparent"
                            VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Row 2: Controls + Seek + Volume -->
                <Grid Grid.Row="2" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Transport -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="ShuffleBtn" Style="{StaticResource MiniBtn}" Click="Shuffle_Click" ToolTip="Shuffle" Padding="4,2">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path x:Name="ShuffleIconPath"
                                          Data="M 1,12 L 10,3 M 10,3 L 7,3 M 10,3 L 10,6 M 1,4 L 10,13 M 10,13 L 7,13 M 10,13 L 10,10"
                                          Stroke="{DynamicResource TextMuted}" StrokeThickness="2.2"
                                          Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource MiniBtn}" Click="Prev_Click" ToolTip="Previous" Padding="5,2">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M 2,1 L 2,13" Stroke="{DynamicResource TextSecondary}" StrokeThickness="2"/>
                                    <Path Data="M 5,7 L 14,1 L 14,13 Z" Fill="{DynamicResource TextSecondary}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="PlayPauseBtn" Style="{StaticResource MiniPlayBtn}"
                                Click="PlayPause_Click" ToolTip="Play/Pause" Margin="4,0">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path x:Name="PlayIcon" Data="M 3,1 L 3,15 L 15,8 Z" Fill="#FF111111"/>
                                    <Path x:Name="PauseIcon" Data="M 2,1 L 2,15 L 6,15 L 6,1 Z M 10,1 L 10,15 L 14,15 L 14,1 Z"
                                          Fill="#FF111111" Visibility="Collapsed"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Style="{StaticResource MiniBtn}" Click="Next_Click" ToolTip="Next" Padding="5,2">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M 2,1 L 2,13 L 12,7 Z" Fill="{DynamicResource TextSecondary}"/>
                                    <Path Data="M 14,1 L 14,13" Stroke="{DynamicResource TextSecondary}" StrokeThickness="2"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <!-- Seek slider with time underneath -->
                    <StackPanel Grid.Column="1" Margin="8,6,8,0" VerticalAlignment="Center">
                        <Grid Height="20">
                            <Canvas x:Name="MiniPlaybarAnimCanvas"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False"
                                    ClipToBounds="False"/>
                            <Slider x:Name="SeekSlider"
                                    Minimum="0" Maximum="100"
                                    IsMoveToPointEnabled="True"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource MiniSeekSlider}"
                                    PreviewMouseLeftButtonDown="SeekSlider_MouseDown"
                                    PreviewMouseLeftButtonUp="SeekSlider_MouseUp"
                                    Thumb.DragStarted="SeekSlider_DragStarted"
                                    Thumb.DragCompleted="SeekSlider_DragCompleted"/>
                        </Grid>
                        <TextBlock x:Name="TimeText" Text="0:00 / 0:00"
                                   HorizontalAlignment="Center"
                                   Margin="0,1,0,0"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="9"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="MuteBtn" Style="{StaticResource MiniBtn}" Click="MuteBtn_Click"
                                ToolTip="Mute" Padding="3,2">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="16" Height="16">
                                    <Path x:Name="VolumeIconPath"
                                          Data="M 2,5 L 5,5 L 9,2 L 9,14 L 5,11 L 2,11 Z"
                                          Fill="{DynamicResource TextMuted}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Slider x:Name="VolumeSlider" Width="44"
                                Minimum="0" Maximum="100" Value="80"
                                VerticalAlignment="Center"
                                Margin="2,0,0,0"
                                Style="{StaticResource MiniSeekSlider}"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
