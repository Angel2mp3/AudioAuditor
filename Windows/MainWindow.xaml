<Window x:Class="AudioQualityChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AudioQualityChecker.Converters"
        Title="AudioAuditor"
        Height="700" Width="1360"
        MinHeight="550" MinWidth="1190"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/icon.png"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="TaskbarInfo"
                         Description="AudioAuditor"
                         ThumbnailClipMargin="20,20,20,20"/>
    </Window.TaskbarItemInfo>

    <Window.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:StatusToTextConverter x:Key="StatusToText"/>
        <converters:ClippingToColorConverter x:Key="ClippingToColor"/>
        <converters:BitrateToColorConverter x:Key="BitrateToColor"/>
        <converters:MqaToColorConverter x:Key="MqaToColor"/>
        <converters:AiToColorConverter x:Key="AiToColor"/>
        <converters:StarConverter x:Key="StarConverter"/>

        <!-- ═══ Scrollbar Styles ═══ -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                                Background="{DynamicResource ScrollThumb}"
                                CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark button style -->
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonPressed}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ToolTip style -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{DynamicResource GlassFloatingBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource GlassBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Player button -->
        <Style x:Key="PlayerButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="150"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="50"/>
        </Style>

        <!-- Volume slider with circle thumb matching seek bar -->
        <Style x:Key="VolumeSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource PlaybarAccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="3" VerticalAlignment="Center"
                                    Background="{DynamicResource ScrollBg}" CornerRadius="1.5"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center"
                                                        Background="{DynamicResource PlaybarAccentColor}"
                                                        CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="volThumb" Width="12" Height="12"
                                                         Fill="{DynamicResource PlaybarAccentColor}"
                                                         Stroke="{DynamicResource TextPrimary}"
                                                         StrokeThickness="1.2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="3"
                                                                          Opacity="0.25" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="volThumb" Property="Width" Value="14"/>
                                                        <Setter TargetName="volThumb" Property="Height" Value="14"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compact themed slider for popup controls (crossfade, etc.) -->
        <Style x:Key="CrossfadeSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="4" VerticalAlignment="Center"
                                    Background="{DynamicResource ScrollBg}" CornerRadius="2"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentColor}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="cfThumb" Width="12" Height="12"
                                                         Fill="{DynamicResource AccentColor}"
                                                         Stroke="{DynamicResource ButtonBorder}"
                                                         StrokeThickness="1">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="3"
                                                                          Opacity="0.25" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="cfThumb" Property="Width" Value="14"/>
                                                        <Setter TargetName="cfThumb" Property="Height" Value="14"/>
                                                        <Setter TargetName="cfThumb" Property="Stroke"
                                                                Value="{DynamicResource AccentColor}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Seek slider with circle thumb and click-to-position -->
        <Style x:Key="SeekSlider" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource PlaybarAccentColor}"/>
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="4" VerticalAlignment="Center"
                                    Background="{DynamicResource ScrollBg}" CornerRadius="2"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <!-- Played portion: paint the accent here (like the mini player) so the
                                                     bar is ALWAYS the themed/colormatch accent and never falls back to the
                                                     dark ScrollBg track (the "black playbar on Ocean" bug) when the
                                                     PlaybarAnimCanvas overlay hasn't painted yet. Animated styles draw on
                                                     top of this on the overlay canvas. -->
                                                <Border Height="4" VerticalAlignment="Center"
                                                        Background="{DynamicResource PlaybarAccentColor}"
                                                        CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" IsTabStop="False"
                                                  Focusable="False" OverridesDefaultStyle="True">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb OverridesDefaultStyle="True" Cursor="Hand">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumbCircle" Width="14" Height="14"
                                                         Fill="{DynamicResource PlaybarAccentColor}"
                                                         Stroke="{DynamicResource TextPrimary}"
                                                         StrokeThickness="1.5">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect ShadowDepth="0" BlurRadius="4"
                                                                          Opacity="0.3" Color="Black"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbCircle" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumbCircle" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ComboBox style -->
        <Style x:Key="ThemedComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="toggleBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3" Padding="6,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="16"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"/>
                                                <TextBlock Grid.Column="1" Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="toggleBorder" Property="Background"
                                                        Value="{DynamicResource ButtonHover}"/>
                                                <Setter TargetName="toggleBorder" Property="BorderBrush"
                                                        Value="{DynamicResource AccentColor}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="8,4,24,4" IsHitTestVisible="False"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="300">
                                    <Border x:Name="DropDownBorder"
                                            Background="{DynamicResource GlassFloatingBg}"
                                            BorderBrush="{DynamicResource GlassBorderBrush}"
                                            BorderThickness="1" CornerRadius="3"
                                            Margin="0,1,0,0" Padding="2">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="3" Margin="1">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource SelectionBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="14" Height="14" CornerRadius="3"
                                    Background="{DynamicResource InputBg}"
                                    BorderBrush="{DynamicResource ButtonBorder}"
                                    BorderThickness="1" VerticalAlignment="Center">
                                <Path x:Name="check" Data="M 3,7 L 6,10 L 11,4"
                                      Stroke="{DynamicResource TextPrimary}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{DynamicResource PlaybarAccentColor}"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource PlaybarAccentColor}"/>
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search box style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!-- Rounded border template so the search box matches the other inputs/buttons on this
                 screen (CornerRadius 3, same tokens). A raw TextBox has square corners + no radius. -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Themed Context Menu ═══ -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="2"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <StackPanel IsItemsHost="True"
                                        SnapsToDevicePixels="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <Border x:Name="HeaderBd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="3" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="CheckGlyph" Grid.Column="0"
                                               Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{DynamicResource AccentColor}"
                                               FontSize="12" VerticalAlignment="Center"
                                               Margin="0,0,6,0" Visibility="Collapsed"/>
                                    <ContentPresenter ContentSource="Header" Grid.Column="1"
                                                      VerticalAlignment="Center"/>
                                    <Path x:Name="Arrow" Grid.Column="2"
                                          Data="M 0,0 L 4,4 L 0,8"
                                          Stroke="{DynamicResource TextMuted}"
                                          StrokeThickness="1.5" StrokeLineJoin="Round"
                                          VerticalAlignment="Center"
                                          Margin="8,0,2,0" Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   Placement="Right" HorizontalOffset="0" VerticalOffset="-2">
                                <Border Background="{DynamicResource InputBg}"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        BorderThickness="1" CornerRadius="6" Padding="4">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12"
                                                          Opacity="0.5" Color="Black"/>
                                    </Border.Effect>
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="HeaderBd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="HeaderBd" Property="Background"
                                        Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="HeaderBd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}"
                                Height="{TemplateBinding Height}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
    <Image x:Name="MainBackgroundImage"
           Stretch="UniformToFill"
           Opacity="0"
           IsHitTestVisible="False"
           RenderOptions.BitmapScalingMode="LowQuality"
           CacheMode="BitmapCache">
        <!-- Static, heavily-blurred backdrop behind animated content: cache the blurred
             result as a GPU texture so per-frame compositing of overlaid animations
             doesn't re-run the BlurEffect. Invalidated only on track change. -->
        <Image.Effect>
            <BlurEffect x:Name="MainBackgroundBlurEffect" Radius="16" RenderingBias="Performance"/>
        </Image.Effect>
    </Image>
    <DockPanel x:Name="MainContent">
        <!-- ═══ Toolbar ═══ -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource GlassToolbarBg}" Padding="8,6"
                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Click="AddFiles_Click" Style="{StaticResource DarkButton}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add Files" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="AddFolder_Click" Style="{StaticResource DarkButton}" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add Folder" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="4,2"/>
                    <Button Click="ClearAll_Click" FontSize="12"
                            Style="{StaticResource DarkButton}" Margin="4,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Clear" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="RefreshBtn" Click="Refresh_Click" FontSize="12"
                            Style="{StaticResource DarkButton}" Margin="0,0,4,0"
                            ToolTip="Re-analyze loaded files (or just the selected ones). Use after adding columns or if something didn't read.">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="2,2"/>
                    <Button x:Name="ExportDropdownBtn" Click="ExportDropdown_Click"
                            Style="{StaticResource DarkButton}" Margin="4,0,4,0">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Export Results" Click="ExportResults_Click"/>
                                <MenuItem Header="Save Spectrograms" Click="SaveAllSpectrograms_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Export" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                       VerticalAlignment="Center" Margin="5,1,0,0"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="2,2"/>
                    <Button Click="Queue_Click" Style="{StaticResource DarkButton}" Margin="4,0,4,0"
                            ToolTip="Play Queue">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE90B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Queue" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="2,2"/>
                    <Button Click="Settings_Click" Style="{StaticResource DarkButton}" Margin="4,0,0,0"
                            ToolTip="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Settings" FontFamily="Segoe UI" FontSize="12"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Rectangle Width="1" Fill="{DynamicResource ButtonBorder}" Margin="4,2"/>
                    <Button x:Name="MiniPlayerButton" Click="MiniPlayer_Click" Style="{StaticResource DarkButton}" Margin="4,0,0,0"
                            ToolTip="Mini Player" Padding="6,3">
                        <TextBlock Text="&#xE73F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="WrappedButton" Click="Wrapped_Click" Style="{StaticResource DarkButton}" Margin="4,0,0,0" ToolTip="Your Wrapped" Padding="6,3">
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Music Service Search Buttons -->
                <StackPanel x:Name="MusicServicesPanel" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            Margin="12,0">
                    <Button x:Name="ServiceBtn1" Click="ServiceSearch_Click" Tag="0"
                            Style="{StaticResource DarkButton}" Margin="3,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Spotify">
                        <Grid Width="28" Height="28">
                            <Grid.Clip><EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/></Grid.Clip>
                            <Image x:Name="ServiceImage1" Width="28" Height="28" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ServiceBtn2" Click="ServiceSearch_Click" Tag="1"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on YouTube Music">
                        <Grid Width="28" Height="28">
                            <Grid.Clip><EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/></Grid.Clip>
                            <Image x:Name="ServiceImage2" Width="28" Height="28" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ServiceBtn3" Click="ServiceSearch_Click" Tag="2"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Tidal">
                        <Grid Width="28" Height="28">
                            <Grid.Clip><EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/></Grid.Clip>
                            <Image x:Name="ServiceImage3" Width="28" Height="28" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ServiceBtn4" Click="ServiceSearch_Click" Tag="3"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Qobuz">
                        <Grid Width="28" Height="28">
                            <Grid.Clip><EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/></Grid.Clip>
                            <Image x:Name="ServiceImage4" Width="28" Height="28" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ServiceBtn5" Click="ServiceSearch_Click" Tag="4"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Amazon Music">
                        <Grid Width="28" Height="28">
                            <Grid.Clip><EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/></Grid.Clip>
                            <Image x:Name="ServiceImage5" Width="28" Height="28" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Button>
                    <Button x:Name="ServiceBtn6" Click="ServiceSearch_Click" Tag="5"
                            Style="{StaticResource DarkButton}" Margin="0,0,3,0" Padding="3"
                            MinWidth="0" ToolTip="Search on Apple Music">
                        <Grid Width="28" Height="28">
                            <Grid.Clip><EllipseGeometry Center="14,14" RadiusX="14" RadiusY="14"/></Grid.Clip>
                            <Image x:Name="ServiceImage6" Width="28" Height="28" Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Status Filter + Search bar -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ComboBox x:Name="StatusFilterCombo" Width="115" Margin="0,0,6,0"
                              SelectionChanged="StatusFilterCombo_SelectionChanged"
                              ToolTip="Filter by status"
                              Style="{StaticResource ThemedComboBox}"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                        <ComboBoxItem Content="Real"/>
                        <ComboBoxItem Content="Fake"/>
                        <ComboBoxItem Content="Unknown"/>
                        <ComboBoxItem Content="Corrupted"/>
                        <ComboBoxItem Content="Optimized"/>
                        <ComboBoxItem Content="Mismatched BR"/>
                    </ComboBox>
                    <Grid Width="240">
                        <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}"
                                 TextChanged="SearchBox_TextChanged"
                                 ToolTip="Search by filename, artist, title, path, extension..."
                                 Padding="26,4,6,4"/>
                        <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                   HorizontalAlignment="Left" Margin="7,0,0,0"
                                   IsHitTestVisible="False"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Search... or Ctrl+F"
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"
                                   HorizontalAlignment="Left" Margin="28,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Status Bar ═══ -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource GlassToolbarBg}" Padding="10,5"
                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Text="Ready — Drag and drop audio files or folders to begin"
                           Foreground="{DynamicResource TextSecondary}" FontSize="12"
                           VerticalAlignment="Center" FontFamily="Segoe UI"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="FooterSupportText" Grid.Column="1"
                           Text="Support AudioAuditor ❤"
                           Foreground="{DynamicResource TextMuted}" FontSize="11"
                           FontFamily="Segoe UI" VerticalAlignment="Center"
                           Cursor="Hand" Margin="12,0"
                           MouseLeftButtonDown="FooterSupport_Click">
                    <TextBlock.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Dismiss" Click="FooterSupport_Dismiss"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                    <TextBlock.ToolTip>
                        <ToolTip Content="Support AudioAuditor on Ko-fi"/>
                    </TextBlock.ToolTip>
                </TextBlock>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="AnalysisPauseButton" Content="⏸" FontSize="12"
                            Visibility="Collapsed" Margin="0,0,6,0"
                            Padding="4,1" MinWidth="28"
                            Background="{DynamicResource ButtonBg}"
                            Foreground="{DynamicResource TextPrimary}"
                            BorderBrush="{DynamicResource ButtonBorder}"
                            Click="AnalysisPause_Click"
                            ToolTip="Pause / Resume scanning"/>
                    <Grid x:Name="AnalysisProgressPanel" Width="200" Height="14" Visibility="Collapsed" Margin="0,0,10,0">
                        <ProgressBar x:Name="AnalysisProgress"
                                     Foreground="{DynamicResource AccentColor}"
                                     Background="{DynamicResource ProgressBg}"
                                     BorderBrush="{DynamicResource ButtonBorder}"/>
                        <TextBlock x:Name="AnalysisEtaText"
                                   Text=""
                                   FontSize="9" FontFamily="Segoe UI" FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="3" Opacity="0.7" Color="Black"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock x:Name="ScrobbleStatusText"
                               Text=""
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                <Button x:Name="ScrobbleWidgetButton"
                        Click="ScrobbleWidgetButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Padding="6,2" Margin="0" Cursor="Hand"
                        Foreground="{DynamicResource AccentColor}"
                        VerticalAlignment="Center"
                        ToolTip="Scrobbling — Click to manage">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid Background="Transparent">
                                <Border x:Name="ScrobbleAccentOverlay"
                                        Background="{DynamicResource AccentColor}"
                                        CornerRadius="5"
                                        Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ScrobbleAccentOverlay" Property="Opacity" Value="0.16"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ScrobbleAccentOverlay" Property="Opacity" Value="0.24"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="♫" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="MnuScrobbleProfiles" Header="Profiles" StaysOpenOnClick="True"/>
                            <Separator/>
                            <MenuItem x:Name="MnuScrobbleNow" Header="Scrobble Current Song Now"
                                      Click="MnuScrobbleNow_Click"/>
                            <MenuItem x:Name="MnuDontScrobble" Header="Don't Scrobble Current Song"
                                      Click="MnuDontScrobble_Click"/>
                            <MenuItem x:Name="MnuBlacklist" Header="Never Scrobble This Song"
                                      Click="MnuBlacklist_Click"/>
                            <MenuItem x:Name="MnuUnblacklist" Header="Remove from Blacklist"
                                      Click="MnuUnblacklist_Click" Visibility="Collapsed"/>
                            <Separator/>
                            <MenuItem x:Name="MnuPauseAll" Header="Pause All Scrobbling"
                                      IsCheckable="True" Click="MnuPauseAll_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                </StackPanel>
                <!-- Offline mode badge — shown only when offline mode is active -->
                <TextBlock Grid.Column="4" x:Name="TxtOfflineBadge"
                           Text="● OFFLINE"
                           Foreground="{DynamicResource Bad}"
                           FontSize="11" FontFamily="Segoe UI" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="Collapsed"
                           ToolTip="Offline mode is active — network features are disabled. Change in Settings."/>
            </Grid>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
            </Grid.RowDefinitions>

            <!-- ═══ DataGrid ═══ -->
            <DataGrid Grid.Row="0"
                      x:Name="FileGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Extended"
                      SelectionChanged="FileGrid_SelectionChanged"
                      MouseDoubleClick="FileGrid_MouseDoubleClick"
                      PreviewMouseWheel="FileGrid_PreviewMouseWheel"
                      Background="{DynamicResource GridBg}"
                      Foreground="{DynamicResource TextPrimary}"
                      RowBackground="{DynamicResource GridRowBg}"
                      AlternatingRowBackground="{DynamicResource GridAltRowBg}"
                      BorderBrush="{DynamicResource BorderColor}"
                      BorderThickness="0"
                      GridLinesVisibility="All"
                      HorizontalGridLinesBrush="{DynamicResource GridLineColor}"
                      VerticalGridLinesBrush="{DynamicResource GridLineColor}"
                      HeadersVisibility="Column"
                      CanUserSortColumns="True"
                      CanUserReorderColumns="True"
                      CanUserResizeColumns="True"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      SelectionUnit="FullRow"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.CacheLength="2,2"
                      VirtualizingPanel.CacheLengthUnit="Page"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="False">

                <!-- Folder group headers -->
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource HeaderBg}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,4">
                                    <TextBlock FontSize="11" FontFamily="Segoe UI"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}">
                                        <Run Text="📁 "/>
                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                        <Run Text=" — " Foreground="{DynamicResource TextMuted}"/>
                                        <Run Text="{Binding ItemCount, Mode=OneWay, StringFormat='{}{0} files'}"
                                             Foreground="{DynamicResource TextMuted}"/>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="GroupItem">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GroupItem">
                                            <StackPanel>
                                                <ContentPresenter/>
                                                <ItemsPresenter/>
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <!-- Column Header Style -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource HeaderBg}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="Padding" Value="8,7"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <!-- Row Style -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource RowHoverBg}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- Cell Style -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" Padding="5,3">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SelectionBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <!-- Context Menu -->
                <DataGrid.ContextMenu>
                    <ContextMenu Opened="ContextMenu_Opened">
                        <MenuItem Header="Play" Click="PlayFile_Click"/>
                        <MenuItem Header="Add to Queue" Click="AddToQueue_Click"/>
                        <Separator/>
                        <!-- Favorites submenu -->
                        <MenuItem x:Name="MenuFavoritesGroup" Header="Favorites">
                            <MenuItem x:Name="MenuToggleFavorite" Header="Add to Favorites" Click="ToggleFavorite_Click"/>
                            <Separator/>
                            <MenuItem x:Name="MenuFavMoveUp" Header="Move Up in Favorites" Click="MoveFavoriteUp_Click"/>
                            <MenuItem x:Name="MenuFavMoveDown" Header="Move Down in Favorites" Click="MoveFavoriteDown_Click"/>
                        </MenuItem>
                        <Separator/>
                        <!-- Metadata submenu -->
                        <MenuItem Header="Metadata">
                            <MenuItem Header="Edit Metadata..." Click="EditMetadata_Click"/>
                            <MenuItem Header="Batch Metadata Enrichment..." Click="BatchMetadata_Click"/>
                            <MenuItem Header="Strip Metadata..." Click="StripMetadata_Click"/>
                            <Separator/>
                            <MenuItem Header="Batch Rename..." Click="BatchRename_Click"/>
                            <MenuItem Header="Quick Rename (Selected Pattern)" Click="QuickRename_Click"/>
                            <MenuItem Header="Auto Rename">
                                <MenuItem Header="To &quot;Artist - Title&quot;" Click="AutoRenameArtistTitle_Click"
                                          ToolTip="Rename selected files to 'Artist - Title.ext'. Files already in this format are skipped untouched."/>
                                <MenuItem Header="To &quot;Title - Artist&quot;" Click="AutoRenameTitleArtist_Click"
                                          ToolTip="Rename selected files to 'Title - Artist.ext'. Files already in this format are skipped untouched."/>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Write Replay Gain" Click="WriteReplayGain_Click"/>
                        </MenuItem>
                        <!-- Analyze &amp; Identify submenu -->
                        <MenuItem Header="Analyze / Identify">
                            <MenuItem Header="Identify with AcoustID" Click="AcoustIdIdentify_Click"/>
                            <MenuItem Header="Compare Waveforms" Click="CompareWaveforms_Click"/>
                            <MenuItem Header="Compare Spectrograms" Click="CompareSpectrograms_Click"/>
                            <MenuItem Header="Find Duplicates..." Click="FindDuplicates_Click"/>
                        </MenuItem>
                        <!-- Spectrogram submenu -->
                        <MenuItem Header="Spectrogram">
                            <MenuItem Header="View Spectrogram" Click="ViewSpectrogram_Click"/>
                            <MenuItem Header="Save Spectrogram..." Click="SaveSpectrogram_Click"/>
                            <Separator/>
                            <MenuItem Header="View Album Cover" Click="ViewAlbumCover_Click"/>
                        </MenuItem>
                        <!-- File Operations submenu -->
                        <MenuItem Header="File Operations">
                            <MenuItem Header="Copy to Folder..." Click="CopyToFolder_Click"/>
                            <MenuItem Header="Move to Folder..." Click="MoveToFolder_Click"/>
                            <Separator/>
                            <MenuItem Header="Save to Playlist..." Click="SaveToPlaylist_Click"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Open File Location" Click="OpenFileLocation_Click"/>
                        <MenuItem Header="Copy Path" Click="CopyPath_Click"/>
                        <MenuItem Header="Copy File Name" Click="CopyFileName_Click"/>
                        <Separator/>
                        <MenuItem Header="Remove from List" Click="RemoveFromList_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>

                <!-- ═══ Columns ═══ -->
                <DataGrid.Columns>
                    <!-- Favorites star column -->
                    <DataGridTemplateColumn Header="★" Width="30" CanUserSort="True"
                                            SortMemberPath="IsFavorite">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding IsFavorite, Converter={StaticResource StarConverter}}"
                                           FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="#FFD700" Cursor="Hand"
                                           MouseLeftButtonDown="StarCell_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status" Width="100" SortMemberPath="Status">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                        CornerRadius="3" Padding="8,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                               Foreground="White" FontWeight="Bold" FontSize="11"
                                               FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180"/>
                    <DataGridTextColumn Header="Artist" Binding="{Binding Artist}" Width="140"/>
                    <DataGridTextColumn Header="Filename" Binding="{Binding FileName}" Width="180"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="140"/>
                    <DataGridTextColumn Header="Sample Rate" Binding="{Binding SampleRateDisplay}" Width="105" SortMemberPath="SampleRate"/>
                    <DataGridTextColumn Header="Bits" Binding="{Binding BitsPerSampleDisplay}" Width="65" SortMemberPath="BitsPerSample"/>
                    <DataGridTextColumn Header="Ch" Binding="{Binding ChannelsDisplay}" Width="60" SortMemberPath="Channels"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="75" SortMemberPath="DurationSeconds"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" Width="80" SortMemberPath="FileSizeBytes"/>

                    <!-- Bitrate (color-coded) -->
                    <DataGridTemplateColumn Header="Bitrate" Width="95" SortMemberPath="ReportedBitrate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ReportedBitrateDisplay}"
                                           FontSize="12.5" FontFamily="Segoe UI"
                                           FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource BitrateToColor}">
                                            <Binding Path="ReportedBitrate"/>
                                            <Binding Path="ActualBitrate"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Actual Bitrate (color-coded) -->
                    <DataGridTemplateColumn Header="Actual BR" Width="95" SortMemberPath="ActualBitrate">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActualBitrateDisplay}"
                                           FontSize="12.5" FontFamily="Segoe UI"
                                           FontWeight="SemiBold">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource BitrateToColor}">
                                            <Binding Path="ReportedBitrate"/>
                                            <Binding Path="ActualBitrate"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Format" Binding="{Binding FormatDisplay}" Width="90" SortMemberPath="Extension"/>
                    <DataGridTextColumn Header="Max Freq" Binding="{Binding EffectiveFrequencyDisplay}" Width="100" SortMemberPath="EffectiveFrequency"/>

                    <DataGridTemplateColumn Header="Clipping" Width="120" SortMemberPath="HasClipping">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ClippingDisplay}"
                                           FontWeight="SemiBold" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           TextTrimming="None">
                                    <TextBlock.Foreground>
                                        <MultiBinding Converter="{StaticResource ClippingToColor}">
                                            <Binding Path="HasClipping"/>
                                            <Binding Path="HasScaledClipping"/>
                                        </MultiBinding>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="BPM" Binding="{Binding BpmDisplay}" Width="65" SortMemberPath="Bpm"/>
                    <DataGridTextColumn Header="Replay Gain" Binding="{Binding ReplayGainDisplay}" Width="105" SortMemberPath="ReplayGain"/>
                    <DataGridTextColumn Header="DR" Binding="{Binding DynamicRangeDisplay}" Width="65" SortMemberPath="DynamicRange">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- MQA Detection -->
                    <DataGridTemplateColumn Header="MQA" Width="120" SortMemberPath="IsMqa">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MqaDisplay}"
                                           Foreground="{Binding IsMqa, Converter={StaticResource MqaToColor}}"
                                           FontWeight="SemiBold" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           ToolTip="{Binding MqaEncoder}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- AI Detection -->
                    <DataGridTemplateColumn Header="AI" Width="120" SortMemberPath="IsAnyAiDetected">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AiDisplay}"
                                           Foreground="{Binding AiVerdict, Converter={StaticResource AiToColor}}"
                                           FontWeight="SemiBold" FontSize="11" FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           ToolTip="{Binding AiDetailTooltip}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Fake Stereo Detection -->
                    <DataGridTextColumn Header="Fake Stereo" Width="120" Binding="{Binding FakeStereoDisplay}" SortMemberPath="IsFakeStereo">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Silence -->
                    <DataGridTextColumn Header="Silence" Width="150" Binding="{Binding SilenceDisplay}" SortMemberPath="HasExcessiveSilence">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Date Modified -->
                    <DataGridTextColumn Header="Date Modified" Width="130" Binding="{Binding DateModifiedDisplay}" SortMemberPath="DateModified">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Date Created -->
                    <DataGridTextColumn Header="Date Created" Width="130" Binding="{Binding DateCreatedDisplay}" SortMemberPath="DateCreated">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- True Peak -->
                    <DataGridTextColumn Header="True Peak" Width="100" Binding="{Binding TruePeakDisplay}" SortMemberPath="TruePeakDbTP">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- LUFS -->
                    <DataGridTextColumn Header="LUFS" Width="100" Binding="{Binding LufsDisplay}" SortMemberPath="IntegratedLufs">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- Rip Quality -->
                    <DataGridTextColumn Header="Rip Quality" Width="200" Binding="{Binding RipQualityDisplay}" SortMemberPath="RipQuality" Visibility="Visible">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ═══ Grid Splitter ═══ -->
            <GridSplitter Grid.Row="1" Height="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBg}"
                          ShowsPreview="True"/>

            <!-- ═══ Bottom Panel (Spectrogram + Player) ═══ -->
            <Border Grid.Row="2" Background="{DynamicResource GlassPanelBg}"
                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <!-- ═══ Player Bar ═══ -->
                    <Border DockPanel.Dock="Bottom" Background="{DynamicResource GlassToolbarBg}"
                            Padding="10,6" BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="BtnShuffle"
                                    Click="Shuffle_Click" Style="{StaticResource PlayerButton}"
                                    ToolTip="Shuffle">
                                <Viewbox Width="16" Height="16" Margin="-2">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="ShuffleIcon" Data="M 1,12 L 10,3 M 10,3 L 7,3 M 10,3 L 10,6 M 1,4 L 10,13 M 10,13 L 7,13 M 10,13 L 10,10"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2.2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Grid.Column="1" x:Name="BtnLoop"
                                    Click="Loop_Click" Style="{StaticResource PlayerButton}"
                                    ToolTip="Loop: Off" Margin="2,0,0,0">
                                <Viewbox Width="14" Height="14" Margin="-1">
                                    <Canvas Width="16" Height="16">
                                        <!-- Modern repeat icon: rounded rectangular loop with chevron arrowheads -->
                                        <Path x:Name="LoopIcon"
                                              Data="M 4,5 L 12,5 M 10,3 L 12,5 L 10,7 M 12,5 Q 14,5 14,8 Q 14,11 11,11 L 4,11 M 6,9 L 4,11 L 6,13 M 4,11 Q 2,11 2,8 Q 2,5 5,5"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.6"
                                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <TextBlock x:Name="LoopOneIndicator" Text="1" FontSize="6" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMuted}" Visibility="Collapsed"
                                                   Canvas.Left="6.5" Canvas.Top="5"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Grid.Column="2" x:Name="BtnPrevTrack"
                                    Click="PrevTrack_Click" Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Previous Track">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="16" Height="14">
                                        <Path Data="M 2,1 L 2,13" Stroke="{DynamicResource TextPrimary}" StrokeThickness="2"/>
                                        <Path Data="M 5,7 L 14,1 L 14,13 Z" Fill="{DynamicResource TextPrimary}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Grid.Column="3" Click="Rewind_Click"
                                    Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Rewind 5s">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="18" Height="14">
                                        <Path Data="M 1,7 L 9,1 L 9,13 Z" Fill="{DynamicResource TextPrimary}"/>
                                        <Path Data="M 9,7 L 17,1 L 17,13 Z" Fill="{DynamicResource TextPrimary}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Grid.Column="4" x:Name="BtnPlayPause"
                                    Click="PlayPause_Click" Style="{StaticResource PlayerButton}" Margin="4,0,0,0">
                                <Viewbox x:Name="PlayPauseIcon" Width="16" Height="16">
                                    <Canvas x:Name="PlayPauseCanvas" Width="16" Height="16">
                                        <Path x:Name="PlayIcon" Data="M 3,1 L 3,15 L 15,8 Z" Fill="{DynamicResource TextPrimary}"/>
                                        <Path x:Name="PauseIcon" Data="M 2,1 L 2,15 L 6,15 L 6,1 Z M 10,1 L 10,15 L 14,15 L 14,1 Z" Fill="{DynamicResource TextPrimary}" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Grid.Column="5" Click="Forward_Click"
                                    Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Forward 5s">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="18" Height="14">
                                        <Path Data="M 1,1 L 1,13 L 9,7 Z" Fill="{DynamicResource TextPrimary}"/>
                                        <Path Data="M 9,1 L 9,13 L 17,7 Z" Fill="{DynamicResource TextPrimary}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button Grid.Column="6" x:Name="BtnNextTrack"
                                    Click="NextTrack_Click" Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Next Track">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="16" Height="14">
                                        <Path Data="M 2,1 L 2,13 L 12,7 Z" Fill="{DynamicResource TextPrimary}"/>
                                        <Path Data="M 14,1 L 14,13" Stroke="{DynamicResource TextPrimary}" StrokeThickness="2"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Seek bar + waveform + time -->
                            <Grid Grid.Column="7" Margin="12,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Canvas x:Name="WaveformCanvas" Height="26" ClipToBounds="True"
                                            VerticalAlignment="Center" Margin="0"/>
                                    <Slider x:Name="SeekSlider"
                                            Minimum="0" Maximum="100" Value="0"
                                            ValueChanged="SeekSlider_ValueChanged"
                                            PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseDown"
                                            PreviewMouseLeftButtonUp="SeekSlider_MouseUp"
                                            Thumb.DragCompleted="SeekSlider_DragCompleted"
                                            MouseMove="SeekSlider_MouseMove"
                                            Style="{StaticResource SeekSlider}"
                                            VerticalAlignment="Center"/>
                                    <Canvas x:Name="PlaybarAnimCanvas" IsHitTestVisible="False"
                                            Height="26" VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                            ClipToBounds="False" Margin="0"/>
                                </Grid>
                                <Grid Grid.Row="1">
                                    <TextBlock x:Name="PlayerTimeText" Text="0:00 / 0:00"
                                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                                               FontFamily="Segoe UI" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="PlayerFileText" Text=""
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Grid>

                            <!-- Volume -->
                            <Viewbox Grid.Column="8" x:Name="VolumeIcon" Width="14" Height="14"
                                     VerticalAlignment="Center" Margin="0,0,4,0" Cursor="Hand"
                                     MouseLeftButtonDown="VolumeIcon_Click">
                                <Canvas Width="16" Height="16">
                                    <Path x:Name="VolumeIconPath"
                                          Data="M 2,5 L 5,5 L 9,2 L 9,14 L 5,11 L 2,11 Z M 11,5 Q 13,8 11,11"
                                          Fill="{DynamicResource TextMuted}"
                                          Stroke="{DynamicResource TextMuted}" StrokeThickness="0.5"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="9" x:Name="VolumeLabel" Text="100%"
                                       Foreground="{DynamicResource TextMuted}" FontSize="11"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center" Margin="0,0,6,0" Width="32"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="VolumeIcon_Click"/>
                            <Slider Grid.Column="10" x:Name="VolumeSlider"
                                    Minimum="0" Maximum="100" Value="100"
                                    ValueChanged="VolumeSlider_ValueChanged"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource VolumeSlider}"/>

                            <!-- EQ Toggle -->
                            <Button Grid.Column="11" x:Name="BtnEqToggle" Click="EqToggle_Click"
                                    Style="{StaticResource PlayerButton}" Margin="8,0,0,0"
                                    ToolTip="Equalizer" Padding="6,4">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="EqIcon"
                                              Data="M 3,2 L 3,14 M 8,2 L 8,14 M 13,2 L 13,14"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Ellipse x:Name="NpEqKnob1" Width="4" Height="4" Canvas.Left="1" Canvas.Top="8"
                                                 Fill="{DynamicResource TextMuted}"/>
                                        <Ellipse x:Name="NpEqKnob2" Width="4" Height="4" Canvas.Left="6" Canvas.Top="3"
                                                 Fill="{DynamicResource TextMuted}"/>
                                        <Ellipse x:Name="NpEqKnob3" Width="4" Height="4" Canvas.Left="11" Canvas.Top="10"
                                                 Fill="{DynamicResource TextMuted}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Now Playing -->
                            <Button Grid.Column="12" Click="NowPlaying_Click"
                                    Style="{StaticResource PlayerButton}" Margin="4,0,0,0"
                                    ToolTip="Now Playing / Lyrics View" Padding="6,4">
                                <Path Width="13" Height="13"
                                      Stretch="Uniform"
                                      Data="M 3,1 L 3,15 L 15,8 Z"
                                      Fill="{DynamicResource PlaybarAccentColor}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ═══ Equalizer Panel ═══ -->
                    <Border x:Name="EqPanel" DockPanel.Dock="Bottom" Visibility="Collapsed"
                            Background="{DynamicResource GlassFloatingBg}"
                            BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1" CornerRadius="10"
                            Padding="10,7" Margin="0,0,0,4">
                        <StackPanel Orientation="Vertical">
                            <!-- Top row: enable + reset moved to the LEFT of the preset selector,
                                 freeing the full width below for the band sliders. -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                <CheckBox x:Name="ChkEqEnabled" Content="EQ" VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                          FontFamily="Segoe UI" Margin="0,0,8,0"
                                          Checked="EqEnabled_Changed" Unchecked="EqEnabled_Changed">
                                    <CheckBox.Template>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border x:Name="checkBorder" Width="15" Height="15"
                                                        Background="{DynamicResource InputBg}"
                                                        BorderBrush="{DynamicResource ButtonBorder}"
                                                        BorderThickness="1" CornerRadius="3"
                                                        VerticalAlignment="Center" Margin="0,0,5,0">
                                                    <TextBlock x:Name="checkMark" Text="&#xE73E;"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                               Foreground="{DynamicResource AccentColor}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Visibility="Collapsed"/>
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="checkBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="checkBorder" Property="BorderBrush"
                                                            Value="{DynamicResource AccentColor}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </CheckBox.Template>
                                </CheckBox>
                                <Button Content="Reset" FontSize="10" FontFamily="Segoe UI"
                                        Padding="6,2" Margin="0,0,10,0" Cursor="Hand"
                                        VerticalAlignment="Center"
                                        Click="EqReset_Click"
                                        Background="{DynamicResource ButtonBg}"
                                        Foreground="{DynamicResource TextMuted}"
                                        BorderBrush="{DynamicResource ButtonBorder}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1" CornerRadius="3"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background"
                                                            Value="{DynamicResource ButtonHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <ComboBox x:Name="EqProfileCombo" Width="120" FontSize="11"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource ThemedComboBox}"
                                          ItemContainerStyle="{StaticResource ThemedComboBoxItem}"
                                          Background="{DynamicResource InputBg}"
                                          Foreground="{DynamicResource TextPrimary}"
                                          BorderBrush="{DynamicResource ButtonBorder}"
                                          SelectionChanged="EqProfile_Changed"/>
                                <Button x:Name="BtnEqSaveProfile" Content="Save" FontSize="10"
                                        Padding="6,2" Margin="4,0,0,0" Cursor="Hand"
                                        VerticalAlignment="Center"
                                        Click="EqSaveProfile_Click"
                                        Style="{StaticResource DarkButton}"
                                        Background="{DynamicResource ButtonBg}"
                                        Foreground="{DynamicResource TextPrimary}"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        ToolTip="Save current EQ as a custom profile"/>
                                <Button x:Name="BtnEqDeleteProfile" Content="Del" FontSize="10"
                                        Padding="6,2" Margin="3,0,0,0" Cursor="Hand"
                                        VerticalAlignment="Center"
                                        Click="EqDeleteProfile_Click"
                                        Visibility="Collapsed"
                                        Style="{StaticResource DarkButton}"
                                        Background="{DynamicResource ButtonBg}"
                                        Foreground="{DynamicResource TextPrimary}"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        ToolTip="Delete this custom profile"/>
                            </StackPanel>
                            <StackPanel x:Name="EqSlidersPanel"
                                        Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- 10 EQ band sliders generated in code-behind -->
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ═══ Spectrogram Area ═══ -->
                    <Grid>
                        <TextBlock x:Name="SpectrogramPlaceholder"
                                   Text="Select a file to view its spectrogram — Double-click or press Enter to play"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextDim}" FontSize="14" FontStyle="Italic"
                                   FontFamily="Segoe UI"/>

                        <StackPanel x:Name="SpectrogramLoading" Visibility="Collapsed"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Generating spectrogram..."
                                       Foreground="{DynamicResource TextMuted}" FontSize="14"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" Width="250" Height="4"
                                         Margin="0,10,0,0"
                                         Foreground="{DynamicResource AccentColor}"
                                         Background="{DynamicResource ProgressBg}"/>
                        </StackPanel>

                        <DockPanel x:Name="SpectrogramPanel" Visibility="Collapsed">
                            <Grid DockPanel.Dock="Top" Margin="10,5,10,6">
                                <TextBlock x:Name="SpectrogramTitle"
                                           Foreground="{DynamicResource TextPrimary}" FontSize="12"
                                           FontWeight="SemiBold" FontFamily="Segoe UI"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="BtnSpectrogramChannel" Click="SpectrogramChannel_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Switch between Mono and L-R Difference channel" Margin="0,0,6,0">
                                        <TextBlock x:Name="SpectrogramChannelText" Text="L-R"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                    <Button x:Name="BtnSpectrogramScale" Click="SpectrogramScale_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Switch between Log and Linear frequency scale" Margin="0,0,6,0">
                                        <TextBlock x:Name="SpectrogramScaleText" Text="Linear"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                    <Button x:Name="BtnJumpToEnd" Click="JumpToEnd_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Show last 10 seconds of the recording zoomed in" Margin="0,0,6,0">
                                        <TextBlock x:Name="JumpToEndText" Text="End"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                    <Button x:Name="BtnResetZoom" Click="ResetZoom_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Reset spectrogram zoom (use mouse wheel to zoom in/out)" Margin="0,0,6,0"
                                            Visibility="Collapsed">
                                        <TextBlock x:Name="ZoomLevelText" Text="1x"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                    <Button x:Name="BtnToggleAlbumCover" Click="ToggleAlbumCover_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Toggle Album Cover" Margin="0,0,6,0">
                                        <TextBlock x:Name="AlbumCoverToggleText" Text="Cover"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                    <Button x:Name="BtnVisualizerStyle" Click="VisualizerStyle_Click"
                                            Cursor="Hand" Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Choose visualizer style"
                                            Margin="0,0,6,0" Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock x:Name="VisualizerStyleText" Text="Style"
                                                       FontSize="10" FontFamily="Segoe UI"/>
                                            <TextBlock Text=" ▾" FontSize="9" FontFamily="Segoe UI"
                                                       VerticalAlignment="Center" Opacity="0.6"/>
                                        </StackPanel>
                                    </Button>
                                    <Popup x:Name="VisualizerStylePopup" StaysOpen="False"
                                           Placement="Bottom" PlacementTarget="{Binding ElementName=BtnVisualizerStyle}"
                                           AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="{DynamicResource GlassFloatingBg}"
                                                BorderBrush="{DynamicResource GlassBorderBrush}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="2" Margin="0,1,0,0">
                                            <StackPanel x:Name="VisualizerStyleMenu" MinWidth="90"/>
                                        </Border>
                                    </Popup>
                                    <Button x:Name="BtnToggleVisualizer" Click="ToggleVisualizer_Click"
                                            HorizontalAlignment="Right" Cursor="Hand"
                                            Style="{StaticResource DarkButton}" Padding="6,2"
                                            ToolTip="Toggle Spectrogram / Visualizer">
                                        <TextBlock x:Name="VisualizerToggleText" Text="Visualizer"
                                                   FontSize="10" FontFamily="Segoe UI"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="5,0,5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="AlbumCoverColumn" Width="0"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <Grid x:Name="FreqLabelGrid" Width="40" HorizontalAlignment="Left"
                                          VerticalAlignment="Stretch" Margin="0,0,0,2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" x:Name="FreqLabelTop"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="1" x:Name="FreqLabelUpperMid"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="2" x:Name="FreqLabelMid"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"/>
                                        <TextBlock Grid.Row="3" x:Name="FreqLabelLowerMid"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Top"
                                                   Margin="0,-4,0,0"/>
                                        <TextBlock Grid.Row="3" x:Name="FreqLabelBot" Text="20 Hz"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                   FontFamily="Segoe UI" VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <ScrollViewer x:Name="SpectrogramScrollViewer"
                                                   Margin="43,0,0,2"
                                                   HorizontalScrollBarVisibility="Auto"
                                                   VerticalScrollBarVisibility="Disabled"
                                                   PreviewMouseWheel="SpectrogramScrollViewer_PreviewMouseWheel"
                                                   SizeChanged="SpectrogramScrollViewer_SizeChanged"
                                                   Background="Transparent">
                                        <Image x:Name="SpectrogramImage"
                                               Stretch="Fill"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               MouseLeftButtonDown="SpectrogramImage_MouseDoubleClick"/>
                                    </ScrollViewer>
                                    <Canvas x:Name="VisualizerCanvas" Visibility="Collapsed"
                                            Margin="0,0,0,2" ClipToBounds="True"
                                            Background="Transparent"/>
                                </Grid>
                                <Border Grid.Column="1" x:Name="AlbumCoverPanel" Visibility="Collapsed"
                                        Margin="8,0,0,2" VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Background="Transparent">
                                    <Image x:Name="AlbumCoverImage"
                                           MaxWidth="200" MaxHeight="200"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           ToolTip="Album Cover">
                                        <Image.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Save Cover..." Click="SaveAlbumCoverFromPanel_Click"/>
                                            </ContextMenu>
                                        </Image.ContextMenu>
                                    </Image>
                                </Border>
                            </Grid>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

    <!-- ═══ Now Playing Panel (takes over entire window) ═══ -->
    <Grid x:Name="NowPlayingPanel" Visibility="Collapsed" Background="{DynamicResource WindowBg}">
        <Image x:Name="NpAlbumBackdropImage"
               Stretch="UniformToFill"
               Opacity="0"
               IsHitTestVisible="False"
               RenderOptions.BitmapScalingMode="LowQuality"
               CacheMode="BitmapCache">
            <!-- Static, heavily-blurred album backdrop sitting behind the animated
                 particle/gradient layers: cache the blurred bitmap on the GPU so the
                 BlurEffect isn't recomputed every animation frame. -->
            <Image.Effect>
                <BlurEffect x:Name="NpAlbumBackdropBlur" Radius="24" RenderingBias="Performance"/>
            </Image.Effect>
        </Image>
        <Border x:Name="NpAlbumBackdropBrightnessOverlay"
                IsHitTestVisible="False"
                Opacity="0"/>
        <!-- Dynamic background gradient from album art -->
        <Border x:Name="NpBgGradient" Opacity="0.6"/>
        <Canvas x:Name="NpStarsCanvas" Opacity="0" IsHitTestVisible="False" ClipToBounds="True"
                SizeChanged="NpStarsCanvas_SizeChanged"/>
        <!-- Dark overlay that adapts to color-match mode -->
        <Border x:Name="NpDarkOverlay" Background="#66000000"/>

        <DockPanel>
            <!-- ═══ Bottom: Controls Bar (docked first = very bottom) ═══ -->
            <Border x:Name="NpBottomBar" DockPanel.Dock="Bottom" Padding="12,6,12,8"
                    Background="{DynamicResource GlassToolbarBg}"
                    BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Seek bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NpTimeElapsed" Grid.Column="0" Text="0:00"
                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   FontFamily="Segoe UI"/>
                        <Grid x:Name="NpPlaybarHost" Grid.Column="1">
                            <Canvas x:Name="NpWaveformCanvas" Height="26"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    ClipToBounds="True"/>
                            <!-- Animated bar canvas sits BELOW the slider so the slider's thumb (the
                                 playhead dot) always renders on top of the bar (the dot must be above
                                 the playbar, esp. under ColorMatch where the bar is a contrasting color). -->
                            <Canvas x:Name="NpPlaybarAnimCanvas" Height="8"
                                    IsHitTestVisible="False"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    ClipToBounds="True"/>
                            <Slider x:Name="NpSeekSlider"
                                    Minimum="0" Maximum="100"
                                    Style="{StaticResource SeekSlider}"
                                    ValueChanged="NpSeekSlider_ValueChanged"
                                    PreviewMouseLeftButtonDown="NpSeekSlider_PreviewMouseDown"
                                    PreviewMouseLeftButtonUp="NpSeekSlider_MouseUp"
                                    MouseMove="NpSeekSlider_MouseMove"
                                    Thumb.DragCompleted="NpSeekSlider_DragCompleted"/>
                        </Grid>
                        <TextBlock x:Name="NpTimeTotal" Grid.Column="2" Text="0:00"
                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                   VerticalAlignment="Center" Margin="8,0,0,0"
                                   FontFamily="Segoe UI"/>
                    </Grid>

                    <!-- Row 1: track info left, transport center, options right -->
                    <Grid Grid.Row="1" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="0"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Track info + specs + tags -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                    MinWidth="0">
                            <Grid Margin="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MaxWidth="260"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MinWidth="0"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="NpSongTitle" Text="No track playing"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource TextPrimary}" FontSize="14"
                                           FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI"/>
                                <TextBlock Text=" — "
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                           VerticalAlignment="Center" Margin="4,0,4,0"
                                           FontFamily="Segoe UI"/>
                                <TextBlock x:Name="NpSongArtist" Text=""
                                           Grid.Column="2"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                           TextTrimming="CharacterEllipsis" FontFamily="Segoe UI"
                                           VerticalAlignment="Center" Margin="0,2,0,0"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                <TextBlock x:Name="NpSongSpecs" Text=""
                                           Foreground="{DynamicResource TextSecondary}" FontSize="10"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"/>
                                <!-- MQA / AI tags area -->
                                <StackPanel x:Name="NpTagsPanel" Orientation="Horizontal"
                                            Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Center: Playback controls -->
                        <StackPanel x:Name="NpTransportBar" Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button x:Name="NpShuffleBtn" Click="NpShuffle_Click" ToolTip="Shuffle"
                                    Style="{StaticResource PlayerButton}" MinWidth="28" Padding="4,4">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpShuffleIcon"
                                              Data="M 1,12 L 10,3 M 10,3 L 7,3 M 10,3 L 10,6 M 1,4 L 10,13 M 10,13 L 7,13 M 10,13 L 10,10"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2.2"
                                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="NpLoopBtn" Click="NpLoop_Click" ToolTip="Loop: Off"
                                    Style="{StaticResource PlayerButton}" MinWidth="28" Padding="4,4" Margin="2,0,0,0">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpLoopIcon"
                                              Data="M 4,5 L 12,5 M 10,3 L 12,5 L 10,7 M 12,5 Q 14,5 14,8 Q 14,11 11,11 L 4,11 M 6,9 L 4,11 L 6,13 M 4,11 Q 2,11 2,8 Q 2,5 5,5"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.7"
                                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <TextBlock x:Name="NpLoopOneIndicator" Text="1" FontSize="6" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextMuted}" Visibility="Collapsed"
                                                   Canvas.Left="6.5" Canvas.Top="5"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="NpPrevBtn" Click="NpPrev_Click" ToolTip="Previous Track"
                                    Style="{StaticResource PlayerButton}" Margin="2,0,0,0"
                                    MinWidth="28" Padding="4,4">
                                <Viewbox Width="13" Height="13">
                                    <Canvas Width="16" Height="14">
                                        <Path x:Name="NpPrevLine" Data="M 2,1 L 2,13" Stroke="{DynamicResource TextPrimary}" StrokeThickness="2"/>
                                        <Path x:Name="NpPrevFill" Data="M 5,7 L 14,1 L 14,13 Z" Fill="{DynamicResource TextPrimary}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="NpPlayPauseBtn" Click="NpPlayPause_Click" ToolTip="Play/Pause"
                                    Style="{StaticResource PlayerButton}" Margin="2,0,0,0"
                                    MinWidth="36" Padding="6,4">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpPlayPath" Data="M 3,1 L 3,15 L 15,8 Z"
                                              Fill="{DynamicResource TextPrimary}"/>
                                        <Path x:Name="NpPausePath"
                                              Data="M 2,1 L 2,15 L 6,15 L 6,1 Z M 10,1 L 10,15 L 14,15 L 14,1 Z"
                                              Fill="{DynamicResource TextPrimary}" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="NpNextBtn" Click="NpNext_Click" ToolTip="Next Track"
                                    Style="{StaticResource PlayerButton}" Margin="2,0,0,0"
                                    MinWidth="28" Padding="4,4">
                                <Viewbox Width="13" Height="13">
                                    <Canvas Width="16" Height="14">
                                        <Path x:Name="NpNextFill" Data="M 2,1 L 2,13 L 12,7 Z" Fill="{DynamicResource TextPrimary}"/>
                                        <Path x:Name="NpNextLine" Data="M 14,1 L 14,13" Stroke="{DynamicResource TextPrimary}" StrokeThickness="2"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <!-- Right: option buttons + volume + back -->
                        <StackPanel x:Name="NpOptionsBar" Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="NpAutoPlayBtn" Click="NpAutoPlay_Click"
                                    ToolTip="Auto-play next" Style="{StaticResource PlayerButton}"
                                    Margin="8,0,4,0" MinWidth="28" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpAutoPlayIcon"
                                              Data="M 1,8 C 1,4 4,2 8,5 C 12,2 15,4 15,8 C 15,12 12,14 8,11 C 4,14 1,12 1,8 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.4"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Crossfade -->
                            <Button x:Name="NpCrossfadeBtn" Click="NpCrossfade_Click"
                                    ToolTip="Crossfade settings" Style="{StaticResource PlayerButton}"
                                    MinWidth="28" Padding="4,4" Margin="2,0,0,0">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpCrossfadeIcon"
                                              Data="M 1,4 L 6,8 L 1,12 M 15,4 L 10,8 L 15,12"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.8"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpCrossfadePopup" StaysOpen="False"
                                   Placement="Top" PlacementTarget="{Binding ElementName=NpCrossfadeBtn}"
                                   AllowsTransparency="True" PopupAnimation="Fade"
                                   VerticalOffset="-4">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Padding="12,10" MinWidth="220">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="12"
                                                          Opacity="0.35" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel Orientation="Vertical">
                                        <Button x:Name="NpCrossfadeToggleBtn" Click="NpCrossfadeToggle_Click"
                                                Style="{StaticResource DarkButton}" Padding="8,5"
                                                HorizontalContentAlignment="Left" Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="NpCrossfadeToggleText" Text="Crossfade: OFF"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                        <TextBlock Text="Duration (seconds)"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11" Margin="0,0,0,3"/>
                                        <Slider x:Name="NpCrossfadeDurationSlider"
                                                Minimum="1" Maximum="30" SmallChange="1"
                                                ValueChanged="NpCrossfadeDuration_ValueChanged"
                                                Style="{StaticResource CrossfadeSlider}"
                                                Margin="0,0,0,4"/>
                                        <TextBlock x:Name="NpCrossfadeDurationLabel"
                                                   Text="5s" Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" HorizontalAlignment="Center"
                                                   Margin="0,0,0,10"/>
                                        <TextBlock Text="Curve"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11" Margin="0,0,0,3"/>
                                        <ComboBox x:Name="NpCrossfadeCurveCombo"
                                                  SelectionChanged="NpCrossfadeCurve_Changed"
                                                  Style="{StaticResource ThemedComboBox}"
                                                  Margin="0,0,0,10"/>
                                        <Button x:Name="NpCrossfadeSkipBtn" Click="NpCrossfadeSkipToggle_Click"
                                                Style="{StaticResource DarkButton}" Padding="8,5"
                                                HorizontalContentAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="NpCrossfadeSkipText"
                                                           Text="Crossfade on manual skip: OFF"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI" FontSize="11"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Visualizer toggle -->
                            <Button x:Name="NpVisualizerBtn" Click="NpVisualizerToggle_Click"
                                    ToolTip="Visualizer" Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpVisualizerIcon"
                                              Data="M 1,12 L 1,6 M 4,12 L 4,3 M 7,12 L 7,8 M 10,12 L 10,2 M 13,12 L 13,7"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Visualizer style dropdown -->
                            <Button x:Name="NpVizStyleBtn" Click="NpVisualizerStyle_Click"
                                    ToolTip="Visualizer style" Style="{StaticResource PlayerButton}"
                                    MinWidth="20" Padding="2,4">
                                <Viewbox Width="8" Height="8">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpVizStyleIcon" Data="M 3,5 L 8,11 L 13,5"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2.5"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpVizStylePopup" StaysOpen="False"
                                   Placement="Top" PlacementTarget="{Binding ElementName=NpVizStyleBtn}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="3"
                                        Padding="2" Margin="0,0,0,2">
                                    <StackPanel x:Name="NpVizStyleMenu" MinWidth="90"/>
                                </Border>
                            </Popup>
                            <!-- Visualizer placement toggle -->
                            <Button x:Name="NpVizPlacementBtn" Click="NpVizPlacement_Click"
                                    ToolTip="Visualizer: Full-width"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpVizPlacementIcon"
                                              Data="M 1,13 L 15,13 M 1,10 L 15,10"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Background animation menu -->
                            <Button x:Name="NpBgFxBtn" Click="NpBgFx_Click"
                                    ToolTip="Background animations" Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4" Margin="2,0,0,0">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpBgFxIcon"
                                              Data="M 2,11 C 4,6 7,14 9,8 S 13,5 14,10 M 3,4 A 1.5,1.5 0 1,1 3,7 A 1.5,1.5 0 1,1 3,4 Z M 11,2 L 12,4 L 14,5 L 12,6 L 11,8 L 10,6 L 8,5 L 10,4 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.4"
                                              Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpBgFxPopup" PlacementTarget="{Binding ElementName=NpBgFxBtn}"
                                   Placement="Top" VerticalOffset="-4" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="10" MinWidth="260">
                                    <StackPanel>
                                        <TextBlock Text="Background animation" Foreground="{DynamicResource TextPrimary}"
                                                   FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <ComboBox x:Name="NpBgFxModeCombo" Style="{StaticResource ThemedComboBox}"
                                                  SelectionChanged="NpBgFxModeCombo_SelectionChanged" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="NpBgFxColorDriftCheck" Content="Color Drift glow (under effect)"
                                                  Style="{StaticResource ThemedCheckBox}"
                                                  Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                                  Checked="NpBgFxColorDrift_Changed" Unchecked="NpBgFxColorDrift_Changed"
                                                  ToolTip="Run the Color Drift gradient glow as a background under the selected effect"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="NpBgFxAlbumColorsCheck" Content="Use album colors"
                                                  Style="{StaticResource ThemedCheckBox}"
                                                  Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                                  Checked="NpBgFxAlbumColors_Changed" Unchecked="NpBgFxAlbumColors_Changed"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="NpBgFxCycleCheck" Content="Cycle animations"
                                                  Style="{StaticResource ThemedCheckBox}"
                                                  Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                                  Checked="NpBgFxCycle_Changed" Unchecked="NpBgFxCycle_Changed"
                                                  Margin="0,0,0,8"/>
                                        <TextBlock Text="Cycle speed" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                        <Slider x:Name="NpBgFxCycleSpeedSlider" Minimum="0.25" Maximum="3" Value="1"
                                                Style="{StaticResource CrossfadeSlider}" ValueChanged="NpBgFxCycleSpeed_Changed"
                                                Margin="0,0,0,8"/>
                                        <CheckBox x:Name="NpBgFxCycleSongCheck" Content="Advance on song change"
                                                  Style="{StaticResource ThemedCheckBox}"
                                                  Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                                  Checked="NpBgFxCycleSong_Changed" Unchecked="NpBgFxCycleSong_Changed"
                                                  Margin="0,0,0,8"/>
                                        <TextBlock Text="Density / intensity" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                        <Slider x:Name="NpBgFxDensitySlider" Minimum="0.25" Maximum="2.5" Value="1"
                                                Style="{StaticResource CrossfadeSlider}" ValueChanged="NpBgFxDensity_Changed"
                                                Margin="0,0,0,8"/>
                                        <CheckBox x:Name="NpBgFxLightningCheck" Content="Rain lightning"
                                                  Style="{StaticResource ThemedCheckBox}"
                                                  Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                                  Checked="NpBgFxLightning_Changed" Unchecked="NpBgFxLightning_Changed"
                                                  Margin="0,0,0,8"/>
                                        <Border x:Name="NpBgFxLightningPrompt" Visibility="Collapsed"
                                                Background="{DynamicResource GlassFloatingBg}"
                                                BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Enable lightning flashes for Rain?" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextPrimary}" FontSize="11" Margin="0,0,0,6"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="No" Style="{StaticResource PlayerButton}" Padding="10,3" Margin="0,0,6,0"
                                                            Click="NpBgFxLightningPromptNo_Click"/>
                                                    <Button Content="Yes" Style="{StaticResource PlayerButton}" Padding="10,3"
                                                            Click="NpBgFxLightningPromptYes_Click"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="Snowflake amount" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                        <Slider x:Name="NpBgFxSnowflakeSlider" Minimum="0.25" Maximum="2.5" Value="1"
                                                Style="{StaticResource CrossfadeSlider}" ValueChanged="NpBgFxSnowflake_Changed"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Equalizer -->
                            <Button x:Name="NpEqBtn" Click="NpEq_Click"
                                    ToolTip="Equalizer" Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4" Margin="2,0,0,0">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpEqIcon"
                                              Data="M 3,2 L 3,14 M 8,2 L 8,14 M 13,2 L 13,14"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Ellipse Width="4" Height="4" Canvas.Left="1" Canvas.Top="8"
                                                 Fill="{DynamicResource TextMuted}"/>
                                        <Ellipse Width="4" Height="4" Canvas.Left="6" Canvas.Top="3"
                                                 Fill="{DynamicResource TextMuted}"/>
                                        <Ellipse Width="4" Height="4" Canvas.Left="11" Canvas.Top="10"
                                                 Fill="{DynamicResource TextMuted}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpEqPopup"
                                   PlacementTarget="{Binding ElementName=NpEqBtn}"
                                   Placement="Custom" VerticalOffset="-4"
                                   StaysOpen="False" AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   Closed="NpEqPopup_Closed"/>
                            <!-- Separator -->
                            <Border Width="1" Height="18" Margin="4,0" Tag="sep"
                                    Background="{DynamicResource BorderColor}" Opacity="0.4"
                                    VerticalAlignment="Center"/>
                            <!-- Color options: opens a flyout above with the toggle, color picker, and pick-count -->
                            <Button x:Name="NpColorMatchBtn" Click="NpColorMatchMenu_Click"
                                    ToolTip="Color options" Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpColorMatchIcon"
                                              Data="M 8,1 A 7,7 0 1,1 8,15 A 7,7 0 1,1 8,1 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              Fill="Transparent"/>
                                        <Path x:Name="NpColorMatchFill" Data="M 8,4 A 4,4 0 1,1 8,12"
                                              Fill="{DynamicResource TextMuted}"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpColorMatchPopup" PlacementTarget="{Binding ElementName=NpColorMatchBtn}"
                                   Placement="Top" VerticalOffset="-4" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="6">
                                    <StackPanel Orientation="Vertical">
                                        <Button x:Name="NpColorMatchToggleBtn" Click="NpColorMatch_Click"
                                                Style="{StaticResource PlayerButton}" Padding="8,6"
                                                HorizontalContentAlignment="Left" Margin="0,0,0,2"
                                                ToolTip="Toggle Color Match">
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                                    <Canvas Width="16" Height="16">
                                                        <Path Data="M 8,1 A 7,7 0 1,1 8,15 A 7,7 0 1,1 8,1 Z"
                                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                                              Fill="Transparent"/>
                                                        <Path Data="M 8,4 A 4,4 0 1,1 8,12"
                                                              Fill="{DynamicResource TextMuted}"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="Color Match" Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="NpColorPickerBtn" Click="NpColorPicker_Click"
                                                MouseRightButtonUp="NpColorPicker_RightClick"
                                                Style="{StaticResource PlayerButton}" Padding="8,6"
                                                HorizontalContentAlignment="Left" Margin="0,0,0,2"
                                                ToolTip="Pick colors from album cover. Right-click to reset.">
                                            <StackPanel Orientation="Horizontal">
                                                <Viewbox Width="14" Height="14" Margin="0,0,8,0">
                                                    <Canvas Width="16" Height="16">
                                                        <Path x:Name="NpColorPickerIcon"
                                                              Data="M 11,2 L 14,5 L 11.5,7.5 L 9,5 Z M 9.5,5.5 L 3.5,11.5 L 3,14 L 5.5,13.5 L 11.5,7.5"
                                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.4"
                                                              StrokeLineJoin="Round" Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="Color Picker" Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- How many colors the eyedropper picks (3–6). First three drive the
                                             palette; extras enrich the background gradient. -->
                                        <Border BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0,1,0,0"
                                                Padding="8,5,8,2" Margin="0,2,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Picker colors" Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI" FontSize="12" VerticalAlignment="Center"/>
                                                <Button x:Name="NpColorCountMinusBtn" Click="NpColorCountMinus_Click"
                                                        Style="{StaticResource PlayerButton}" Content="−" Padding="0"
                                                        MinWidth="22" Width="22" Height="22" Margin="10,0,0,0"
                                                        ToolTip="Fewer colors"/>
                                                <TextBlock x:Name="NpColorCountLabel" Text="3"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" TextAlignment="Center"
                                                           MinWidth="20" Margin="2,0"/>
                                                <Button x:Name="NpColorCountPlusBtn" Click="NpColorCountPlus_Click"
                                                        Style="{StaticResource PlayerButton}" Content="+" Padding="0"
                                                        MinWidth="22" Width="22" Height="22"
                                                        ToolTip="More colors"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Lyrics-off (pure viz+art) toggle -->
                            <Button x:Name="NpLyricsOffBtn" Click="NpLyricsOff_Click"
                                    ToolTip="Hide lyrics (art mode)"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpLyricsOffIcon"
                                              Data="M 2,2 L 14,2 M 2,6 L 14,6 M 2,10 L 10,10 M 2,14 L 8,14"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Separator -->
                            <Border Width="1" Height="18" Margin="4,0" Tag="sep"
                                    Background="{DynamicResource BorderColor}" Opacity="0.4"
                                    VerticalAlignment="Center"/>
                            <!-- Translate lyrics toggle -->
                            <Button x:Name="NpTranslateBtn" Click="NpTranslate_Click"
                                    ToolTip="Translate lyrics"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpTranslateIcon"
                                              Data="M 1,3 L 8,3 M 4.5,1 L 4.5,3 M 2,3 Q 3,8 6,10 M 7,3 Q 6,8 3,10 M 9,7 L 12,15 L 15,7 M 10,12 L 14,12"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Translate language settings -->
                            <Button x:Name="NpTranslateSettingsBtn" Click="NpTranslateSettings_Click"
                                    ToolTip="Translation settings"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="18" Padding="1,4" Visibility="Collapsed">
                                <Viewbox Width="7" Height="7">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpTranslateSettingsIcon" Data="M 3,5 L 8,11 L 13,5"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="2.5"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpTranslatePopup" StaysOpen="False"
                                   Placement="Top" PlacementTarget="{Binding ElementName=NpTranslateSettingsBtn}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="8,6" Margin="0,0,0,2"
                                        MaxHeight="350">
                                    <StackPanel MinWidth="170">
                                        <TextBlock Text="From language:" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"
                                                   FontFamily="Segoe UI"/>
                                        <ComboBox x:Name="NpTranslateFromCombo"
                                                  SelectionChanged="NpTranslateFrom_Changed"
                                                  FontSize="12" Margin="0,0,0,8" MaxDropDownHeight="200"
                                                  Style="{StaticResource ThemedComboBox}"
                                                  ItemContainerStyle="{StaticResource ThemedComboBoxItem}"/>
                                        <TextBlock Text="To language:" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,3"
                                                   FontFamily="Segoe UI"/>
                                        <ComboBox x:Name="NpTranslateToCombo"
                                                  SelectionChanged="NpTranslateTo_Changed"
                                                  FontSize="12" MaxDropDownHeight="200"
                                                  Style="{StaticResource ThemedComboBox}"
                                                  ItemContainerStyle="{StaticResource ThemedComboBoxItem}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Focused lyrics toggle -->
                            <Button x:Name="NpFocusedLyricsBtn" Click="NpFocusedLyrics_Click"
                                    ToolTip="Lyrics mode"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <!-- Music note: stem + flag, with an open note-head ring (stroked
                                             so the active-state recolor via .Stroke keeps working). -->
                                        <Path x:Name="NpFocusedLyricsIcon"
                                              Data="M 6.5,12 L 6.5,3 C 8.7,2.7 10.8,3.8 11.3,5.8 M 4.3,12 A 2.2,1.8 0 1,0 8.7,12 A 2.2,1.8 0 1,0 4.3,12"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Karaoke mode toggle -->
                            <Button x:Name="NpKaraokeBtn" Click="NpKaraoke_Click"
                                    ToolTip="Karaoke word-by-word"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpKaraokeIcon"
                                              Data="M 8,1 C 5.8,1 4,2.8 4,5 L 4,8 C 4,10.2 5.8,12 8,12 C 10.2,12 12,10.2 12,8 L 12,5 C 12,2.8 10.2,1 8,1 Z M 8,14 L 8,16 M 5,16 L 11,16 M 2,8 C 2,11.3 4.7,14 8,14 C 11.3,14 14,11.3 14,8"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.3"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Separator -->
                            <Border Width="1" Height="18" Margin="4,0" Tag="sep"
                                    Background="{DynamicResource BorderColor}" Opacity="0.4"
                                    VerticalAlignment="Center"/>
                            <!-- Lyrics provider cycle -->
                            <Button x:Name="NpProviderBtn" Click="NpLyricSource_Click"
                                    ToolTip="Cycle lyrics provider" Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpProviderCircle" Data="M 8,1 A 7,7 0 1,0 15,8 L 8,8 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              Fill="Transparent"/>
                                        <Path x:Name="NpProviderArc" Data="M 8,1 A 7,7 0 0,1 15,8"
                                              Stroke="{DynamicResource AccentColor}" StrokeThickness="1.5"
                                              Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Lyric save options (load + save merged) -->
                            <Button x:Name="NpSaveLyricsBtn" Click="NpSaveLyrics_Click" ToolTip="Lyric save options"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="NpSaveLyricsMenu" Opened="NpSaveLyricsMenu_Opened">
                                        <MenuItem x:Name="NpSaveLyricsNowItem" Header="Save lyrics as .lrc"
                                                  Click="NpSaveLyricsNow_Click"/>
                                        <MenuItem x:Name="NpAutoSaveLyricsToggleItem" Header="Auto-save each song"
                                                  IsCheckable="True"
                                                  Click="NpAutoSaveLyricsToggle_Click"/>
                                        <MenuItem x:Name="NpSaveAllLyricsItem" Header="Save all lyrics in folder"
                                                  Click="NpSaveAllLyricsNow_Click"/>
                                        <Separator/>
                                        <MenuItem x:Name="NpAvoidCensoredLyricsItem"
                                                  IsCheckable="True"
                                                  Header="Avoid censored lyrics (auto-fallback)"
                                                  ToolTip="When the chosen provider returns censored lyrics (***** or ######), try the next provider instead. Off by default."
                                                  Click="NpAvoidCensoredLyricsToggle_Click"/>
                                        <MenuItem Header="Find alternate lyrics..."
                                                  Click="NpFindAlternateLyrics_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Load .lrc file..."
                                                  Click="NpLoadLrcFile_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <!-- Page outline (same shape as before) -->
                                        <Path x:Name="NpSaveLyricsIcon"
                                              Data="M 3,1 L 10,1 L 13,4 L 13,15 L 3,15 Z M 10,1 L 10,4 L 13,4 M 5,8 L 11,8 M 8,5 L 8,11 M 6,11 L 8,13 L 10,11"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.5"
                                              Fill="Transparent" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Look up current song on a music service -->
                            <Button x:Name="NpSearchBtn" Click="NpSearch_Click" ToolTip="Look up this song"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <TextBlock x:Name="NpSearchIcon"
                                               Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpSearchPopup" PlacementTarget="{Binding ElementName=NpSearchBtn}"
                                   Placement="Top" VerticalOffset="-4" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="6">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="Look up this song on" Foreground="{DynamicResource TextSecondary}"
                                                   FontFamily="Segoe UI" FontSize="11" Margin="6,2,6,6"/>
                                        <!-- Service buttons are added here at runtime from the user's configured slots -->
                                        <StackPanel x:Name="NpSearchServicesList" Orientation="Vertical"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Queue -->
                            <Button x:Name="NpQueueBtn" Click="NpQueue_Click" ToolTip="Queue"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <TextBlock x:Name="NpQueueIcon"
                                               Text="&#xE90B;" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpQueuePopup" StaysOpen="False"
                                   Placement="Top" PlacementTarget="{Binding ElementName=NpQueueBtn}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="14,10" Margin="0,0,0,4"
                                        MinWidth="220" MaxWidth="320">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="0" BlurRadius="20" Opacity="0.4" Color="Black"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Queue" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,0,0,8"/>
                                        <StackPanel x:Name="NpQueuePopupContent"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                            <!-- Settings -->
                            <Button x:Name="NpSettingsBtn" Click="NpSettings_Click" ToolTip="Settings"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,3">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpSettingsGear" Data="M 6.7,1 L 9.3,1 L 9.8,3.1 L 11.6,3.9 L 13.5,2.8 L 15.2,4.5 L 14.1,6.4 L 14.9,8.2 L 17,8.7 L 17,11.3 L 14.9,11.8 L 14.1,13.6 L 15.2,15.5 L 13.5,17.2 L 11.6,16.1 L 9.8,16.9 L 9.3,19 L 6.7,19 L 6.2,16.9 L 4.4,16.1 L 2.5,17.2 L 0.8,15.5 L 1.9,13.6 L 1.1,11.8 L -1,11.3 L -1,8.7 L 1.1,8.2 L 1.9,6.4 L 0.8,4.5 L 2.5,2.8 L 4.4,3.9 L 6.2,3.1 Z"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2"
                                              Fill="Transparent" StrokeLineJoin="Round"/>
                                        <Ellipse x:Name="NpSettingsCenter" Canvas.Left="5" Canvas.Top="7" Width="6" Height="6"
                                                 Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2"
                                                 Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Customize NP Layout -->
                            <Button x:Name="NpLayoutBtn" Click="NpLayoutCustomize_Click"
                                    ToolTip="Customize layout"
                                    Style="{StaticResource PlayerButton}"
                                    MinWidth="26" Padding="4,4">
                                <Viewbox Width="12" Height="12">
                                    <Canvas Width="16" Height="16">
                                        <Path x:Name="NpLayoutIcon"
                                              Data="M 8,1 L 8,15 M 1,8 L 15,8 M 8,1 L 6,3 M 8,1 L 10,3 M 8,15 L 6,13 M 8,15 L 10,13 M 1,8 L 3,6 M 1,8 L 3,10 M 15,8 L 13,6 M 15,8 L 13,10"
                                              Stroke="{DynamicResource TextMuted}" StrokeThickness="1.2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Popup x:Name="NpLayoutPopup" StaysOpen="False"
                                   Placement="Top" PlacementTarget="{Binding ElementName=NpLayoutBtn}"
                                   AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{DynamicResource GlassFloatingBg}"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Padding="10,8" Margin="0,0,0,4">
                                    <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                    <!-- Fixed width keeps the popup compact: wrapping text and the
                                         star-sized button-name column can no longer balloon it wide. -->
                                    <StackPanel Width="250">
                                        <TextBlock Text="Customize Layout" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2"/>
                                        <TextBlock Text="Tap a section to expand it."
                                                   FontSize="10" Foreground="{DynamicResource TextDim}" Margin="0,0,0,6"/>

                                        <!-- ═══ Saved Layout Profiles ═══ -->
                                        <Expander IsExpanded="False" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2">
                                            <Expander.Header>
                                                <TextBlock Text="Layout Profiles" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,4">
                                        <ItemsControl x:Name="NpLayoutProfilesList" Margin="0,0,0,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource ButtonBg}"
                                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                                            CornerRadius="5" Padding="2" Margin="0,0,0,3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Apply this profile -->
                                                            <Button Grid.Column="0" Content="{Binding Name}"
                                                                    Tag="{Binding Name}" Click="NpLayoutProfileApply_Click"
                                                                    Style="{StaticResource PlayerButton}" Padding="8,4"
                                                                    HorizontalContentAlignment="Left" FontSize="12"
                                                                    ToolTip="Apply this layout"/>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <Button Content="&#x2191;" Tag="{Binding Name}" Click="NpLayoutProfileMoveUp_Click"
                                                                        Style="{StaticResource PlayerButton}" Padding="6,4" FontSize="11" ToolTip="Move up"/>
                                                                <Button Content="&#x2193;" Tag="{Binding Name}" Click="NpLayoutProfileMoveDown_Click"
                                                                        Style="{StaticResource PlayerButton}" Padding="6,4" FontSize="11" ToolTip="Move down"/>
                                                                <Button Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                                        Tag="{Binding Name}" Click="NpLayoutProfileDelete_Click"
                                                                        Style="{StaticResource PlayerButton}" Padding="6,4" FontSize="11" ToolTip="Delete"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock x:Name="NpLayoutProfilesEmpty" Text="No saved profiles yet."
                                                   FontSize="11" FontStyle="Italic" Foreground="{DynamicResource TextMuted}"
                                                   Margin="2,0,0,6" Visibility="Collapsed"/>
                                        <Button Content="Save current layout as…" FontSize="11" HorizontalAlignment="Left"
                                                Click="NpLayoutProfileSave_Click"
                                                Style="{StaticResource PlayerButton}" Padding="8,4" Margin="0,0,0,4"/>
                                            </StackPanel>
                                        </Expander>

                                        <!-- ═══ Bottom-bar buttons: show/hide + reorder ═══ -->
                                        <Expander IsExpanded="False" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2">
                                            <Expander.Header>
                                                <TextBlock Text="Bottom Bar Buttons" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,4">
                                        <TextBlock Text="Reorder any button with ← →. Transport buttons (shuffle, loop, prev, play, next) can be reordered but not hidden; the rest can also be shown or hidden."
                                                   FontSize="10" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                        <ItemsControl x:Name="NpButtonCustomizeList" Margin="0,0,0,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource ButtonBg}"
                                                            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="1"
                                                            CornerRadius="5" Padding="2" Margin="0,0,0,3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0" IsChecked="{Binding Visible, Mode=OneWay}"
                                                                      Style="{StaticResource ThemedCheckBox}"
                                                                      Tag="{Binding Id}" Click="NpButtonVisible_Click"
                                                                      Visibility="{Binding CheckBoxVisibility}"
                                                                      VerticalAlignment="Center" Margin="6,0,8,0"
                                                                      ToolTip="Show this button"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource TextPrimary}" FontFamily="Segoe UI"
                                                                       FontSize="12" VerticalAlignment="Center"/>
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                <Button Content="&#x2190;" Tag="{Binding Id}" Click="NpButtonMoveLeft_Click"
                                                                        Style="{StaticResource PlayerButton}" Padding="6,3" FontSize="11" ToolTip="Move left"/>
                                                                <Button Content="&#x2192;" Tag="{Binding Id}" Click="NpButtonMoveRight_Click"
                                                                        Style="{StaticResource PlayerButton}" Padding="6,3" FontSize="11" ToolTip="Move right"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="Reset buttons" FontSize="11" HorizontalAlignment="Left"
                                                Click="NpButtonReset_Click"
                                                Style="{StaticResource PlayerButton}" Padding="8,3" Margin="0,0,0,4"/>
                                            </StackPanel>
                                        </Expander>

                                        <!-- ═══ Glow Options ═══ -->
                                        <Expander IsExpanded="False" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2">
                                            <Expander.Header>
                                                <TextBlock Text="Glow Options" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,4">
                                        <CheckBox x:Name="NpGlowMotionCheck"
                                                  Content="Glow motion"
                                                  FontSize="11"
                                                  Style="{StaticResource ThemedCheckBox}"
                                                  Tag="GlowMotion"
                                                  MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                  Margin="0,0,0,4"
                                                  Checked="NpGlowMotion_Changed"
                                                  Unchecked="NpGlowMotion_Changed"
                                                  ToolTip="Move album glow colors while Now Playing is visible"/>
                                        <TextBlock Text="Motion Mode" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <ComboBox x:Name="NpGlowMotionModeCombo"
                                                  Style="{StaticResource ThemedComboBox}"
                                                  ItemContainerStyle="{StaticResource ThemedComboBoxItem}"
                                                  Tag="MotionMode"
                                                  MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                  SelectionChanged="NpGlowMotionModeCombo_Changed"
                                                  Margin="0,0,0,4">
                                            <ComboBoxItem Content="Swirl"/>
                                            <ComboBoxItem Content="Linear (Left to Right)"/>
                                            <ComboBoxItem Content="Linear (Right to Left)"/>
                                            <ComboBoxItem Content="Random"/>
                                            <ComboBoxItem Content="Diagonal Sweep"/>
                                            <ComboBoxItem Content="Orbit"/>
                                            <ComboBoxItem Content="Color Drift"/>
                                        </ComboBox>
                                        <TextBlock Text="Album Cover Glow" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutCoverGlowSlider" Minimum="0" Maximum="2.0" Value="1.0"
                                                SmallChange="0.1" LargeChange="0.25"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="CoverGlow"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"
                                                ToolTip="0 = no glow, 1 = default, &gt;1 = larger glow"/>
                                        <TextBlock Text="Focused Lyrics Blur" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpFocusedLyricsBlurSlider" Minimum="0" Maximum="16" Value="6.5"
                                                SmallChange="0.5" LargeChange="2" TickFrequency="0.5"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="FocusedBlur"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"
                                                ToolTip="Blur intensity for inactive focused lyrics"/>
                                            </StackPanel>
                                        </Expander>

                                        <!-- ═══ Backdrop ═══ -->
                                        <Expander IsExpanded="False" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2">
                                            <Expander.Header>
                                                <TextBlock Text="Backdrop" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,4">
                                        <TextBlock Text="Horizontal Position" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpBackdropFocusXSlider" Minimum="0" Maximum="1" Value="0.5"
                                                SmallChange="0.05" LargeChange="0.1" TickFrequency="0.05"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="BackdropHorizontal"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Vertical Position" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <ComboBox x:Name="NpBackdropVerticalPresetCombo"
                                                  Style="{StaticResource ThemedComboBox}"
                                                  ItemContainerStyle="{StaticResource ThemedComboBoxItem}"
                                                  Tag="BackdropVerticalPreset"
                                                  MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                  SelectionChanged="NpBackdropVerticalPresetCombo_Changed"
                                                  Margin="0,0,0,4">
                                            <ComboBoxItem Content="Top"/>
                                            <ComboBoxItem Content="Center"/>
                                            <ComboBoxItem Content="Bottom"/>
                                        </ComboBox>
                                        <Slider x:Name="NpBackdropFocusYSlider" Minimum="0" Maximum="1" Value="0.5"
                                                SmallChange="0.05" LargeChange="0.1" TickFrequency="0.05"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="BackdropVertical"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Zoom" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpBackdropZoomSlider" Minimum="1" Maximum="2.5" Value="1"
                                                SmallChange="0.05" LargeChange="0.25" TickFrequency="0.05"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="BackdropZoom"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Blur" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpBackdropBlurSlider" Minimum="0" Maximum="48" Value="24"
                                                SmallChange="1" LargeChange="4" TickFrequency="1"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="BackdropBlur"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Brightness" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpBackdropBrightnessSlider" Minimum="0.35" Maximum="1.6" Value="1"
                                                SmallChange="0.05" LargeChange="0.1" TickFrequency="0.05"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="BackdropBrightness"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Cover Shape" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <ComboBox x:Name="NpCoverShapeCombo"
                                                  Style="{StaticResource ThemedComboBox}"
                                                  ItemContainerStyle="{StaticResource ThemedComboBoxItem}"
                                                  Tag="CoverShape"
                                                  MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                  SelectionChanged="NpCoverShapeCombo_Changed"
                                                  Margin="0,0,0,4">
                                            <ComboBoxItem Content="Default"/>
                                            <ComboBoxItem Content="Rounded"/>
                                            <ComboBoxItem Content="Circle"/>
                                        </ComboBox>
                                            </StackPanel>
                                        </Expander>

                                        <!-- ═══ Sizes ═══ -->
                                        <Expander IsExpanded="False" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2">
                                            <Expander.Header>
                                                <TextBlock Text="Sizes" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,4">
                                        <!-- Album Cover Size -->
                                        <TextBlock Text="Album Cover" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutCoverSlider" Minimum="200" Maximum="800" Value="400"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="CoverSize"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Title Size -->
                                        <TextBlock Text="Song Title" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutTitleSlider" Minimum="16" Maximum="56" Value="28"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="TitleSize"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Artist / Queue Size -->
                                        <TextBlock Text="Artist / Queue" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutSubSlider" Minimum="9" Maximum="24" Value="11"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="SubTextSize"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Lyrics Size -->
                                        <TextBlock Text="Lyrics" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutLyricsSlider" Minimum="12" Maximum="60" Value="18"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="LyricsSize"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Lyrics Position -->
                                        <TextBlock Text="Lyrics Position" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutLyricsPosSlider" Minimum="0" Maximum="300" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="LyricsOffsetX"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Visualizer Size -->
                                        <TextBlock Text="Visualizer" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutVizSlider" Minimum="40" Maximum="300" Value="100"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="VizSize"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                            </StackPanel>
                                        </Expander>

                                        <!-- ═══ Position Offsets ═══ -->
                                        <Expander IsExpanded="False" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2">
                                            <Expander.Header>
                                                <TextBlock Text="Position Offsets" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                            </Expander.Header>
                                            <StackPanel Margin="0,6,0,4">
                                        <!-- Cover Position -->
                                        <TextBlock Text="Cover ↔" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutCoverXSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="CoverOffsetX"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Cover ↕" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutCoverYSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="CoverOffsetY"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Title Position -->
                                        <TextBlock Text="Title ↔" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutTitleXSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="TitleOffsetX"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Title ↕" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutTitleYSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="TitleOffsetY"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Artist Position -->
                                        <TextBlock Text="Artist ↔" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutArtistXSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="ArtistOffsetX"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <TextBlock Text="Artist ↕" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutArtistYSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="ArtistOffsetY"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                        <!-- Visualizer Position -->
                                        <TextBlock Text="Visualizer ↕" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,2"/>
                                        <Slider x:Name="NpLayoutVizYSlider" Minimum="-200" Maximum="200" Value="0"
                                                Style="{StaticResource VolumeSlider}" Margin="0,0,0,4"
                                                Tag="VizOffsetY"
                                                MouseRightButtonUp="NpLayoutControlReset_MouseRightButtonUp"
                                                ValueChanged="NpLayoutSlider_Changed"/>
                                            </StackPanel>
                                        </Expander>

                                        <Border Height="1" Background="{DynamicResource BorderColor}" Opacity="0.35" Margin="0,6,0,6"/>
                                        <!-- Reset (asks for confirmation) -->
                                        <Button Content="Reset to Default" FontSize="11" HorizontalAlignment="Right"
                                                Click="NpLayoutResetConfirm_Click"
                                                Style="{StaticResource PlayerButton}" Padding="8,3"/>
                                    </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                            <!-- Separator -->
                            <Border Width="1" Height="18" Margin="4,0"
                                    Background="{DynamicResource BorderColor}" Opacity="0.4"
                                    VerticalAlignment="Center"/>
                            <Viewbox Width="13" Height="13" VerticalAlignment="Center"
                                     Cursor="Hand" MouseLeftButtonDown="NpVolumeIcon_Click">
                                <Canvas Width="16" Height="16">
                                    <Path x:Name="NpVolumeIconPath"
                                          Data="M 2,5 L 5,5 L 9,2 L 9,14 L 5,11 L 2,11 Z M 11,5 Q 13,8 11,11"
                                          Fill="{DynamicResource TextMuted}"
                                          Stroke="{DynamicResource TextMuted}" StrokeThickness="0.5"/>
                                </Canvas>
                            </Viewbox>
                            <Slider x:Name="NpVolumeSlider" Width="80"
                                    Minimum="0" Maximum="100"
                                    VerticalAlignment="Center" Margin="4,0,6,0"
                                    Style="{StaticResource VolumeSlider}"
                                    ValueChanged="NpVolumeSlider_ValueChanged"/>
                            <!-- Back -->
                            <Button Click="NpBack_Click" ToolTip="Back to main view"
                                    Style="{StaticResource PlayerButton}" MinWidth="28"
                                    Padding="6,4">
                                <Viewbox Width="13" Height="13">
                                    <Canvas Width="16" Height="16">
                                        <Path Data="M 12,2 L 4,8 L 12,14"
                                              Stroke="{DynamicResource TextPrimary}" StrokeThickness="2"
                                              Fill="Transparent" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ Full-width Visualizer Bar (above playbar) ═══ -->
            <Border x:Name="NpVizBar" DockPanel.Dock="Bottom"
                    Background="Transparent" ClipToBounds="True"
                    Height="0">
                <Grid>
                    <!-- Resize grip at top edge -->
                    <Border x:Name="NpVizResizeGrip" Height="5" VerticalAlignment="Top"
                            Background="Transparent" Cursor="SizeNS"
                            MouseLeftButtonDown="NpVizResize_MouseDown"
                            MouseMove="NpVizResize_MouseMove"
                            MouseLeftButtonUp="NpVizResize_MouseUp"
                            Panel.ZIndex="1"/>
                    <Canvas x:Name="NpVisualizerCanvas" ClipToBounds="True"
                            Background="Transparent"/>
                </Grid>
            </Border>

            <!-- ═══ Cover + Lyrics Area ═══ -->
            <Grid x:Name="NpContentArea" Margin="32,16,32,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Big title + Album Cover + optional under-cover visualizer -->
                <Grid Grid.Column="0" Margin="0,0,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="NpUnderCoverVizRow" Height="0"/>
                    </Grid.RowDefinitions>

                    <!-- Big bold song name above cover -->
                    <Border x:Name="NpBigTitleBorder" Grid.Row="0" Margin="8,12,8,4" MaxHeight="48"
                            HorizontalAlignment="Stretch">
                        <Viewbox MaxHeight="42" StretchDirection="DownOnly" Stretch="Uniform"
                                 HorizontalAlignment="Center">
                            <TextBlock x:Name="NpBigTitle"
                                       Text="" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                       FontFamily="Segoe UI"
                                       MaxWidth="450"/>
                        </Viewbox>
                    </Border>

                    <!-- Album cover with glow -->
                    <Grid x:Name="NpCoverAssembly" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Outer color glow -->
                    <Border x:Name="NpCoverGlow1" CornerRadius="20" Opacity="0.5" Margin="-24">
                        <Border.Effect>
                            <BlurEffect Radius="30"/>
                        </Border.Effect>
                    </Border>
                    <!-- Inner color glow -->
                    <Border x:Name="NpCoverGlow2" CornerRadius="14" Opacity="0.35" Margin="-14">
                        <Border.Effect>
                            <BlurEffect Radius="18"/>
                        </Border.Effect>
                    </Border>
                    <!-- Album cover (double-click to edit tags) -->
                    <Border x:Name="NpCoverBorder" CornerRadius="8"
                            Background="{DynamicResource GridBg}"
                            MouseLeftButtonDown="NpCoverBorder_MouseDoubleClick"
                            SizeChanged="NpCoverBorder_SizeChanged">
                        <Border.Effect>
                            <DropShadowEffect x:Name="NpCoverShadow" BlurRadius="40"
                                              ShadowDepth="6" Opacity="0.5" Color="Black"/>
                        </Border.Effect>
                        <Border.Clip>
                            <RectangleGeometry x:Name="NpCoverClip" RadiusX="8" RadiusY="8"/>
                        </Border.Clip>
                        <Image x:Name="NpCoverImage" Stretch="Uniform"
                               MouseLeftButtonDown="NpCoverImage_MouseLeftButtonDown"/>
                    </Border>
                    </Grid>

                    <!-- Next track / Artist preview (under cover) — click to toggle -->
                    <Border x:Name="NpNextTrackBorder" Grid.Row="2"
                            HorizontalAlignment="Center" Margin="0,4,0,2"
                            Background="{DynamicResource ButtonBg}" CornerRadius="5" Padding="10,4"
                            Visibility="Collapsed" Cursor="Hand"
                            MouseLeftButtonUp="NpNextTrackBorder_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="NpNextTrackLabel" Text="Artist:  " FontSize="11"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"
                                       FontWeight="Medium"/>
                            <TextBlock x:Name="NpNextTrackText" FontSize="11"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" MaxWidth="280"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Under-cover visualizer (alternative placement) -->
                    <Border x:Name="NpUnderCoverVizBorder" Grid.Row="3"
                            ClipToBounds="True" Background="Transparent"
                            Margin="0,8,0,0" CornerRadius="6">
                        <Canvas x:Name="NpUnderCoverVizCanvas" ClipToBounds="True"
                                Background="Transparent"/>
                    </Border>
                </Grid>

                <!-- Right: Lyrics only -->
                <Grid Grid.Column="1" Margin="24,0,0,0" x:Name="NpLyricsDropTarget"
                      AllowDrop="True" Drop="NpLyrics_Drop" DragOver="NpLyrics_DragOver"
                      DragLeave="NpLyrics_DragLeave">

                    <!-- Lyrics area -->
                    <ScrollViewer x:Name="NpLyricsScroller"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="NpLyricsScroller_PreviewMouseWheel"
                                  ScrollChanged="NpLyricsScroller_ScrollChanged">
                        <StackPanel x:Name="NpLyricsPanel" Margin="0,4,8,80">
                            <TextBlock x:Name="NpNoLyrics"
                                       Text="No lyrics loaded&#x0a;Play a track to search for lyrics"
                                       Foreground="{DynamicResource TextDim}" FontSize="14"
                                       FontStyle="Italic" Margin="0,20,0,0"
                                       TextWrapping="Wrap" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Drop overlay hint -->
                    <Border x:Name="NpDropOverlay"
                            Visibility="Collapsed"
                            Background="#CC1a1a2e" CornerRadius="8" Margin="4">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Viewbox Width="36" Height="36" Margin="0,0,0,8">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M 3,1 L 10,1 L 13,4 L 13,15 L 3,15 Z"
                                          Stroke="{DynamicResource AccentColor}" StrokeThickness="1.5"
                                          Fill="Transparent" StrokeLineJoin="Round"/>
                                    <Path Data="M 10,1 L 10,4 L 13,4"
                                          Stroke="{DynamicResource AccentColor}" StrokeThickness="1.5"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Drop .lrc file here"
                                       Foreground="{DynamicResource AccentColor}" FontSize="15"
                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>

    <!-- ═══ Donation Overlay ═══ -->
    <Grid x:Name="DonationOverlay" Visibility="Collapsed">
        <!-- Semi-transparent backdrop -->
        <Border Background="#AA000000" MouseLeftButtonDown="DonationBackdrop_Click"/>

        <!-- Popup card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="32,28" MaxWidth="440" MinWidth="360">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <!-- Heart icon -->
                <TextBlock Text="❤" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"
                           Foreground="#E25555"/>

                <!-- Title -->
                <TextBlock Text="Support AudioAuditor" FontSize="18" FontWeight="Bold"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                <!-- Message -->
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                           LineHeight="20" Margin="0,0,0,20">
                    This project is built and maintained by one person. AudioAuditor has no ads, no tracking, is open source, and will be free forever. If you find it helpful, a small donation would mean a lot and help fund further development. Thank you for using AudioAuditor!
                </TextBlock>

                <!-- Donate button -->
                <Button Click="DonationDonate_Click" Cursor="Hand" HorizontalAlignment="Center"
