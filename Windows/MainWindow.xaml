    <!-- ═══ Feature Configuration Overlay (first-run / version update) ═══ -->
    <Grid x:Name="FeatureConfigOverlay" Visibility="Collapsed">
        <Border Background="#AA000000" MouseLeftButtonDown="FeatureConfigBackdrop_Click"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="32,28,32,20" MaxWidth="560" MinWidth="420"
                MaxHeight="700">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Image Grid.Row="0" Source="/Resources/icon.png" Width="32" Height="32" HorizontalAlignment="Center" Margin="0,0,0,12" RenderOptions.BitmapScalingMode="HighQuality"/>

                <TextBlock Grid.Row="1" Text="Welcome to AudioAuditor" FontSize="18" FontWeight="Bold"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" x:Name="FeatureConfigSubtitle" TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                           LineHeight="20" Margin="0,0,0,16">
                    Configure which analysis features are enabled. You can change these anytime in Settings.
                </TextBlock>

                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                    <ScrollViewer.Resources>
                        <!-- Theme-aware CheckBox style -->
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal" Background="Transparent">
                                            <Border x:Name="CheckBorder" Width="18" Height="18"
                                                    CornerRadius="3" BorderThickness="1.5"
                                                    BorderBrush="{DynamicResource AccentColor}"
                                                    Background="Transparent"
                                                    VerticalAlignment="Top" Margin="0,2,0,0">
                                                <TextBlock x:Name="CheckMark" Text="✓" FontSize="12" FontWeight="Bold"
                                                           Foreground="White" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Margin="0,-1,0,0"
                                                           Visibility="Collapsed"/>
                                            </Border>
                                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Top"/>
                                        </StackPanel>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CheckBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="CheckBorder" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <!-- Silence Detection -->
                        <CheckBox x:Name="FcChkSilence" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Silence Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Detects leading, trailing, and mid-track silence gaps."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Fake Stereo Detection -->
                        <CheckBox x:Name="FcChkFakeStereo" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Fake Stereo Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Detects mono-duplicated or artificially widened stereo files."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Dynamic Range -->
                        <CheckBox x:Name="FcChkDR" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Dynamic Range (DR Score)" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Measures dynamic range to detect over-compressed or loudness-war masters."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- True Peak -->
                        <CheckBox x:Name="FcChkTruePeak" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="True Peak (dBTP)" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Measures inter-sample peaks that can cause distortion on playback."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Integrated LUFS -->
                        <CheckBox x:Name="FcChkLufs" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Integrated LUFS Loudness" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="EBU R128 loudness measurement — the industry standard for loudness normalization."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Rip Quality -->
                        <CheckBox x:Name="FcChkRipQuality" IsChecked="False" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Rip/Encode Quality Check (Experimental)" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Detects bad rips: zero gaps, clicks/pops, glitches, bit truncation."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- Clipping Detection -->
                        <CheckBox x:Name="FcChkClipping" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Clipping Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Detects samples at or near maximum level (clipping and scaled clipping)."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- MQA Detection -->
                        <CheckBox x:Name="FcChkMqa" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="MQA Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Identifies MQA-encoded audio and original sample rates."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- BPM Detection -->
                        <CheckBox x:Name="FcChkBpm" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="BPM Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Detects tempo (BPM) for files without existing BPM tags. Can be slow for large libraries."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,10"/>

                        <!-- AI Detection: Default -->
                        <CheckBox x:Name="FcChkDefaultAi" IsChecked="True" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Default AI Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Scans watermarks and metadata markers for AI-generated audio."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- AI Detection: Experimental Spectral -->
                        <CheckBox x:Name="FcChkExperimentalAi" IsChecked="False" Margin="0,5" Cursor="Hand">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <TextBlock Text="Experimental Spectral AI Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Analyzes spectral patterns for AI artifacts. May produce false positives."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>

                        <!-- AI Detection: SH Labs -->
                        <CheckBox x:Name="FcChkSHLabs" IsChecked="False" Margin="0,5" Cursor="Hand"
                                  Checked="FcChkSHLabs_Checked">
                            <StackPanel Orientation="Vertical" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠️ " FontSize="12.5" VerticalAlignment="Center"/>
                                    <TextBlock Text="SH Labs AI Detection (API)" FontSize="12.5" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                                <TextBlock Text="Cloud-based AI detection — requires network. Limited to 15 scans/day, 100/month."
                                           FontSize="11" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,1,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Save button -->
                <Button Grid.Row="4" Click="FeatureConfigSave_Click" Cursor="Hand" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="fcSaveBd" Background="{DynamicResource AccentColor}"
                                    CornerRadius="6" Padding="28,10">
                                <TextBlock Text="Save &amp; Continue" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="fcSaveBd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Row="5" Text="You can change these anytime in Settings. Disabled features will hide their columns and skip during analysis."
                           FontSize="10.5" FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" Opacity="0.7" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>

    <!-- ═══ SH Labs Privacy Notice Overlay ═══ -->
    <Grid x:Name="SHLabsPrivacyOverlay" Visibility="Collapsed">
        <Border Background="#AA000000" MouseLeftButtonDown="SHLabsPrivacyBackdrop_Click"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="32,24" MaxWidth="560" MinWidth="420">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="⚠️" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="SH Labs — Privacy Notice" FontSize="17" FontWeight="Bold"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                <TextBlock TextWrapping="Wrap" FontSize="12.5" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="0,0,0,10">
                    When SH Labs AI Detection is enabled, the following occurs:
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="8,0,0,6">
                    <Bold>What is sent:</Bold> The audio file you scan is uploaded to the AudioAuditor proxy server so it can be forwarded to the SH Labs API for analysis. Only the audio file content is transmitted — no personal information, filenames, folder paths, or system details are included.
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="8,0,0,6">
                    <Bold>Where it is sent:</Bold> Your audio file is routed through a proxy hosted on Cloudflare and then forwarded to the SH Labs API (shlabs.music). The proxy exists solely to protect the shared API key — it does not store your files or results.
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="8,0,0,6">
                    <Bold>What is used for:</Bold> The audio is analyzed by SH Labs to determine whether it was generated by AI. The result (prediction, confidence score, and AI type) is returned to AudioAuditor and cached locally on your computer. No results are shared externally or stored on any server.
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="8,0,0,6">
                    <Bold>What is stored locally:</Bold> An anonymous installation ID (derived from your machine name), scan results cached by file hash, and daily/monthly usage counters — all in your Documents/AudioAuditor folder.
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="8,0,0,6">
                    <Bold>Third-party disclaimer:</Bold> While AudioAuditor does not send any information beyond what is described above, we have no control over or oversight of the SH Labs API or its internal practices. We cannot fully guarantee that audio files, once received by SH Labs, are not retained, used for training, shared, or otherwise processed on their end — although SH Labs does not explicitly state that they do so. By enabling this feature, you acknowledge this limitation.
                </TextBlock>

                <TextBlock TextWrapping="Wrap" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" LineHeight="19" Margin="8,0,0,10">
                    <Bold>Alternative:</Bold> You can use your own SH Labs API key in Settings → AI Detection to bypass the proxy entirely. With a personal key, audio is sent directly to SH Labs with no intermediary and no rate limits.
                </TextBlock>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                    <Button Click="SHLabsPrivacyAccept_Click" Cursor="Hand" Margin="0,0,12,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="privAccBd" Background="{DynamicResource AccentColor}"
                                        CornerRadius="6" Padding="24,9">
                                    <TextBlock Text="I Understand — Enable SH Labs" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="privAccBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="SHLabsPrivacyDecline_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="privDecBd" Background="{DynamicResource ButtonBg}"
                                        BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                        CornerRadius="6" Padding="24,9">
                                    <TextBlock Text="Cancel" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="privDecBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ═══ SH Labs Scan Limit Overlay (themed replacement for MessageBox) ═══ -->
    <Grid x:Name="SHLabsLimitOverlay" Visibility="Collapsed">
        <Border Background="#AA000000" MouseLeftButtonDown="SHLabsLimitBackdrop_Click"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="32,24" MaxWidth="480" MinWidth="360">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="SH Labs Scan Limit" FontSize="17" FontWeight="Bold"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>

                <TextBlock x:Name="SHLabsLimitMessage" TextWrapping="Wrap" FontSize="13"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                           LineHeight="20" TextAlignment="Center" Margin="0,0,0,20"/>

                <StackPanel x:Name="SHLabsLimitButtons" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="SHLabsLimitOkBtn" Click="SHLabsLimitOk_Click" Cursor="Hand" Margin="0,0,12,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="limOkBd" Background="{DynamicResource AccentColor}"
                                        CornerRadius="6" Padding="24,9">
                                    <TextBlock Text="Continue" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="limOkBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="SHLabsLimitCancelBtn" Click="SHLabsLimitCancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="limCancelBd" Background="{DynamicResource ButtonBg}"
                                        BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1"
                                        CornerRadius="6" Padding="24,9">
                                    <TextBlock Text="Cancel" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="limCancelBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ═══ Update Available Overlay ═══ -->
    <Grid x:Name="UpdateOverlay" Visibility="Collapsed">
        <Border Background="#AA000000" MouseLeftButtonDown="UpdateBackdrop_Click"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="32,28" MaxWidth="420" MinWidth="340">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="30" Opacity="0.5" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="🔔" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                <TextBlock Text="Update Available" FontSize="18" FontWeight="Bold"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock x:Name="UpdateLatestText"
                               FontSize="13" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="UpdateCurrentText"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <!-- Progress bar (hidden until download starts) -->
                <Border x:Name="UpdateProgressPanel" Visibility="Collapsed"
                        Background="{DynamicResource InputBg}" CornerRadius="4"
                        Height="8" Margin="0,0,0,16">
                    <Grid>
                        <Border x:Name="UpdateProgressBar" Background="{DynamicResource AccentColor}"
                                CornerRadius="4" HorizontalAlignment="Left" Width="0"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="UpdateProgressText" Visibility="Collapsed"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,-12,0,16"/>

                <Button x:Name="BtnUpdateDownloadInstall" Click="UpdateDownloadInstall_Click" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="updateDlBd" Background="{DynamicResource AccentColor}"
                                    CornerRadius="6" Padding="24,10">
                                <TextBlock Text="Download &amp; Install" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="updateDlBd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="BtnUpdateOpenBrowser" Click="UpdateDownload_Click" Cursor="Hand"
                        HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="updateBrowserText" Text="Open in browser"
                                       FontSize="12.5" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Opacity="0.75"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="updateBrowserText" Property="Opacity" Value="1.0"/>
                                    <Setter TargetName="updateBrowserText" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Click="UpdateDismiss_Click" Cursor="Hand" HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="updateDismissText" Text="Later"
                                       FontSize="12.5" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Opacity="0.75"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="updateDismissText" Property="Opacity" Value="1.0"/>
                                    <Setter TargetName="updateDismissText" Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ═══ Restore Last Session prompt ═══ -->
    <Grid x:Name="RestoreSessionOverlay" Visibility="Collapsed">
        <Border Background="#88000000" MouseLeftButtonDown="RestoreSessionBackdrop_Click"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="28,24" MaxWidth="420" MinWidth="340">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.4" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Restore your last session?" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI" HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"/>
                <TextBlock x:Name="RestoreSessionDetail" TextWrapping="Wrap" TextAlignment="Center"
                           FontSize="13" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}"
                           LineHeight="20" Margin="0,0,0,18"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Click="RestoreSessionRestore_Click" Cursor="Hand" Margin="0,0,8,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="restoreBd" Background="{DynamicResource AccentColor}"
                                        CornerRadius="6" Padding="22,9">
                                    <TextBlock Text="Restore" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="restoreBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="RestoreSessionDismiss_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="laterBd" Background="Transparent"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="18,9">
                                    <TextBlock Text="Not now" FontSize="13" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextSecondary}"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="laterBd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ═══ Reusable themed dialog (confirm + optional text input) ═══ -->
    <!-- Driven by ShowThemedDialog(...) in MainWindow.ThemedDialog.cs. Used for the layout-reset
         confirmation and the "name this profile" prompt; reuses the glass theme tokens so it
         matches whatever theme/ColorMatch is active. -->
    <Grid x:Name="ThemedDialogOverlay" Visibility="Collapsed" Panel.ZIndex="50">
        <Border Background="#88000000" MouseLeftButtonDown="ThemedDialogBackdrop_Click"/>
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource GlassFloatingBg}"
                BorderBrush="{DynamicResource GlassBorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Padding="26,22" MaxWidth="420" MinWidth="340">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.4" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock x:Name="ThemedDialogTitle" Text="" FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                <TextBlock x:Name="ThemedDialogMessage" Text="" TextWrapping="Wrap"
                           FontSize="13" FontFamily="Segoe UI" Foreground="{DynamicResource TextSecondary}"
                           LineHeight="19" Margin="0,0,0,14"/>
                <TextBox x:Name="ThemedDialogInput" Visibility="Collapsed"
                         FontSize="13" FontFamily="Segoe UI" Padding="6,5" Margin="0,0,0,14"
                         Background="{DynamicResource InputBg}" Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource ButtonBorder}"
                         KeyDown="ThemedDialogInput_KeyDown"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ThemedDialogConfirmBtn" Click="ThemedDialogConfirm_Click" Cursor="Hand"
                            Margin="0,0,8,0" Content="OK">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="okBd" Background="{DynamicResource AccentColor}"
                                        CornerRadius="6" Padding="20,8">
                                    <TextBlock Text="{TemplateBinding Content}" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="Segoe UI" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="okBd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="ThemedDialogCancelBtn" Click="ThemedDialogCancel_Click" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="cancelBd" Background="Transparent"
                                        BorderBrush="{DynamicResource GlassBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="16,8">
                                    <TextBlock Text="Cancel" FontSize="13" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="cancelBd" Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <!-- ═══ Subtle themed toast (auto-dismiss) ═══ -->
    <!-- Used by ShowThemedNotice(): tiny corner notice for things like "scan cache turned on too"
         or "AudioAuditor recovered from a problem". Not modal, no backdrop, fades on its own. -->
    <Border x:Name="ThemedNoticeToast" Visibility="Collapsed"
            HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,18,72" MaxWidth="360" Padding="16,12"
            Background="{DynamicResource GlassFloatingBg}"
            BorderBrush="{DynamicResource GlassBorderBrush}"
            BorderThickness="1" CornerRadius="8"
            IsHitTestVisible="True">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="18" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock x:Name="ThemedNoticeTitle" FontSize="13" FontWeight="SemiBold"
                           FontFamily="Segoe UI" Foreground="{DynamicResource TextPrimary}"
                           Margin="0,0,0,4" TextWrapping="Wrap"/>
                <TextBlock x:Name="ThemedNoticeBody" FontSize="12" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
            </StackPanel>
            <!-- Close (X) — Segoe MDL2 'ChromeClose' glyph -->
            <Button Grid.Column="1" VerticalAlignment="Top" Cursor="Hand"
                    Click="ThemedNoticeClose_Click" ToolTip="Dismiss"
                    Background="Transparent" BorderThickness="0" Padding="4">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="closeBd" Background="Transparent" CornerRadius="4" Padding="4">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="closeBd" Property="Background"
                                        Value="{DynamicResource GlassBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>

    <!-- ═══════════════ Wrapped (in-app stats dashboard overlay) ═══════════════ -->
    <Grid x:Name="WrappedOverlay" Visibility="Collapsed" Panel.ZIndex="55"
          Background="{DynamicResource WindowBg}" Focusable="True"
          KeyDown="WrappedOverlay_KeyDown">
        <Grid.Resources>
            <Style x:Key="WrappedSecondaryButton" TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                    CornerRadius="8" Padding="16,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="WrappedPrimaryButton" TargetType="Button">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{DynamicResource AccentColor}"
                                    CornerRadius="8" Padding="22,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="WrappedCard" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="18,16"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
            </Style>
            <Style x:Key="WrappedCardTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
            </Style>

            <!-- Segmented range selector button (Day / Week / Month / Year / All / Custom) -->
            <Style x:Key="WrappedRangeButton" TargetType="ToggleButton">
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="7"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ Themed Calendar (dark) for the custom date range ═══ -->
            <Style x:Key="WrappedCalendarDayButton" TargetType="CalendarDayButton">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="MinWidth" Value="30"/>
                <Setter Property="MinHeight" Value="30"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarDayButton">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6" Margin="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsToday" Value="True">
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                    <Setter TargetName="bd" Property="BorderThickness" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsInactive" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WrappedCalendarButton" TargetType="CalendarButton">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="MinWidth" Value="42"/>
                <Setter Property="MinHeight" Value="42"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarButton">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="6" Margin="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                                <Trigger Property="HasSelectedDays" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsInactive" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WrappedCalendarItem" TargetType="CalendarItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CalendarItem">
                            <ControlTemplate.Resources>
                                <Style x:Key="WrappedCalNavButton" TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="nb" Background="Transparent" CornerRadius="5"
                                                        Width="26" Height="26">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="nb" Property="Background" Value="#22FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style x:Key="WrappedCalHeaderButton" TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="hb" Background="Transparent" CornerRadius="5"
                                                        Padding="8,2">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="hb" Property="Background" Value="#22FFFFFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ControlTemplate.Resources>
                            <Border Background="{DynamicResource PanelBg}" CornerRadius="8"
                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" Padding="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="PART_PreviousButton" Grid.Column="0"
                                                Style="{StaticResource WrappedCalNavButton}" Content="‹"/>
                                        <Button x:Name="PART_HeaderButton" Grid.Column="1"
                                                Style="{StaticResource WrappedCalHeaderButton}"/>
                                        <Button x:Name="PART_NextButton" Grid.Column="2"
                                                Style="{StaticResource WrappedCalNavButton}" Content="›"/>
                                    </Grid>
                                    <Grid x:Name="PART_MonthView" Grid.Row="1" Margin="0,6,0,0"
                                          Visibility="Visible"/>
                                    <Grid x:Name="PART_YearView" Grid.Row="1" Margin="0,6,0,0"
                                          Visibility="Hidden"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="WrappedCalendar" TargetType="Calendar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CalendarDayButtonStyle" Value="{StaticResource WrappedCalendarDayButton}"/>
                <Setter Property="CalendarButtonStyle" Value="{StaticResource WrappedCalendarButton}"/>
                <Setter Property="CalendarItemStyle" Value="{StaticResource WrappedCalendarItem}"/>
            </Style>
        </Grid.Resources>

        <Grid x:Name="WrappedDashboardHost" Margin="36,12,36,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Your AudioAuditor " FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock Text="Wrapped" FontSize="28" FontWeight="ExtraBold"
                               Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="WrappedSubtitleText" Text=""
                           FontSize="13" Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>

                <!-- Time-range selector -->
                <Border Background="{DynamicResource PanelBg}" CornerRadius="9" Padding="3"
                        Margin="0,12,0,0" HorizontalAlignment="Center"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="WrappedRangeDay" Content="Day" Tag="Day"
                                      Style="{StaticResource WrappedRangeButton}" Click="WrappedRange_Click"/>
                        <ToggleButton x:Name="WrappedRangeWeek" Content="Week" Tag="Week"
                                      Style="{StaticResource WrappedRangeButton}" Click="WrappedRange_Click"/>
                        <ToggleButton x:Name="WrappedRangeMonth" Content="Month" Tag="Month"
                                      Style="{StaticResource WrappedRangeButton}" Click="WrappedRange_Click"/>
                        <ToggleButton x:Name="WrappedRangeYear" Content="Year" Tag="Year"
                                      Style="{StaticResource WrappedRangeButton}" Click="WrappedRange_Click"/>
                        <ToggleButton x:Name="WrappedRangeAll" Content="All Time" Tag="All"
                                      Style="{StaticResource WrappedRangeButton}" Click="WrappedRange_Click"/>
                        <ToggleButton x:Name="WrappedRangeCustom" Content="Custom" Tag="Custom"
                                      Style="{StaticResource WrappedRangeButton}" Click="WrappedRange_Click"/>
                    </StackPanel>
                </Border>

                <!-- Custom date-range calendar popup -->
                <Popup x:Name="WrappedCustomPopup" PlacementTarget="{Binding ElementName=WrappedRangeCustom}"
                       Placement="Bottom" VerticalOffset="6" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="{DynamicResource GlassFloatingBg}" BorderBrush="{DynamicResource GlassBorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel Width="260">
                            <TextBlock Text="Custom range" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,2"/>
                            <TextBlock Text="Click a start date, then shift-click or drag to the end."
                                       FontSize="11" Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Calendar x:Name="WrappedCustomCalendar" Style="{StaticResource WrappedCalendar}"
                                      SelectionMode="SingleRange"
                                      SelectedDatesChanged="WrappedCustomCalendar_SelectedDatesChanged"/>
                            <TextBlock x:Name="WrappedCustomRangeText" Text="No range selected"
                                       FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                       Margin="0,8,0,0" HorizontalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                <Button Content="Cancel" Click="WrappedCustomCancel_Click"
                                        Style="{StaticResource WrappedSecondaryButton}" Margin="0,0,8,0"/>
                                <Button x:Name="WrappedCustomApplyBtn" Content="Apply"
                                        Click="WrappedCustomApply_Click" Style="{StaticResource WrappedPrimaryButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>

            <!-- Close -->
            <Button x:Name="WrappedCloseButton" Click="WrappedClose_Click" Cursor="Hand"
                    Panel.ZIndex="10" Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,-4,-6,0" Background="Transparent" BorderThickness="0" Padding="0"
                    ToolTip="Close (Esc)">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="xbd" Width="34" Height="34" CornerRadius="17"
                                Background="Transparent" BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1">
                            <Path x:Name="xglyph" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M 0,0 L 11,11 M 11,0 L 0,11" Stroke="{DynamicResource TextMuted}"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="xbd" Property="Background" Value="#22FFFFFF"/>
                                <Setter TargetName="xbd" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="xglyph" Property="Stroke" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Three landscape columns (scrollable when they overflow the window) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
            <Grid VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0 -->
                <StackPanel x:Name="WrappedCol0" Grid.Column="0" Margin="0,0,9,0">
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource WrappedCard}" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock x:Name="WStatFilesText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Files Scanned" FontSize="11"
                                           Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource WrappedCard}" Margin="3,0,3,0">
                            <StackPanel>
                                <TextBlock x:Name="WStatHoursText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hours Listened" FontSize="11"
                                           Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource WrappedCard}" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="WStatSessionsText" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Scan Sessions" FontSize="11"
                                           Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Style="{StaticResource WrappedCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="WStatLibrarySize" Text="-" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Library" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="WStatTotalPlays" Text="-" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Plays" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="WStatUniqueArtists" Text="-" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Artists" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock x:Name="WStatUniqueTracks" Text="-" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Tracks" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Library Quality" Style="{StaticResource WrappedCardTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="WStatAvgBitrate" Text="-" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" TextAlignment="Center"/>
                                    <TextBlock Text="Avg Bitrate" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="WStatAvgLufs" Text="-" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg LUFS" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="WStatAvgDr" Text="-" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg DR" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock x:Name="WStatClipping" Text="-" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Clipping" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#22FFFFFF" CornerRadius="8" Padding="12,9" Margin="0,14,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Audiophile rating: " FontSize="12"
                                               Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="WStatAudiophile" Text="-" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Averages" Style="{StaticResource WrappedCardTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="WStatAvgFileSize" Text="-" FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Avg File Size" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="WStatAvgPlaysPerTrack" Text="-" FontSize="18" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Plays / Track" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Activity over time" Style="{StaticResource WrappedCardTitle}"/>
                            <Grid x:Name="WActivityChartHost" Height="130"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Column 1 -->
                <StackPanel x:Name="WrappedCol1" Grid.Column="1" Margin="9,0,9,0">
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Resolution" Style="{StaticResource WrappedCardTitle}"/>
                            <TextBlock Text="Sample rate" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4"/>
                            <StackPanel x:Name="WSampleRatePanel" Orientation="Vertical"/>
                            <TextBlock Text="Bit depth" FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,12,0,4"/>
                            <StackPanel x:Name="WBitDepthPanel" Orientation="Vertical"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Channel Layout" Style="{StaticResource WrappedCardTitle}"/>
                            <StackPanel x:Name="WChannelPanel" Orientation="Vertical"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Loudness &amp; Dynamics" Style="{StaticResource WrappedCardTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="WStatDrRating" Text="-" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Dynamic range" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="WStatClippingPct" Text="-" FontSize="17" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Files clipping" FontSize="11" Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Formats &amp; Codecs" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="WStatLosslessRatio" Text="" FontSize="12"
                                           Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Right"/>
                            </Grid>
                            <StackPanel x:Name="WFormatsPanel" Orientation="Vertical"/>
                            <Grid Margin="0,8,0,0">
                                <TextBlock x:Name="WStatLosslessLossy" Text="" FontSize="11"
                                           Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="WStatMqaCount" Text="" FontSize="11"
                                           Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Format mix" Style="{StaticResource WrappedCardTitle}"/>
                            <Grid x:Name="WFormatDonutHost" Height="150"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Column 2 -->
                <StackPanel x:Name="WrappedCol2" Grid.Column="2" Margin="9,0,0,0">
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Top Artists" Style="{StaticResource WrappedCardTitle}"/>
                            <StackPanel x:Name="WArtistsPanel" Orientation="Vertical"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Top Albums" Style="{StaticResource WrappedCardTitle}"/>
                            <StackPanel x:Name="WAlbumsPanel" Orientation="Vertical"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Top Tracks" Style="{StaticResource WrappedCardTitle}"/>
                            <StackPanel x:Name="WTracksPanel" Orientation="Vertical"/>
                            <TextBlock x:Name="WStatMostByTime" Text="" FontSize="11"
                                       Foreground="{DynamicResource TextMuted}" Margin="0,8,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource WrappedCard}">
                        <StackPanel>
                            <TextBlock Text="Quality trend" Style="{StaticResource WrappedCardTitle}"/>
                            <Grid x:Name="WQualityTrendHost" Height="130"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Margin="0,4,0,0">
                <TextBlock Text="All data is stored locally on your PC. Nothing is uploaded or shared."
                           FontSize="11" Foreground="{DynamicResource TextMuted}"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Reset Stats" Click="WrappedResetStats_Click"
                            Style="{StaticResource WrappedSecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Close" Click="WrappedClose_Click"
                            Style="{StaticResource WrappedPrimaryButton}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Themed reset-stats confirmation -->
        <Grid x:Name="WrappedResetConfirmOverlay" Visibility="Collapsed" Panel.ZIndex="50"
              Background="#99000000" MouseLeftButtonDown="WrappedResetConfirmDim_MouseDown">
            <Border Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1" CornerRadius="12" Padding="24,20" MaxWidth="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="0" BlurRadius="24" Opacity="0.45" Color="Black"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Reset stats?" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="This permanently clears all locally-stored listening and analysis statistics. This cannot be undone."
                               FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset" Click="WrappedResetConfirmYes_Click"
                                Style="{StaticResource WrappedSecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Click="WrappedResetConfirmCancel_Click"
                                Style="{StaticResource WrappedPrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

    </Grid>
</Window>
