<Window x:Class="AudioQualityChecker.MetadataEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="700" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBg}"
        Foreground="{DynamicResource TextPrimary}"
        AllowsTransparency="True">

    <Window.Resources>
        <!-- Themed TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small themed button -->
        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{DynamicResource ButtonHover}"/>
                                <Setter TargetName="bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button style -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Danger button style -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
            <Setter Property="Foreground" Value="#FFFF6666"/>
        </Style>

        <!-- ═══ Themed Scrollbar Styles ═══ -->
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                                Background="{DynamicResource ScrollThumb}"
                                CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background"
                                        Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollBg}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="{DynamicResource ScrollBg}" CornerRadius="4"/>
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageButton}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="6">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" MouseLeftButtonDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource AccentColor}" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Edit Metadata"
                               FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>
                <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="Close_Click" Cursor="Hand"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="{DynamicResource TextMuted}" Padding="6,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" CornerRadius="3" Padding="6,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#44FF4444"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Scrollable content area -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <!-- File name display -->
                    <TextBlock x:Name="FileNameLabel" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextMuted}" TextTrimming="CharacterEllipsis"
                               Margin="0,0,0,12"/>

                    <!-- Title -->
                    <TextBlock Text="Title" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TitleBox" Margin="0,0,0,10"/>

                    <!-- Artist -->
                    <TextBlock Text="Artist" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="ArtistBox" Margin="0,0,0,10"/>

                    <!-- Album -->
                    <TextBlock Text="Album" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="AlbumBox" Margin="0,0,0,10"/>

                    <!-- Album Artist -->
                    <TextBlock Text="Album Artist" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="AlbumArtistBox" Margin="0,0,0,10"/>

                    <!-- Year -->
                    <TextBlock Text="Year" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="YearBox" Margin="0,0,0,10"/>

                    <!-- Track Number / Disc Number -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Track #" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TrackNumberBox"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Disc #" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                            <TextBox x:Name="DiscNumberBox"/>
                        </StackPanel>
                    </Grid>

                    <!-- Genre -->
                    <TextBlock Text="Genre" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="GenreBox" Margin="0,0,0,10"/>

                    <!-- Composer -->
                    <TextBlock Text="Composer" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="ComposerBox" Margin="0,0,0,10"/>

                    <!-- Conductor -->
                    <TextBlock Text="Conductor" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="ConductorBox" Margin="0,0,0,10"/>

                    <!-- Copyright -->
                    <TextBlock Text="Copyright" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="CopyrightBox" Margin="0,0,0,10"/>

                    <!-- Comment -->
                    <TextBlock Text="Comment" FontSize="12" FontFamily="Segoe UI"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBox x:Name="CommentBox" Height="60" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,10"/>

                    <!-- Album Cover Section -->
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                            Padding="0,10,0,0" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="Album Cover" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="80" Height="80"
                                        Background="{DynamicResource InputBg}"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        BorderThickness="1" CornerRadius="3">
                                    <Image x:Name="CoverPreview" Stretch="UniformToFill"/>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <TextBlock x:Name="CoverInfoText" FontSize="11" FontFamily="Segoe UI"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Replace..." Style="{StaticResource SmallButton}"
                                                Click="ReplaceCover_Click" Margin="0,0,6,0"/>
                                        <Button Content="Remove" Style="{StaticResource DangerButton}"
                                                Click="RemoveCover_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Search Metadata Online -->
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                            Padding="0,10,0,0" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Search Metadata Online" FontSize="12" FontFamily="Segoe UI"
                                       Foreground="{DynamicResource TextSecondary}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Look up this track on metadata databases" FontSize="11"
                                       FontFamily="Segoe UI" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Content="MusicBrainz" Style="{StaticResource SmallButton}"
                                        Click="SearchMusicBrainz_Click" Margin="0,0,6,6"/>
                                <Button Content="Discogs" Style="{StaticResource SmallButton}"
                                        Click="SearchDiscogs_Click" Margin="0,0,6,6"/>
                                <Button Content="AllMusic" Style="{StaticResource SmallButton}"
                                        Click="SearchAllMusic_Click" Margin="0,0,6,6"/>
                                <Button Content="Rate Your Music" Style="{StaticResource SmallButton}"
                                        Click="SearchRateYourMusic_Click" Margin="0,0,6,6"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Remove All Metadata -->
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0"
                            Padding="0,10,0,0" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Strip All Metadata" FontSize="12" FontFamily="Segoe UI"
                                           Foreground="#FFFF6666" FontWeight="SemiBold"/>
                                <TextBlock Text="Removes all tags from the file" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Strip All" Style="{StaticResource DangerButton}"
                                    Click="StripAllMetadata_Click" VerticalAlignment="Center"
                                    Padding="12,6"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" FontSize="11" FontFamily="Segoe UI"
                           Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SmallButton}"
                        Click="Close_Click" Padding="16,6"/>
                <Button Grid.Column="3" Content="Save" Style="{StaticResource AccentButton}"
                        Click="Save_Click" Padding="16,6"/>
            </Grid>
        </Grid>
    </Border>
</Window>
