<Window x:Class="AudioQualityChecker.Windows.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to AudioAuditor"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="740" Height="600"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseDown">

    <Border Background="#FF151515" BorderBrush="#FF333333" BorderThickness="1.5" CornerRadius="10">
        <Grid Margin="28,22,28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,4" HorizontalAlignment="Center">
                <Image Source="/Resources/icon.png" Width="40" Height="40" HorizontalAlignment="Center"
                       Margin="0,0,0,10" RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="WelcomeTitle" Text="Welcome to AudioAuditor" FontSize="20" FontWeight="Bold"
                           FontFamily="Segoe UI" Foreground="#FFEEEEEE" HorizontalAlignment="Center"/>
                <TextBlock Text="Complete audio analysis, playback, and management for Windows."
                           FontSize="12" FontFamily="Segoe UI" Foreground="#FF888888"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Divider -->
            <Border Grid.Row="1" Height="1" Background="#FF2A2A2A" Margin="0,10,0,12"/>

            <!-- Scrollable content -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                <ScrollViewer.Resources>
                    <!-- Themed CheckBox style matching the Feature Config Overlay -->
                    <Style TargetType="CheckBox">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="CheckBox">
                                    <StackPanel Orientation="Horizontal" Background="Transparent">
                                        <Border x:Name="CheckBorder" Width="18" Height="18"
                                                CornerRadius="3" BorderThickness="1.5"
                                                BorderBrush="{DynamicResource AccentColor}"
                                                Background="Transparent"
                                                VerticalAlignment="Top" Margin="0,2,0,0">
                                            <TextBlock x:Name="CheckMark" Text="✓" FontSize="12" FontWeight="Bold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Margin="0,-1,0,0"
                                                       Visibility="Collapsed"/>
                                        </Border>
                                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Top"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="CheckBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CheckBorder" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="CheckBorder" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ScrollViewer.Resources>
                <StackPanel>

                    <!-- Online / Offline choice -->
                    <TextBlock Text="Connection Mode" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="#FFCCCCCC" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Online Panel -->
                        <Border Grid.Column="0" Background="#FF1A1A2A" CornerRadius="8"
                                BorderThickness="2" x:Name="OnlinePanelBorder" Cursor="Hand"
                                MouseLeftButtonDown="OnlinePanel_Click">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF5588FF"/>
                            </Border.BorderBrush>
                            <StackPanel Margin="14,12">
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Online Mode" FontSize="14" FontWeight="Bold"
                                               FontFamily="Segoe UI" Foreground="#FF88AAFF"/>
                                    <Border Grid.Column="1" Background="#FF223355" CornerRadius="3"
                                            Padding="5,1" VerticalAlignment="Center">
                                        <TextBlock Text="★ Recommended" FontSize="10" FontFamily="Segoe UI"
                                                   Foreground="#FF88AAFF" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                                <TextBlock Text="Full features: lyrics, AI detection, updates, Last.fm, Discord, AcoustID."
                                           FontSize="11" Foreground="#FF9999BB" FontFamily="Segoe UI"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Offline Panel -->
                        <Border Grid.Column="2" Background="#FF181818" CornerRadius="8"
                                BorderThickness="1.5" x:Name="OfflinePanelBorder" BorderBrush="#FF2D2D2D"
                                Cursor="Hand" MouseLeftButtonDown="OfflinePanel_Click">
                            <StackPanel Margin="14,12">
                                <TextBlock Text="Offline Mode" FontSize="14" FontWeight="Bold"
                                           FontFamily="Segoe UI" Foreground="#FF888888" Margin="0,0,0,4"/>
                                <TextBlock Text="No network. All local features work: scanning, playback, EQ, metadata, spectrograms."
                                           FontSize="11" Foreground="#FF777777" FontFamily="Segoe UI"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Text="You can switch modes anytime in Settings."
                               FontSize="11" Foreground="#FF555577" FontFamily="Segoe UI"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>

                    <!-- Feature Highlights -->
                    <TextBlock Text="Feature Highlights" FontSize="13" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="#FFCCCCCC" Margin="0,16,0,8"/>
                    <TextBlock Text="Toggle features you want enabled. You can change these later in Settings."
                               FontSize="11" Foreground="#FF888888" FontFamily="Segoe UI"
                               Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <CheckBox x:Name="ChkSilence" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="Silence Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkFakeStereo" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="Fake Stereo Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkDR" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="Dynamic Range (DR Score)" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkTruePeak" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="True Peak" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkLufs" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="LUFS" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkClipping" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="Clipping Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <CheckBox x:Name="ChkMqa" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="MQA Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkBpm" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="BPM Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkDefaultAi" IsChecked="True" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="AI Detection (Watermark)" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkExperimentalAi" IsChecked="False" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="Aggressive AI Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkRipQuality" IsChecked="False" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="Rip Quality Check" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                            <CheckBox x:Name="ChkSHLabs" IsChecked="False" Margin="0,5" Cursor="Hand">
                                <TextBlock Text="SH Labs AI Detection" FontSize="12.5" FontWeight="SemiBold"
                                           FontFamily="Segoe UI" Foreground="#FFBBBBDD"/>
                            </CheckBox>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Grid Grid.Row="4" Margin="0,12,0,0">
                <Button x:Name="BtnGetStarted" Click="BtnGetStarted_Click"
                        Padding="0,11" Cursor="Hand" HorizontalAlignment="Stretch">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="#FF2244AA" BorderBrush="#FF5588FF"
                                    BorderThickness="1.5" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#FF3355CC"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="#FF77AAFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Get Started" FontFamily="Segoe UI" FontSize="14"
                               FontWeight="SemiBold" Foreground="#FFEEEEFF"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
