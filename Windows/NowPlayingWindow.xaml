<Window x:Class="AudioQualityChecker.NowPlayingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Now Playing"
        Height="680" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="#FF0A0A0F"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Button style for controls -->
        <Style x:Key="NpButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Play button (white bg, dark icon) -->
        <Style x:Key="NpPlayButton" TargetType="Button">
            <Setter Property="Background" Value="#EEFFFFFF"/>
            <Setter Property="Foreground" Value="#FF111111"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="24" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#CCFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Background gradient (dynamically colored from album art) -->
        <Border x:Name="BgGradient" Opacity="0.8"/>

        <!-- Dark overlay for readability -->
        <Border Background="#88000000"/>

        <DockPanel>
            <!-- ═══ Bottom: Controls Bar ═══ -->
            <Border DockPanel.Dock="Bottom" Padding="24,12" Background="#44000000">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Seek bar row -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="NpTimeElapsed" Grid.Column="0" Text="0:00"
                                   Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontFamily="Consolas"/>
                        <Slider x:Name="NpSeekSlider" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                ValueChanged="NpSeekSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="NpSeekSlider_MouseDown"
                                PreviewMouseLeftButtonUp="NpSeekSlider_MouseUp"/>
                        <TextBlock x:Name="NpTimeTotal" Grid.Column="2" Text="0:00"
                                   Foreground="#88FFFFFF" FontSize="11" VerticalAlignment="Center"
                                   Margin="8,0,0,0" FontFamily="Consolas"/>
                    </Grid>

                    <!-- Controls row -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Song info -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center"
                                    Margin="0,0,16,0">
                            <TextBlock x:Name="NpSongTitle" Text="No track playing"
                                       Foreground="White" FontSize="15" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" MaxHeight="22"/>
                            <TextBlock x:Name="NpSongArtist" Text=""
                                       Foreground="#99FFFFFF" FontSize="12"
                                       TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                        </StackPanel>

                        <!-- Center: Play controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Button Style="{StaticResource NpButton}" Click="NpShuffle_Click" ToolTip="Shuffle">
                                <TextBlock x:Name="NpShuffleIcon" Text="&#x1F500;" FontSize="16"
                                           Foreground="#CCFFFFFF"/>
                            </Button>
                            <Button Style="{StaticResource NpButton}" Click="NpPrev_Click" ToolTip="Previous"
                                    Margin="4,0">
                                <TextBlock Text="&#x23EE;" FontSize="18" Foreground="#CCFFFFFF"/>
                            </Button>
                            <Button Style="{StaticResource NpPlayButton}" Click="NpPlayPause_Click"
                                    ToolTip="Play/Pause" Margin="4,0">
                                <TextBlock x:Name="NpPlayIcon" Text="&#x25B6;" FontSize="20"
                                           Foreground="#FF111111"/>
                            </Button>
                            <Button Style="{StaticResource NpButton}" Click="NpNext_Click" ToolTip="Next"
                                    Margin="4,0">
                                <TextBlock Text="&#x23ED;" FontSize="18" Foreground="#CCFFFFFF"/>
                            </Button>
                            <Button Style="{StaticResource NpButton}" Click="NpLyricSource_Click"
                                    ToolTip="Change lyrics source" Margin="4,0">
                                <TextBlock x:Name="NpLyricSourceText" Text="&#x1F3A4;" FontSize="16"
                                           Foreground="#CCFFFFFF"/>
                            </Button>
                        </StackPanel>

                        <!-- Right: Volume + close -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F50A;" FontSize="14" Foreground="#88FFFFFF"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Slider x:Name="NpVolumeSlider" Minimum="0" Maximum="100" Value="80"
                                    Width="100" VerticalAlignment="Center"
                                    ValueChanged="NpVolumeSlider_ValueChanged"/>
                            <Button Style="{StaticResource NpButton}" Click="NpClose_Click"
                                    ToolTip="Back to main" Padding="8,6" Margin="8,0,0,0">
                                <TextBlock Text="&#x2715;" FontSize="14" Foreground="#CCFFFFFF"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ Main Content: Cover + Lyrics ═══ -->
            <Grid Margin="40,40,40,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Album Cover with glow -->
                <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Margin="0,0,20,0">
                    <!-- Outer glow layers -->
                    <Border x:Name="NpCoverGlow1" CornerRadius="20" Opacity="0.4"
                            Margin="-24" IsHitTestVisible="False"/>
                    <Border x:Name="NpCoverGlow2" CornerRadius="16" Opacity="0.25"
                            Margin="-16" IsHitTestVisible="False"/>
                    <!-- Cover image -->
                    <Border x:Name="NpCoverBorder" CornerRadius="12"
                            Background="#FF111111" ClipToBounds="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.4" Color="Black"/>
                        </Border.Effect>
                        <Image x:Name="NpCoverImage" Stretch="Uniform"
                               MaxWidth="420" MaxHeight="420"/>
                    </Border>
                </Grid>

                <!-- Right: Lyrics panel -->
                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Lyrics header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock x:Name="NpLyricsTitle" Text="Lyrics"
                                   Foreground="#BBFFFFFF" FontSize="14" FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="NpLyricsSource" Text=""
                                   Foreground="#55FFFFFF" FontSize="11"/>
                    </StackPanel>

                    <!-- Scrolling lyrics -->
                    <ScrollViewer x:Name="LyricsScroller" Grid.Row="1"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="LyricsPanel" Margin="0,40,16,120">
                            <TextBlock x:Name="NpNoLyrics"
                                       Text="No lyrics available for this track"
                                       Foreground="#44FFFFFF" FontSize="16"
                                       FontStyle="Italic" Margin="0,60,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
